<http://w3id.org/sepses/resource/cve/CVE-1999-1122> a cve:CVE ;
    cve:description "Vulnerability in restore in SunOS 4.0.3 and earlier allows local users to gain privileges." ;
    cve:id "CVE-1999-1122" .


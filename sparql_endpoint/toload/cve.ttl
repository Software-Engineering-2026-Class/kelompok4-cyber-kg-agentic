<http://w3id.org/sepses/resource/cve/CVE-1999-0334> a cve:CVE ;
    cve:description "In Solaris 2.2 and 2.3, when fsck fails on startup, it allows a local user with physical access to obtain root access." ;
    cve:id "CVE-1999-0334" .

<http://w3id.org/sepses/resource/cve/CVE-1999-0337> a cve:CVE ;
    cve:description "AIX batch queue (bsh) allows local and remote users to gain additional privileges when network printing is enabled." ;
    cve:id "CVE-1999-0337" .

<http://w3id.org/sepses/resource/cve/CVE-1999-0338> a cve:CVE ;
    cve:description "AIX Licensed Program Product performance tools allow local users to gain root access." ;
    cve:id "CVE-1999-0338" .

<http://w3id.org/sepses/resource/cve/CVE-1999-0423> a cve:CVE ;
    cve:description "Vulnerability in hpterm on HP-UX 10.20 allows local users to gain additional privileges." ;
    cve:id "CVE-1999-0423" .

<http://w3id.org/sepses/resource/cve/CVE-1999-0498> a cve:CVE ;
    cve:description "TFTP is not running in a restricted directory, allowing a remote attacker to access sensitive information such as password files." ;
    cve:id "CVE-1999-0498" .

<http://w3id.org/sepses/resource/cve/CVE-1999-0627> a cve:CVE ;
    cve:description "The rexd service is running, which uses weak authentication that can allow an attacker to execute commands." ;

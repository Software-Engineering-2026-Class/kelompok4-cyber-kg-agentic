@prefix cwe: <http://w3id.org/sepses/vocab/ref/cwe#> .

<http://w3id.org/sepses/resource/cwe/CWE-1004> a cwe:CWE ;
    cwe:description "The product uses a cookie to store sensitive information, but the cookie is not marked with the HttpOnly flag." ;
    cwe:id "CWE-1004" ;
    cwe:name "Sensitive Cookie Without 'HttpOnly' Flag" .

<http://w3id.org/sepses/resource/cwe/CWE-1007> a cwe:CWE ;
    cwe:description "The product displays information or identifiers to a user, but the display mechanism does not make it easy for the user to distinguish between visually similar or identical glyphs (homoglyphs), which may cause the user to misinterpret a glyph and perform an unintended, insecure action." ;
    cwe:id "CWE-1007" ;
    cwe:name "Insufficient Visual Distinction of Homoglyphs Presented to User" .

<http://w3id.org/sepses/resource/cwe/CWE-102> a cwe:CWE ;
    cwe:description "The product uses multiple validation forms with the same name, which might cause the Struts Validator to validate a form that the programmer does not expect." ;
    cwe:id "CWE-102" ;
    cwe:name "Struts: Duplicate Validation Forms" .

<http://w3id.org/sepses/resource/cwe/CWE-1021> a cwe:CWE ;
    cwe:description "The web application does not restrict or incorrectly restricts frame objects or UI layers that belong to another application or domain." ;
    cwe:id "CWE-1021" ;
    cwe:name "Improper Restriction of Rendered UI Layers or Frames" .

<http://w3id.org/sepses/resource/cwe/CWE-1022> a cwe:CWE ;
    cwe:description "The web application produces links to untrusted external sites outside of its sphere of control, but it does not properly prevent the external site from modifying security-critical properties of the window.opener object, such as the location property." ;
    cwe:id "CWE-1022" ;
    cwe:name "Use of Web Link to Untrusted Target with window.opener Access" .

<http://w3id.org/sepses/resource/cwe/CWE-1023> a cwe:CWE ;
    cwe:description "The product performs a comparison between entities that must consider multiple factors or characteristics of each entity, but the comparison does not include one or more of these factors." ;
    cwe:id "CWE-1023" ;
    cwe:name "Incomplete Comparison with Missing Factors" .

<http://w3id.org/sepses/resource/cwe/CWE-1024> a cwe:CWE ;
    cwe:description "The product performs a comparison between two entities, but the entities are of different, incompatible types that cannot be guaranteed to provide correct results when they are directly compared." ;
    cwe:id "CWE-1024" ;
    cwe:name "Comparison of Incompatible Types" .

<http://w3id.org/sepses/resource/cwe/CWE-1025> a cwe:CWE ;
    cwe:description "The code performs a comparison between two entities, but the comparison examines the wrong factors or characteristics of the entities, which can lead to incorrect results and resultant weaknesses." ;
    cwe:id "CWE-1025" ;
    cwe:name "Comparison Using Wrong Factors" .

<http://w3id.org/sepses/resource/cwe/CWE-103> a cwe:CWE ;
    cwe:description "The product has a validator form that either does not define a validate() method, or defines a validate() method but does not call super.validate()." ;
    cwe:id "CWE-103" ;
    cwe:name "Struts: Incomplete validate() Method Definition" .

<http://w3id.org/sepses/resource/cwe/CWE-1037> a cwe:CWE ;
    cwe:description "The developer builds a security-critical protection mechanism into the software, but the processor optimizes the execution of the program such that the mechanism is removed or modified." ;
    cwe:id "CWE-1037" ;
    cwe:name "Processor Optimization Removal or Modification of Security-critical Code" .

<http://w3id.org/sepses/resource/cwe/CWE-1038> a cwe:CWE ;
    cwe:description "The product uses a mechanism that automatically optimizes code, e.g. to improve a characteristic such as performance, but the optimizations can have an unintended side effect that might violate an intended security assumption." ;
    cwe:id "CWE-1038" ;
    cwe:name "Insecure Automated Optimizations" .

<http://w3id.org/sepses/resource/cwe/CWE-1039> a cwe:CWE ;
    cwe:description "The product uses an automated mechanism such as machine learning to recognize complex data inputs (e.g. image or audio) as a particular concept or category, but it does not properly detect or handle inputs that have been modified or constructed in a way that causes the mechanism to detect a different, incorrect concept." ;
    cwe:id "CWE-1039" ;
    cwe:name "Inadequate Detection or Handling of Adversarial Input Perturbations in Automated Recognition Mechanism" .

<http://w3id.org/sepses/resource/cwe/CWE-104> a cwe:CWE ;
    cwe:description "If a form bean does not extend an ActionForm subclass of the Validator framework, it can expose the application to other weaknesses related to insufficient input validation." ;
    cwe:id "CWE-104" ;
    cwe:name "Struts: Form Bean Does Not Extend Validation Class" .

<http://w3id.org/sepses/resource/cwe/CWE-1041> a cwe:CWE ;
    cwe:description """The product has multiple functions, methods, procedures, macros, etc. that
					contain the same code.""" ;
    cwe:id "CWE-1041" ;
    cwe:name "Use of Redundant Code" .

<http://w3id.org/sepses/resource/cwe/CWE-1042> a cwe:CWE ;
    cwe:description """The code contains a member element that is declared as static (but not final), in which
					its parent class element 
					is not a singleton class - that is, a class element that can be used only once in
					the 'to' association of a Create action.""" ;
    cwe:id "CWE-1042" ;
    cwe:name "Static Member Data Element outside of a Singleton Class Element" .

<http://w3id.org/sepses/resource/cwe/CWE-1043> a cwe:CWE ;
    cwe:description """The product uses a data element that has an excessively large
					number of sub-elements with non-primitive data types such as structures or aggregated objects.""" ;
    cwe:id "CWE-1043" ;
    cwe:name "Data Element Aggregating an Excessively Large Number of Non-Primitive Elements" .

<http://w3id.org/sepses/resource/cwe/CWE-1044> a cwe:CWE ;
    cwe:description """The product's architecture contains too many - or too few -
					horizontal layers.""" ;
    cwe:id "CWE-1044" ;
    cwe:name "Architecture with Number of Horizontal Layers Outside of Expected Range" .

<http://w3id.org/sepses/resource/cwe/CWE-1045> a cwe:CWE ;
    cwe:description "A parent class has a virtual destructor method, but the parent has a child class that does not have a virtual destructor." ;
    cwe:id "CWE-1045" ;
    cwe:name "Parent Class with a Virtual Destructor and a Child Class without a Virtual Destructor" .

<http://w3id.org/sepses/resource/cwe/CWE-1046> a cwe:CWE ;
    cwe:description "The product creates an immutable text string using string concatenation operations." ;
    cwe:id "CWE-1046" ;
    cwe:name "Creation of Immutable Text Using String Concatenation" .

<http://w3id.org/sepses/resource/cwe/CWE-1047> a cwe:CWE ;
    cwe:description "The product contains modules in which one module has references that cycle back to itself, i.e., there are circular dependencies." ;
    cwe:id "CWE-1047" ;
    cwe:name "Modules with Circular Dependencies" .

<http://w3id.org/sepses/resource/cwe/CWE-1048> a cwe:CWE ;
    cwe:description """The code contains callable control elements that
         contain an excessively large number of references to other
         application objects external to the context of the callable,
         i.e. a Fan-Out value that is excessively large.""" ;
    cwe:id "CWE-1048" ;
    cwe:name "Invokable Control Element with Large Number of Outward Calls" .

<http://w3id.org/sepses/resource/cwe/CWE-1049> a cwe:CWE ;
    cwe:description """The product performs a data query with a large number of joins
					and sub-queries on a large data table.""" ;
    cwe:id "CWE-1049" ;
    cwe:name "Excessive Data Query Operations in a Large Data Table" .

<http://w3id.org/sepses/resource/cwe/CWE-105> a cwe:CWE ;
    cwe:description "The product has a form field that is not validated by a corresponding validation form, which can introduce other weaknesses related to insufficient input validation." ;
    cwe:id "CWE-105" ;
    cwe:name "Struts: Form Field Without Validator" .

<http://w3id.org/sepses/resource/cwe/CWE-1050> a cwe:CWE ;
    cwe:description """The product has a loop body or loop condition that contains a control element that directly or
					indirectly consumes platform resources, e.g. messaging, sessions, locks, or file
					descriptors.""" ;
    cwe:id "CWE-1050" ;
    cwe:name "Excessive Platform Resource Consumption within a Loop" .

<http://w3id.org/sepses/resource/cwe/CWE-1051> a cwe:CWE ;
    cwe:description "The product initializes data using hard-coded values that act as network resource identifiers." ;
    cwe:id "CWE-1051" ;
    cwe:name "Initialization with Hard-Coded Network Resource Configuration Data" .

<http://w3id.org/sepses/resource/cwe/CWE-1052> a cwe:CWE ;
    cwe:description """The product initializes a data element using a hard-coded
					literal that is not a simple integer or static constant element.""" ;
    cwe:id "CWE-1052" ;
    cwe:name "Excessive Use of Hard-Coded Literals in Initialization" .

<http://w3id.org/sepses/resource/cwe/CWE-1053> a cwe:CWE ;
    cwe:description "The product does not have documentation that represents how it is designed." ;
    cwe:id "CWE-1053" ;
    cwe:name "Missing Documentation for Design" .

<http://w3id.org/sepses/resource/cwe/CWE-1054> a cwe:CWE ;
    cwe:description """The code at one architectural layer invokes code that resides
					at a deeper layer than the adjacent layer, i.e., the invocation skips at least one
					layer, and the invoked code is not part of a vertical utility layer that can be referenced from any horizontal layer.""" ;
    cwe:id "CWE-1054" ;
    cwe:name "Invocation of a Control Element at an Unnecessarily Deep Horizontal Layer" .

<http://w3id.org/sepses/resource/cwe/CWE-1055> a cwe:CWE ;
    cwe:description """The product contains a class with inheritance from more than
					one concrete class.""" ;
    cwe:id "CWE-1055" ;
    cwe:name "Multiple Inheritance from Concrete Classes" .

<http://w3id.org/sepses/resource/cwe/CWE-1056> a cwe:CWE ;
    cwe:description """A named-callable or method control element has a signature that
					supports a variable (variadic) number of parameters or arguments.""" ;
    cwe:id "CWE-1056" ;
    cwe:name "Invokable Control Element with Variadic Parameters" .

<http://w3id.org/sepses/resource/cwe/CWE-1057> a cwe:CWE ;
    cwe:description "The product uses a dedicated, central data manager component as required by design, but it contains code that performs data-access operations that do not use this data manager." ;
    cwe:id "CWE-1057" ;
    cwe:name "Data Access Operations Outside of Expected Data Manager Component" .

<http://w3id.org/sepses/resource/cwe/CWE-1058> a cwe:CWE ;
    cwe:description """The code contains a function or method that
		 operates in a multi-threaded environment but owns an unsafe non-final
		                     static storable or member data element.""" ;
    cwe:id "CWE-1058" ;
    cwe:name "Invokable Control Element in Multi-Thread Context with non-Final Static Storable or Member Element" .

<http://w3id.org/sepses/resource/cwe/CWE-1059> a cwe:CWE ;
    cwe:description """The product does not contain sufficient
         technical or engineering documentation (whether on paper or
         in electronic form) that contains descriptions of all the
         relevant software/hardware elements of the product, such as
         its usage, structure, architectural components, interfaces, design, implementation,
         configuration, operation, etc.""" ;
    cwe:id "CWE-1059" ;
    cwe:name "Insufficient Technical Documentation" .

<http://w3id.org/sepses/resource/cwe/CWE-106> a cwe:CWE ;
    cwe:description "When an application does not use an input validation framework such as the Struts Validator, there is a greater risk of introducing weaknesses related to insufficient input validation." ;
    cwe:id "CWE-106" ;
    cwe:name "Struts: Plug-in Framework not in Use" .

<http://w3id.org/sepses/resource/cwe/CWE-1060> a cwe:CWE ;
    cwe:description "The product performs too many data queries without using efficient data processing functionality such as stored procedures." ;
    cwe:id "CWE-1060" ;
    cwe:name "Excessive Number of Inefficient Server-Side Data Accesses" .

<http://w3id.org/sepses/resource/cwe/CWE-1061> a cwe:CWE ;
    cwe:description "The product does not sufficiently hide the internal representation and implementation details of data or methods, which might allow external components or modules to modify data unexpectedly, invoke unexpected functionality, or introduce dependencies that the programmer did not intend." ;
    cwe:id "CWE-1061" ;
    cwe:name "Insufficient Encapsulation" .

<http://w3id.org/sepses/resource/cwe/CWE-1062> a cwe:CWE ;
    cwe:description "The code has a parent class that contains references to a child class, its methods, or its members." ;
    cwe:id "CWE-1062" ;
    cwe:name "Parent Class with References to Child Class" .

<http://w3id.org/sepses/resource/cwe/CWE-1063> a cwe:CWE ;
    cwe:description "A static code block creates an instance of a class." ;
    cwe:id "CWE-1063" ;
    cwe:name "Creation of Class Instance within a Static Code Block" .

<http://w3id.org/sepses/resource/cwe/CWE-1064> a cwe:CWE ;
    cwe:description """The product contains a function, subroutine, or method whose signature has an unnecessarily large number of
					parameters/arguments.""" ;
    cwe:id "CWE-1064" ;
    cwe:name "Invokable Control Element with Signature Containing an Excessive Number of Parameters" .

<http://w3id.org/sepses/resource/cwe/CWE-1065> a cwe:CWE ;
    cwe:description "The product uses deployed components from application servers, but it also uses low-level functions/methods for management of resources, instead of the API provided by the application server." ;
    cwe:id "CWE-1065" ;
    cwe:name "Runtime Resource Management Control Element in a Component Built to Run on Application Servers" .

<http://w3id.org/sepses/resource/cwe/CWE-1066> a cwe:CWE ;
    cwe:description """The product contains a serializable data element that does not
					have an associated serialization method.""" ;
    cwe:id "CWE-1066" ;
    cwe:name "Missing Serialization Control Element" .

<http://w3id.org/sepses/resource/cwe/CWE-1067> a cwe:CWE ;
    cwe:description """The product contains a data query against an SQL table or view
					that is configured in a way that does not utilize an index and may cause
					sequential searches to be performed.""" ;
    cwe:id "CWE-1067" ;
    cwe:name "Excessive Execution of Sequential Searches of Data Resource" .

<http://w3id.org/sepses/resource/cwe/CWE-1068> a cwe:CWE ;
    cwe:description """The implementation of the product is not consistent with the
					design as described within the relevant documentation.""" ;
    cwe:id "CWE-1068" ;
    cwe:name "Inconsistency Between Implementation and Documented Design" .

<http://w3id.org/sepses/resource/cwe/CWE-1069> a cwe:CWE ;
    cwe:description "An invokable code block contains an exception handling block that does not contain any code, i.e. is empty." ;
    cwe:id "CWE-1069" ;
    cwe:name "Empty Exception Block" .

<http://w3id.org/sepses/resource/cwe/CWE-107> a cwe:CWE ;
    cwe:description "An unused validation form indicates that validation logic is not up-to-date." ;
    cwe:id "CWE-107" ;
    cwe:name "Struts: Unused Validation Form" .

<http://w3id.org/sepses/resource/cwe/CWE-1070> a cwe:CWE ;
    cwe:description """The product contains a serializable, storable data element such as a field or member,
					but the data element contains member elements that are not
					serializable.""" ;
    cwe:id "CWE-1070" ;
    cwe:name "Serializable Data Element Containing non-Serializable Item Elements" .

<http://w3id.org/sepses/resource/cwe/CWE-1071> a cwe:CWE ;
    cwe:description "The source code contains a block that does not contain any code, i.e., the block is empty." ;
    cwe:id "CWE-1071" ;
    cwe:name "Empty Code Block" .

<http://w3id.org/sepses/resource/cwe/CWE-1072> a cwe:CWE ;
    cwe:description """The product accesses a data resource through a database without using a
					connection pooling capability.""" ;
    cwe:id "CWE-1072" ;
    cwe:name "Data Resource Access without Use of Connection Pooling" .

<http://w3id.org/sepses/resource/cwe/CWE-1073> a cwe:CWE ;
    cwe:description "The product contains a client with a function or method that contains a large number of data accesses/queries that are sent through a data manager, i.e., does not use efficient database capabilities." ;
    cwe:id "CWE-1073" ;
    cwe:name "Non-SQL Invokable Control Element with Excessive Number of Data Resource Accesses" .

<http://w3id.org/sepses/resource/cwe/CWE-1074> a cwe:CWE ;
    cwe:description """A class has an inheritance level that is too high, i.e., it
					has a large number of parent classes.""" ;
    cwe:id "CWE-1074" ;
    cwe:name "Class with Excessively Deep Inheritance" .

<http://w3id.org/sepses/resource/cwe/CWE-1075> a cwe:CWE ;
    cwe:description """The product performs unconditional control transfer (such as a
					"goto") in code outside of a branching structure such as a switch
					block.""" ;
    cwe:id "CWE-1075" ;
    cwe:name "Unconditional Control Flow Transfer outside of Switch Block" .

<http://w3id.org/sepses/resource/cwe/CWE-1076> a cwe:CWE ;
    cwe:description """The product's architecture, source code, design, documentation,
					or other artifact does not follow required conventions.""" ;
    cwe:id "CWE-1076" ;
    cwe:name "Insufficient Adherence to Expected Conventions" .

<http://w3id.org/sepses/resource/cwe/CWE-1077> a cwe:CWE ;
    cwe:description """The code performs a comparison such as an
        equality test between two float (floating point) values, but
        it uses comparison operators that do not account for the
        possibility of loss of precision.""" ;
    cwe:id "CWE-1077" ;
    cwe:name "Floating Point Comparison with Incorrect Operator" .

<http://w3id.org/sepses/resource/cwe/CWE-1078> a cwe:CWE ;
    cwe:description """The source code does not follow
				desired style or formatting for indentation, white
				space, comments, etc.""" ;
    cwe:id "CWE-1078" ;
    cwe:name "Inappropriate Source Code Style or Formatting" .

<http://w3id.org/sepses/resource/cwe/CWE-1079> a cwe:CWE ;
    cwe:description "A parent class contains one or more child classes, but the parent class does not have a virtual destructor method." ;
    cwe:id "CWE-1079" ;
    cwe:name "Parent Class without Virtual Destructor Method" .

<http://w3id.org/sepses/resource/cwe/CWE-108> a cwe:CWE ;
    cwe:description "Every Action Form must have a corresponding validation form." ;
    cwe:id "CWE-108" ;
    cwe:name "Struts: Unvalidated Action Form" .

<http://w3id.org/sepses/resource/cwe/CWE-1080> a cwe:CWE ;
    cwe:description """A source code file has too many lines of
					code.""" ;
    cwe:id "CWE-1080" ;
    cwe:name "Source Code File with Excessive Number of Lines of Code" .

<http://w3id.org/sepses/resource/cwe/CWE-1082> a cwe:CWE ;
    cwe:description "The code contains a class instance that calls the method or function to delete or destroy itself." ;
    cwe:id "CWE-1082" ;
    cwe:name "Class Instance Self Destruction Control Element" .

<http://w3id.org/sepses/resource/cwe/CWE-1083> a cwe:CWE ;
    cwe:description "The product is intended to manage data access through a particular data manager component such as a relational or non-SQL database, but it contains code that performs data access operations without using that component." ;
    cwe:id "CWE-1083" ;
    cwe:name "Data Access from Outside Expected Data Manager Component" .

<http://w3id.org/sepses/resource/cwe/CWE-1084> a cwe:CWE ;
    cwe:description """A function or method contains too many
					operations that utilize a data manager or file resource.""" ;
    cwe:id "CWE-1084" ;
    cwe:name "Invokable Control Element with Excessive File or Data Access Operations" .

<http://w3id.org/sepses/resource/cwe/CWE-1085> a cwe:CWE ;
    cwe:description """A function, method, procedure, etc. contains an excessive amount of code that has been
					commented out within its body.""" ;
    cwe:id "CWE-1085" ;
    cwe:name "Invokable Control Element with Excessive Volume of Commented-out Code" .

<http://w3id.org/sepses/resource/cwe/CWE-1086> a cwe:CWE ;
    cwe:description """A class contains an unnecessarily large number of
					children.""" ;
    cwe:id "CWE-1086" ;
    cwe:name "Class with Excessive Number of Child Classes" .

<http://w3id.org/sepses/resource/cwe/CWE-1087> a cwe:CWE ;
    cwe:description "A class contains a virtual method, but the method does not have an associated virtual destructor." ;
    cwe:id "CWE-1087" ;
    cwe:name "Class with Virtual Method without a Virtual Destructor" .

<http://w3id.org/sepses/resource/cwe/CWE-1088> a cwe:CWE ;
    cwe:description "The code has a synchronous call to a remote resource, but there is no timeout for the call, or the timeout is set to infinite." ;
    cwe:id "CWE-1088" ;
    cwe:name "Synchronous Access of Remote Resource without Timeout" .

<http://w3id.org/sepses/resource/cwe/CWE-1089> a cwe:CWE ;
    cwe:description """The product uses a large data table that contains an excessively large number of
					indices.""" ;
    cwe:id "CWE-1089" ;
    cwe:name "Large Data Table with Excessive Number of Indices" .

<http://w3id.org/sepses/resource/cwe/CWE-109> a cwe:CWE ;
    cwe:description "Automatic filtering via a Struts bean has been turned off, which disables the Struts Validator and custom validation logic. This exposes the application to other weaknesses related to insufficient input validation." ;
    cwe:id "CWE-109" ;
    cwe:name "Struts: Validator Turned Off" .

<http://w3id.org/sepses/resource/cwe/CWE-1090> a cwe:CWE ;
    cwe:description """A method for a class performs an operation that directly
					accesses a member element from another class.""" ;
    cwe:id "CWE-1090" ;
    cwe:name "Method Containing Access of a Member Element from Another Class" .

<http://w3id.org/sepses/resource/cwe/CWE-1091> a cwe:CWE ;
    cwe:description """The product contains a method that accesses an object but does not later invoke
					the element's associated finalize/destructor method.""" ;
    cwe:id "CWE-1091" ;
    cwe:name "Use of Object without Invoking Destructor Method" .

<http://w3id.org/sepses/resource/cwe/CWE-1092> a cwe:CWE ;
    cwe:description """The product uses the same control element across multiple
					architectural layers.""" ;
    cwe:id "CWE-1092" ;
    cwe:name "Use of Same Invokable Control Element in Multiple Architectural Layers" .

<http://w3id.org/sepses/resource/cwe/CWE-1093> a cwe:CWE ;
    cwe:description "The product uses an unnecessarily complex internal representation for its data structures or interrelationships between those structures." ;
    cwe:id "CWE-1093" ;
    cwe:name "Excessively Complex Data Representation" .

<http://w3id.org/sepses/resource/cwe/CWE-1094> a cwe:CWE ;
    cwe:description """The product contains an index range scan for a large data table,
					but the scan can cover a large number of rows.""" ;
    cwe:id "CWE-1094" ;
    cwe:name "Excessive Index Range Scan for a Data Resource" .

<http://w3id.org/sepses/resource/cwe/CWE-1095> a cwe:CWE ;
    cwe:description """The product uses a loop with a control flow condition based on
					a value that is updated within the body of the loop.""" ;
    cwe:id "CWE-1095" ;
    cwe:name "Loop Condition Value Update within the Loop" .

<http://w3id.org/sepses/resource/cwe/CWE-1096> a cwe:CWE ;
    cwe:description "The product implements a Singleton design pattern but does not use appropriate locking or other synchronization mechanism to ensure that the singleton class is only instantiated once." ;
    cwe:id "CWE-1096" ;
    cwe:name "Singleton Class Instance Creation without Proper Locking or Synchronization" .

<http://w3id.org/sepses/resource/cwe/CWE-1097> a cwe:CWE ;
    cwe:description """The product uses a storable data element that does not have
					all of the associated functions or methods that are necessary to support
					comparison.""" ;
    cwe:id "CWE-1097" ;
    cwe:name "Persistent Storable Data Element without Associated Comparison Control Element" .

<http://w3id.org/sepses/resource/cwe/CWE-1098> a cwe:CWE ;
    cwe:description "The code contains a data element with a pointer that does not have an associated copy or constructor method." ;
    cwe:id "CWE-1098" ;
    cwe:name "Data Element containing Pointer Item without Proper Copy Control Element" .

<http://w3id.org/sepses/resource/cwe/CWE-1099> a cwe:CWE ;
    cwe:description """The product's code, documentation, or other artifacts do not
					consistently use the same naming conventions for variables, callables, groups of
					related callables, I/O capabilities, data types, file names, or similar types of
					elements.""" ;
    cwe:id "CWE-1099" ;
    cwe:name "Inconsistent Naming Conventions for Identifiers" .

<http://w3id.org/sepses/resource/cwe/CWE-11> a cwe:CWE ;
    cwe:description "Debugging messages help attackers learn about the system and plan a form of attack." ;
    cwe:id "CWE-11" ;
    cwe:name "ASP.NET Misconfiguration: Creating Debug Binary" .

<http://w3id.org/sepses/resource/cwe/CWE-110> a cwe:CWE ;
    cwe:description "Validation fields that do not appear in forms they are associated with indicate that the validation logic is out of date." ;
    cwe:id "CWE-110" ;
    cwe:name "Struts: Validator Without Form Field" .

<http://w3id.org/sepses/resource/cwe/CWE-1100> a cwe:CWE ;
    cwe:description """The product or code does not isolate system-dependent
					functionality into separate standalone modules.""" ;
    cwe:id "CWE-1100" ;
    cwe:name "Insufficient Isolation of System-Dependent Functions" .

<http://w3id.org/sepses/resource/cwe/CWE-1101> a cwe:CWE ;
    cwe:description """The product uses automatically-generated code that cannot be
					executed without a specific runtime support component.""" ;
    cwe:id "CWE-1101" ;
    cwe:name "Reliance on Runtime Component in Generated Code" .

<http://w3id.org/sepses/resource/cwe/CWE-1102> a cwe:CWE ;
    cwe:description """The code uses a data representation that relies on low-level
					data representation or constructs that may vary across different processors,
					physical machines, OSes, or other physical components.""" ;
    cwe:id "CWE-1102" ;
    cwe:name "Reliance on Machine-Dependent Data Representation" .

<http://w3id.org/sepses/resource/cwe/CWE-1103> a cwe:CWE ;
    cwe:description """The product relies on third-party components that do
					not provide equivalent functionality across all desirable
					platforms.""" ;
    cwe:id "CWE-1103" ;
    cwe:name "Use of Platform-Dependent Third Party Components" .

<http://w3id.org/sepses/resource/cwe/CWE-1104> a cwe:CWE ;
    cwe:description """The product relies on third-party components that are not
					actively supported or maintained by the original developer or a trusted proxy
					for the original developer.""" ;
    cwe:id "CWE-1104" ;
    cwe:name "Use of Unmaintained Third Party Components" .

<http://w3id.org/sepses/resource/cwe/CWE-1105> a cwe:CWE ;
    cwe:description """The product or code uses machine-dependent functionality, but
					it does not sufficiently encapsulate or isolate this functionality from
					the rest of the code.""" ;
    cwe:id "CWE-1105" ;
    cwe:name "Insufficient Encapsulation of Machine-Dependent Functionality" .

<http://w3id.org/sepses/resource/cwe/CWE-1106> a cwe:CWE ;
    cwe:description """The source code uses literal constants that may need to change
					or evolve over time, instead of using symbolic constants.""" ;
    cwe:id "CWE-1106" ;
    cwe:name "Insufficient Use of Symbolic Constants" .

<http://w3id.org/sepses/resource/cwe/CWE-1107> a cwe:CWE ;
    cwe:description """The source code uses symbolic constants, but it does not
					sufficiently place the definitions of these constants into a more centralized or
					isolated location.""" ;
    cwe:id "CWE-1107" ;
    cwe:name "Insufficient Isolation of Symbolic Constant Definitions" .

<http://w3id.org/sepses/resource/cwe/CWE-1108> a cwe:CWE ;
    cwe:description """The code is structured in a way that relies too much on using
					or setting global variables throughout various points in the code, instead of
					preserving the associated information in a narrower, more local
					context.""" ;
    cwe:id "CWE-1108" ;
    cwe:name "Excessive Reliance on Global Variables" .

<http://w3id.org/sepses/resource/cwe/CWE-1109> a cwe:CWE ;
    cwe:description """The code contains a callable, block, or other code element in
					which the same variable is used to control more than one unique task or store
					more than one instance of data.""" ;
    cwe:id "CWE-1109" ;
    cwe:name "Use of Same Variable for Multiple Purposes" .

<http://w3id.org/sepses/resource/cwe/CWE-111> a cwe:CWE ;
    cwe:description "When a Java application uses the Java Native Interface (JNI) to call code written in another programming language, it can expose the application to weaknesses in that code, even if those weaknesses cannot occur in Java." ;
    cwe:id "CWE-111" ;
    cwe:name "Direct Use of Unsafe JNI" .

<http://w3id.org/sepses/resource/cwe/CWE-1110> a cwe:CWE ;
    cwe:description """The product's design documentation does not adequately describe
					control flow, data flow, system initialization, relationships between tasks,
					components, rationales, or other important aspects of the
					design.""" ;
    cwe:id "CWE-1110" ;
    cwe:name "Incomplete Design Documentation" .

<http://w3id.org/sepses/resource/cwe/CWE-1111> a cwe:CWE ;
    cwe:description """The product's documentation does not adequately define inputs,
					outputs, or system/software interfaces.""" ;
    cwe:id "CWE-1111" ;
    cwe:name "Incomplete I/O Documentation" .

<http://w3id.org/sepses/resource/cwe/CWE-1112> a cwe:CWE ;
    cwe:description """The document does not fully define all mechanisms that are used
					to control or influence how product-specific programs are
					executed.""" ;
    cwe:id "CWE-1112" ;
    cwe:name "Incomplete Documentation of Program Execution" .

<http://w3id.org/sepses/resource/cwe/CWE-1113> a cwe:CWE ;
    cwe:description """The source code uses comment styles or formats that are
					inconsistent or do not follow expected standards for the
					product.""" ;
    cwe:id "CWE-1113" ;
    cwe:name "Inappropriate Comment Style" .

<http://w3id.org/sepses/resource/cwe/CWE-1114> a cwe:CWE ;
    cwe:description """The source code contains whitespace that is inconsistent across
					the code or does not follow expected standards for the
					product.""" ;
    cwe:id "CWE-1114" ;
    cwe:name "Inappropriate Whitespace Style" .

<http://w3id.org/sepses/resource/cwe/CWE-1115> a cwe:CWE ;
    cwe:description """The source code contains elements such as source files 
					that do not consistently provide a prologue or header that has been
					standardized for the project.""" ;
    cwe:id "CWE-1115" ;
    cwe:name "Source Code Element without Standard Prologue" .

<http://w3id.org/sepses/resource/cwe/CWE-1116> a cwe:CWE ;
    cwe:description """The source code contains comments that do not accurately
					describe or explain aspects of the portion of the code with which the comment is
					associated.""" ;
    cwe:id "CWE-1116" ;
    cwe:name "Inaccurate Source Code Comments" .

<http://w3id.org/sepses/resource/cwe/CWE-1117> a cwe:CWE ;
    cwe:description """The code contains a function or method whose signature and/or associated
					inline documentation does not sufficiently describe the callable's inputs, outputs,
					side effects, assumptions, or return codes.""" ;
    cwe:id "CWE-1117" ;
    cwe:name "Callable with Insufficient Behavioral Summary" .

<http://w3id.org/sepses/resource/cwe/CWE-1118> a cwe:CWE ;
    cwe:description """The documentation does not sufficiently describe the techniques
					that are used for error handling, exception processing, or similar
					mechanisms.""" ;
    cwe:id "CWE-1118" ;
    cwe:name "Insufficient Documentation of Error Handling Techniques" .

<http://w3id.org/sepses/resource/cwe/CWE-1119> a cwe:CWE ;
    cwe:description """The code uses too many unconditional branches (such as
					"goto").""" ;
    cwe:id "CWE-1119" ;
    cwe:name "Excessive Use of Unconditional Branching" .

<http://w3id.org/sepses/resource/cwe/CWE-112> a cwe:CWE ;
    cwe:description "The product accepts XML from an untrusted source but does not validate the XML against the proper schema." ;
    cwe:id "CWE-112" ;
    cwe:name "Missing XML Validation" .

<http://w3id.org/sepses/resource/cwe/CWE-1120> a cwe:CWE ;
    cwe:description """The code is too complex, as calculated using a well-defined,
					quantitative measure.""" ;
    cwe:id "CWE-1120" ;
    cwe:name "Excessive Code Complexity" .

<http://w3id.org/sepses/resource/cwe/CWE-1121> a cwe:CWE ;
    cwe:description """The code contains McCabe cyclomatic complexity that exceeds a
	desirable maximum.""" ;
    cwe:id "CWE-1121" ;
    cwe:name "Excessive McCabe Cyclomatic Complexity" .

<http://w3id.org/sepses/resource/cwe/CWE-1122> a cwe:CWE ;
    cwe:description """The code is structured in a way that a Halstead complexity
					measure exceeds a desirable maximum.""" ;
    cwe:id "CWE-1122" ;
    cwe:name "Excessive Halstead Complexity" .

<http://w3id.org/sepses/resource/cwe/CWE-1123> a cwe:CWE ;
    cwe:description "The product uses too much self-modifying code." ;
    cwe:id "CWE-1123" ;
    cwe:name "Excessive Use of Self-Modifying Code" .

<http://w3id.org/sepses/resource/cwe/CWE-1124> a cwe:CWE ;
    cwe:description """The code contains a callable or other code grouping in which
					the nesting / branching is too deep.""" ;
    cwe:id "CWE-1124" ;
    cwe:name "Excessively Deep Nesting" .

<http://w3id.org/sepses/resource/cwe/CWE-1125> a cwe:CWE ;
    cwe:description """The product has an attack surface whose quantitative
					measurement exceeds a desirable maximum.""" ;
    cwe:id "CWE-1125" ;
    cwe:name "Excessive Attack Surface" .

<http://w3id.org/sepses/resource/cwe/CWE-1126> a cwe:CWE ;
    cwe:description """The source code declares a variable in one scope, but the
					variable is only used within a narrower scope.""" ;
    cwe:id "CWE-1126" ;
    cwe:name "Declaration of Variable with Unnecessarily Wide Scope" .

<http://w3id.org/sepses/resource/cwe/CWE-1127> a cwe:CWE ;
    cwe:description """The code is compiled without sufficient warnings enabled, which
					may prevent the detection of subtle bugs or quality
					issues.""" ;
    cwe:id "CWE-1127" ;
    cwe:name "Compilation with Insufficient Warnings or Errors" .

<http://w3id.org/sepses/resource/cwe/CWE-113> a cwe:CWE ;
    cwe:description "The product receives data from an HTTP agent/component (e.g., web server, proxy, browser, etc.), but it does not neutralize or incorrectly neutralizes CR and LF characters before the data is included in outgoing HTTP headers." ;
    cwe:id "CWE-113" ;
    cwe:name "Improper Neutralization of CRLF Sequences in HTTP Headers ('HTTP Request/Response Splitting')" .

<http://w3id.org/sepses/resource/cwe/CWE-114> a cwe:CWE ;
    cwe:description "Executing commands or loading libraries from an untrusted source or in an untrusted environment can cause an application to execute malicious commands (and payloads) on behalf of an attacker." ;
    cwe:id "CWE-114" ;
    cwe:name "Process Control" .

<http://w3id.org/sepses/resource/cwe/CWE-115> a cwe:CWE ;
    cwe:description "The product misinterprets an input, whether from an attacker or another product, in a security-relevant fashion." ;
    cwe:id "CWE-115" ;
    cwe:name "Misinterpretation of Input" .

<http://w3id.org/sepses/resource/cwe/CWE-116> a cwe:CWE ;
    cwe:description "The product prepares a structured message for communication with another component, but encoding or escaping of the data is either missing or done incorrectly. As a result, the intended structure of the message is not preserved." ;
    cwe:id "CWE-116" ;
    cwe:name "Improper Encoding or Escaping of Output" .

<http://w3id.org/sepses/resource/cwe/CWE-1164> a cwe:CWE ;
    cwe:description """The product contains code that is not essential for execution,
	     i.e. makes no state changes and has no side effects that alter
	     data or control flow, such that removal of the code would have no impact
	     to functionality or correctness.""" ;
    cwe:id "CWE-1164" ;
    cwe:name "Irrelevant Code" .

<http://w3id.org/sepses/resource/cwe/CWE-117> a cwe:CWE ;
    cwe:description "The product constructs a log message from external input, but it does not neutralize or incorrectly neutralizes special elements when the message is written to a log file." ;
    cwe:id "CWE-117" ;
    cwe:name "Improper Output Neutralization for Logs" .

<http://w3id.org/sepses/resource/cwe/CWE-1173> a cwe:CWE ;
    cwe:description "The product does not use, or incorrectly uses, an input validation framework that is provided by the source language or an independent library." ;
    cwe:id "CWE-1173" ;
    cwe:name "Improper Use of Validation Framework" .

<http://w3id.org/sepses/resource/cwe/CWE-1174> a cwe:CWE ;
    cwe:description "The ASP.NET application does not use, or incorrectly uses, the model validation framework." ;
    cwe:id "CWE-1174" ;
    cwe:name "ASP.NET Misconfiguration: Improper Model Validation" .

<http://w3id.org/sepses/resource/cwe/CWE-1176> a cwe:CWE ;
    cwe:description """The product performs CPU computations using
         algorithms that are not as efficient as they could be for the
         needs of the developer, i.e., the computations can be
         optimized further.""" ;
    cwe:id "CWE-1176" ;
    cwe:name "Inefficient CPU Computation" .

<http://w3id.org/sepses/resource/cwe/CWE-1177> a cwe:CWE ;
    cwe:description """The product uses a function, library, or third party component
	     that has been explicitly prohibited, whether by the developer or
	     the customer.""" ;
    cwe:id "CWE-1177" ;
    cwe:name "Use of Prohibited Code" .

<http://w3id.org/sepses/resource/cwe/CWE-118> a cwe:CWE ;
    cwe:description "The product does not restrict or incorrectly restricts operations within the boundaries of a resource that is accessed using an index or pointer, such as memory or files." ;
    cwe:id "CWE-118" ;
    cwe:name "Incorrect Access of Indexable Resource ('Range Error')" .

<http://w3id.org/sepses/resource/cwe/CWE-1187> a cwe:CWE ;
    cwe:description "This entry has been deprecated because it was a duplicate of CWE-908. All content has been transferred to CWE-908." ;
    cwe:id "CWE-1187" ;
    cwe:name "DEPRECATED: Use of Uninitialized Resource" .

<http://w3id.org/sepses/resource/cwe/CWE-1188> a cwe:CWE ;
    cwe:description "The product initializes or sets a resource with a default that is intended to be changed by the product's installer, administrator, or maintainer, but the default is not secure." ;
    cwe:id "CWE-1188" ;
    cwe:name "Initialization of a Resource with an Insecure Default" .

<http://w3id.org/sepses/resource/cwe/CWE-1189> a cwe:CWE ;
    cwe:description "The System-On-a-Chip (SoC) does not properly isolate shared resources between trusted and untrusted agents." ;
    cwe:id "CWE-1189" ;
    cwe:name "Improper Isolation of Shared Resources on System-on-a-Chip (SoC)" .

<http://w3id.org/sepses/resource/cwe/CWE-119> a cwe:CWE ;
    cwe:description "The product performs operations on a memory buffer, but it reads from or writes to a memory location outside the buffer's intended boundary. This may result in read or write operations on unexpected memory locations that could be linked to other variables, data structures, or internal program data." ;
    cwe:id "CWE-119" ;
    cwe:name "Improper Restriction of Operations within the Bounds of a Memory Buffer" .

<http://w3id.org/sepses/resource/cwe/CWE-1190> a cwe:CWE ;
    cwe:description "The product enables a Direct Memory Access (DMA) capable device before the security configuration settings are established, which allows an attacker to extract data from or gain privileges on the product." ;
    cwe:id "CWE-1190" ;
    cwe:name "DMA Device Enabled Too Early in Boot Phase" .

<http://w3id.org/sepses/resource/cwe/CWE-1191> a cwe:CWE ;
    cwe:description "The chip does not implement or does not correctly perform access control to check whether users are authorized to access internal registers and test modes through the physical debug/test interface." ;
    cwe:id "CWE-1191" ;
    cwe:name "On-Chip Debug and Test Interface With Improper Access Control" .

<http://w3id.org/sepses/resource/cwe/CWE-1192> a cwe:CWE ;
    cwe:description "The System-on-Chip (SoC) does not have unique, immutable identifiers for each of its components." ;
    cwe:id "CWE-1192" ;
    cwe:name "Improper Identifier for IP Block used in System-On-Chip (SOC)" .

<http://w3id.org/sepses/resource/cwe/CWE-1193> a cwe:CWE ;
    cwe:description "The product enables components that contain untrusted firmware before memory and fabric access controls have been enabled." ;
    cwe:id "CWE-1193" ;
    cwe:name "Power-On of Untrusted Execution Core Before Enabling Fabric Access Control" .

<http://w3id.org/sepses/resource/cwe/CWE-12> a cwe:CWE ;
    cwe:description "An ASP .NET application must enable custom error pages in order to prevent attackers from mining information from the framework's built-in responses." ;
    cwe:id "CWE-12" ;
    cwe:name "ASP.NET Misconfiguration: Missing Custom Error Page" .

<http://w3id.org/sepses/resource/cwe/CWE-120> a cwe:CWE ;
    cwe:description "The product copies an input buffer to an output buffer without verifying that the size of the input buffer is less than the size of the output buffer." ;
    cwe:id "CWE-120" ;
    cwe:name "Buffer Copy without Checking Size of Input ('Classic Buffer Overflow')" .

<http://w3id.org/sepses/resource/cwe/CWE-1204> a cwe:CWE ;
    cwe:description """The product uses a cryptographic primitive that uses an Initialization
			Vector (IV), but the product does not generate IVs that are
			sufficiently unpredictable or unique according to the expected
			cryptographic requirements for that primitive.
			""" ;
    cwe:id "CWE-1204" ;
    cwe:name "Generation of Weak Initialization Vector (IV)" .

<http://w3id.org/sepses/resource/cwe/CWE-1209> a cwe:CWE ;
    cwe:description "The reserved bits in a hardware design are not disabled prior to production. Typically, reserved bits are used for future capabilities and should not support any functional logic in the design.   However, designers might covertly use these bits to debug or further develop new capabilities in production hardware. Adversaries with access to these bits will write to them in hopes of compromising hardware state." ;
    cwe:id "CWE-1209" ;
    cwe:name "Failure to Disable Reserved Bits" .

<http://w3id.org/sepses/resource/cwe/CWE-121> a cwe:CWE ;
    cwe:description "A stack-based buffer overflow condition is a condition where the buffer being overwritten is allocated on the stack (i.e., is a local variable or, rarely, a parameter to a function)." ;
    cwe:id "CWE-121" ;
    cwe:name "Stack-based Buffer Overflow" .

<http://w3id.org/sepses/resource/cwe/CWE-122> a cwe:CWE ;
    cwe:description "A heap overflow condition is a buffer overflow, where the buffer that can be overwritten is allocated in the heap portion of memory, generally meaning that the buffer was allocated using a routine such as malloc()." ;
    cwe:id "CWE-122" ;
    cwe:name "Heap-based Buffer Overflow" .

<http://w3id.org/sepses/resource/cwe/CWE-1220> a cwe:CWE ;
    cwe:description "The product implements access controls via a policy or other feature with the intention to disable or restrict accesses (reads and/or writes) to assets in a system from untrusted agents. However, implemented access controls lack required granularity, which renders the control policy too broad because it allows accesses from unauthorized agents to the security-sensitive assets." ;
    cwe:id "CWE-1220" ;
    cwe:name "Insufficient Granularity of Access Control" .

<http://w3id.org/sepses/resource/cwe/CWE-1221> a cwe:CWE ;
    cwe:description "Hardware description language code incorrectly defines register defaults or hardware Intellectual Property (IP) parameters to insecure values." ;
    cwe:id "CWE-1221" ;
    cwe:name "Incorrect Register Defaults or Module Parameters" .

<http://w3id.org/sepses/resource/cwe/CWE-1222> a cwe:CWE ;
    cwe:description "The product defines a large address region protected from modification by the same register lock control bit. This results in a conflict between the functional requirement that some addresses need to be writable by software during operation and the security requirement that the system configuration lock bit must be set during the boot process." ;
    cwe:id "CWE-1222" ;
    cwe:name "Insufficient Granularity of Address Regions Protected by Register Locks" .

<http://w3id.org/sepses/resource/cwe/CWE-1223> a cwe:CWE ;
    cwe:description "A write-once register in hardware design is programmable by an untrusted software component earlier than the trusted software component, resulting in a race condition issue." ;
    cwe:id "CWE-1223" ;
    cwe:name "Race Condition for Write-Once Attributes" .

<http://w3id.org/sepses/resource/cwe/CWE-1224> a cwe:CWE ;
    cwe:description "The hardware design control register \"sticky bits\" or write-once bit fields are improperly implemented, such that they can be reprogrammed by software." ;
    cwe:id "CWE-1224" ;
    cwe:name "Improper Restriction of Write-Once Bit Fields" .

<http://w3id.org/sepses/resource/cwe/CWE-1229> a cwe:CWE ;
    cwe:description "The product manages resources or behaves in a way that indirectly creates a new, distinct resource that can be used by attackers in violation of the intended policy." ;
    cwe:id "CWE-1229" ;
    cwe:name "Creation of Emergent Resource" .

<http://w3id.org/sepses/resource/cwe/CWE-123> a cwe:CWE ;
    cwe:description "Any condition where the attacker has the ability to write an arbitrary value to an arbitrary location, often as the result of a buffer overflow." ;
    cwe:id "CWE-123" ;
    cwe:name "Write-what-where Condition" .

<http://w3id.org/sepses/resource/cwe/CWE-1230> a cwe:CWE ;
    cwe:description "The product prevents direct access to a resource containing sensitive information, but it does not sufficiently limit access to metadata that is derived from the original, sensitive information." ;
    cwe:id "CWE-1230" ;
    cwe:name "Exposure of Sensitive Information Through Metadata" .

<http://w3id.org/sepses/resource/cwe/CWE-1231> a cwe:CWE ;
    cwe:description "The product uses a trusted lock bit for restricting access to registers, address regions, or other resources, but the product does not prevent the value of the lock bit from being modified after it has been set." ;
    cwe:id "CWE-1231" ;
    cwe:name "Improper Prevention of Lock Bit Modification" .

<http://w3id.org/sepses/resource/cwe/CWE-1232> a cwe:CWE ;
    cwe:description "Register lock bit protection disables changes to system configuration once the bit is set. Some of the protected registers or lock bits become programmable after power state transitions (e.g., Entry and wake from low power sleep modes) causing the system configuration to be changeable." ;
    cwe:id "CWE-1232" ;
    cwe:name "Improper Lock Behavior After Power State Transition" .

<http://w3id.org/sepses/resource/cwe/CWE-1233> a cwe:CWE ;
    cwe:description "The product uses a register lock bit protection mechanism, but it does not ensure that the lock bit prevents modification of system registers or controls that perform changes to important hardware system configuration." ;
    cwe:id "CWE-1233" ;
    cwe:name "Security-Sensitive Hardware Controls with Missing Lock Bit Protection" .

<http://w3id.org/sepses/resource/cwe/CWE-1234> a cwe:CWE ;
    cwe:description "System configuration protection may be bypassed during debug mode." ;
    cwe:id "CWE-1234" ;
    cwe:name "Hardware Internal or Debug Modes Allow Override of Locks" .

<http://w3id.org/sepses/resource/cwe/CWE-1235> a cwe:CWE ;
    cwe:description "The code uses boxed primitives, which may introduce inefficiencies into performance-critical operations." ;
    cwe:id "CWE-1235" ;
    cwe:name "Incorrect Use of Autoboxing and Unboxing for Performance Critical Operations" .

<http://w3id.org/sepses/resource/cwe/CWE-1236> a cwe:CWE ;
    cwe:description "The product saves user-provided information into a Comma-Separated Value (CSV) file, but it does not neutralize or incorrectly neutralizes special elements that could be interpreted as a command when the file is opened by a spreadsheet product." ;
    cwe:id "CWE-1236" ;
    cwe:name "Improper Neutralization of Formula Elements in a CSV File" .

<http://w3id.org/sepses/resource/cwe/CWE-1239> a cwe:CWE ;
    cwe:description "The hardware product does not properly clear sensitive information from built-in registers when the user of the hardware block changes." ;
    cwe:id "CWE-1239" ;
    cwe:name "Improper Zeroization of Hardware Register" .

<http://w3id.org/sepses/resource/cwe/CWE-124> a cwe:CWE ;
    cwe:description "The product writes to a buffer using an index or pointer that references a memory location prior to the beginning of the buffer." ;
    cwe:id "CWE-124" ;
    cwe:name "Buffer Underwrite ('Buffer Underflow')" .

<http://w3id.org/sepses/resource/cwe/CWE-1240> a cwe:CWE ;
    cwe:description "To fulfill the need for a cryptographic primitive, the product implements a cryptographic algorithm using a non-standard, unproven, or disallowed/non-compliant cryptographic implementation." ;
    cwe:id "CWE-1240" ;
    cwe:name "Use of a Cryptographic Primitive with a Risky Implementation" .

<http://w3id.org/sepses/resource/cwe/CWE-1241> a cwe:CWE ;
    cwe:description "The device uses an algorithm that is predictable and generates a pseudo-random number." ;
    cwe:id "CWE-1241" ;
    cwe:name "Use of Predictable Algorithm in Random Number Generator" .

<http://w3id.org/sepses/resource/cwe/CWE-1242> a cwe:CWE ;
    cwe:description "The device includes chicken bits or undocumented features that can create entry points for unauthorized actors." ;
    cwe:id "CWE-1242" ;
    cwe:name "Inclusion of Undocumented Features or Chicken Bits" .

<http://w3id.org/sepses/resource/cwe/CWE-1243> a cwe:CWE ;
    cwe:description "Access to security-sensitive information stored in fuses is not limited during debug." ;
    cwe:id "CWE-1243" ;
    cwe:name "Sensitive Non-Volatile Information Not Protected During Debug" .

<http://w3id.org/sepses/resource/cwe/CWE-1244> a cwe:CWE ;
    cwe:description """The product uses physical debug or test
        interfaces with support for multiple access levels, but it
        assigns the wrong debug access level to an internal asset,
        providing unintended access to the asset from untrusted debug
        agents.""" ;
    cwe:id "CWE-1244" ;
    cwe:name "Internal Asset Exposed to Unsafe Debug Access Level or State" .

<http://w3id.org/sepses/resource/cwe/CWE-1245> a cwe:CWE ;
    cwe:description "Faulty finite state machines (FSMs) in the hardware logic allow an attacker to put the system in an undefined state, to cause a denial of service (DoS) or gain privileges on the victim's system." ;
    cwe:id "CWE-1245" ;
    cwe:name "Improper Finite State Machines (FSMs) in Hardware Logic" .

<http://w3id.org/sepses/resource/cwe/CWE-1246> a cwe:CWE ;
    cwe:description "The product does not implement or incorrectly implements wear leveling operations in limited-write non-volatile memories." ;
    cwe:id "CWE-1246" ;
    cwe:name "Improper Write Handling in Limited-write Non-Volatile Memories" .

<http://w3id.org/sepses/resource/cwe/CWE-1247> a cwe:CWE ;
    cwe:description "The device does not contain or contains incorrectly implemented circuitry or sensors to detect and mitigate voltage and clock glitches and protect sensitive information or software contained on the device." ;
    cwe:id "CWE-1247" ;
    cwe:name "Improper Protection Against Voltage and Clock Glitches" .

<http://w3id.org/sepses/resource/cwe/CWE-1248> a cwe:CWE ;
    cwe:description "The security-sensitive hardware module contains semiconductor defects." ;
    cwe:id "CWE-1248" ;
    cwe:name "Semiconductor Defects in Hardware Logic with Security-Sensitive Implications" .

<http://w3id.org/sepses/resource/cwe/CWE-1249> a cwe:CWE ;
    cwe:description "The product provides an application for administrators to manage parts of the underlying operating system, but the application does not accurately identify all of the relevant entities or resources that exist in the OS; that is, the application's model of the OS's state is inconsistent with the OS's actual state." ;
    cwe:id "CWE-1249" ;
    cwe:name "Application-Level Admin Tool with Inconsistent View of Underlying Operating System" .

<http://w3id.org/sepses/resource/cwe/CWE-125> a cwe:CWE ;
    cwe:description "The product reads data past the end, or before the beginning, of the intended buffer." ;
    cwe:id "CWE-125" ;
    cwe:name "Out-of-bounds Read" .

<http://w3id.org/sepses/resource/cwe/CWE-1250> a cwe:CWE ;
    cwe:description "The product has or supports multiple distributed components or sub-systems that are each required to keep their own local copy of shared data - such as state or cache - but the product does not ensure that all local copies remain consistent with each other." ;
    cwe:id "CWE-1250" ;
    cwe:name "Improper Preservation of Consistency Between Independent Representations of Shared State" .

<http://w3id.org/sepses/resource/cwe/CWE-1251> a cwe:CWE ;
    cwe:description "The product's architecture mirrors regions without ensuring that their contents always stay in sync." ;
    cwe:id "CWE-1251" ;
    cwe:name "Mirrored Regions with Different Values" .

<http://w3id.org/sepses/resource/cwe/CWE-1252> a cwe:CWE ;
    cwe:description "The CPU is not configured to provide hardware support for exclusivity of write and execute operations on memory. This allows an attacker to execute data from all of memory." ;
    cwe:id "CWE-1252" ;
    cwe:name "CPU Hardware Not Configured to Support Exclusivity of Write and Execute Operations" .

<http://w3id.org/sepses/resource/cwe/CWE-1253> a cwe:CWE ;
    cwe:description "The logic level used to set a system to a secure state relies on a fuse being unblown." ;
    cwe:id "CWE-1253" ;
    cwe:name "Incorrect Selection of Fuse Values" .

<http://w3id.org/sepses/resource/cwe/CWE-1254> a cwe:CWE ;
    cwe:description "The product's comparison logic is performed over a series of steps rather than across the entire string in one operation. If there is a comparison logic failure on one of these steps, the operation may be vulnerable to a timing attack that can result in the interception of the process for nefarious purposes." ;
    cwe:id "CWE-1254" ;
    cwe:name "Incorrect Comparison Logic Granularity" .

<http://w3id.org/sepses/resource/cwe/CWE-1255> a cwe:CWE ;
    cwe:description "A device's real time power consumption may be monitored during security token evaluation and the information gleaned may be used to determine the value of the reference token." ;
    cwe:id "CWE-1255" ;
    cwe:name "Comparison Logic is Vulnerable to Power Side-Channel Attacks" .

<http://w3id.org/sepses/resource/cwe/CWE-1256> a cwe:CWE ;
    cwe:description """The product provides software-controllable
			device functionality for capabilities such as power and
			clock management, but it does not properly limit
			functionality that can lead to modification of
			hardware memory or register bits, or the ability to
			observe physical side channels.""" ;
    cwe:id "CWE-1256" ;
    cwe:name "Improper Restriction of Software Interfaces to Hardware Features" .

<http://w3id.org/sepses/resource/cwe/CWE-1257> a cwe:CWE ;
    cwe:description """Aliased or mirrored memory regions in hardware designs may have inconsistent read/write permissions enforced by the hardware. A possible result is that an untrusted agent is blocked from accessing a memory region but is not blocked from accessing the corresponding aliased memory region.
			""" ;
    cwe:id "CWE-1257" ;
    cwe:name "Improper Access Control Applied to Mirrored or Aliased Memory Regions" .

<http://w3id.org/sepses/resource/cwe/CWE-1258> a cwe:CWE ;
    cwe:description "The hardware does not fully clear security-sensitive values, such as keys and intermediate values in cryptographic operations, when debug mode is entered." ;
    cwe:id "CWE-1258" ;
    cwe:name "Exposure of Sensitive System Information Due to Uncleared Debug Information" .

<http://w3id.org/sepses/resource/cwe/CWE-1259> a cwe:CWE ;
    cwe:description "The System-On-A-Chip (SoC) implements a Security Token mechanism to differentiate what actions are allowed or disallowed when a transaction originates from an entity. However, the Security Tokens are improperly protected." ;
    cwe:id "CWE-1259" ;
    cwe:name "Improper Restriction of Security Token Assignment" .

<http://w3id.org/sepses/resource/cwe/CWE-126> a cwe:CWE ;
    cwe:description "The product reads from a buffer using buffer access mechanisms such as indexes or pointers that reference memory locations after the targeted buffer." ;
    cwe:id "CWE-126" ;
    cwe:name "Buffer Over-read" .

<http://w3id.org/sepses/resource/cwe/CWE-1260> a cwe:CWE ;
    cwe:description "The product allows address regions to overlap, which can result in the bypassing of intended memory protection." ;
    cwe:id "CWE-1260" ;
    cwe:name "Improper Handling of Overlap Between Protected Memory Ranges" .

<http://w3id.org/sepses/resource/cwe/CWE-1261> a cwe:CWE ;
    cwe:description "The hardware logic does not effectively handle when single-event upsets (SEUs) occur." ;
    cwe:id "CWE-1261" ;
    cwe:name "Improper Handling of Single Event Upsets" .

<http://w3id.org/sepses/resource/cwe/CWE-1262> a cwe:CWE ;
    cwe:description "The product uses memory-mapped I/O registers that act as an interface to hardware functionality from software, but there is improper access control to those registers." ;
    cwe:id "CWE-1262" ;
    cwe:name "Improper Access Control for Register Interface" .

<http://w3id.org/sepses/resource/cwe/CWE-1263> a cwe:CWE ;
    cwe:description "The product is designed with access restricted to certain information, but it does not sufficiently protect against an unauthorized actor with physical access to these areas." ;
    cwe:id "CWE-1263" ;
    cwe:name "Improper Physical Access Control" .

<http://w3id.org/sepses/resource/cwe/CWE-1264> a cwe:CWE ;
    cwe:description "The hardware logic for error handling and security checks can incorrectly forward data before the security check is complete." ;
    cwe:id "CWE-1264" ;
    cwe:name "Hardware Logic with Insecure De-Synchronization between Control and Data Channels" .

<http://w3id.org/sepses/resource/cwe/CWE-1265> a cwe:CWE ;
    cwe:description "The product invokes code that is believed to be reentrant, but the code performs a call that unintentionally produces a nested invocation of the non-reentrant code." ;
    cwe:id "CWE-1265" ;
    cwe:name "Unintended Reentrant Invocation of Non-reentrant Code Via Nested Calls" .

<http://w3id.org/sepses/resource/cwe/CWE-1266> a cwe:CWE ;
    cwe:description "The product does not properly provide a capability for the product administrator to remove sensitive data at the time the product is decommissioned.  A scrubbing capability could be missing, insufficient, or incorrect." ;
    cwe:id "CWE-1266" ;
    cwe:name "Improper Scrubbing of Sensitive Data from Decommissioned Device" .

<http://w3id.org/sepses/resource/cwe/CWE-1267> a cwe:CWE ;
    cwe:description "The product uses an obsolete encoding mechanism to implement access controls." ;
    cwe:id "CWE-1267" ;
    cwe:name "Policy Uses Obsolete Encoding" .

<http://w3id.org/sepses/resource/cwe/CWE-1268> a cwe:CWE ;
    cwe:description """The product's hardware-enforced access control for a particular resource improperly accounts for privilege discrepancies between control and write policies.
			   """ ;
    cwe:id "CWE-1268" ;
    cwe:name "Policy Privileges are not Assigned Consistently Between Control and Data Agents" .

<http://w3id.org/sepses/resource/cwe/CWE-1269> a cwe:CWE ;
    cwe:description "The product released to market is released in pre-production or manufacturing configuration." ;
    cwe:id "CWE-1269" ;
    cwe:name "Product Released in Non-Release Configuration" .

<http://w3id.org/sepses/resource/cwe/CWE-127> a cwe:CWE ;
    cwe:description "The product reads from a buffer using buffer access mechanisms such as indexes or pointers that reference memory locations prior to the targeted buffer." ;
    cwe:id "CWE-127" ;
    cwe:name "Buffer Under-read" .

<http://w3id.org/sepses/resource/cwe/CWE-1270> a cwe:CWE ;
    cwe:description "The product implements a Security Token mechanism to differentiate what actions are allowed or disallowed when a transaction originates from an entity. However, the Security Tokens generated in the system are incorrect." ;
    cwe:id "CWE-1270" ;
    cwe:name "Generation of Incorrect Security Tokens" .

<http://w3id.org/sepses/resource/cwe/CWE-1271> a cwe:CWE ;
    cwe:description "Security-critical logic is not set to a known value on reset." ;
    cwe:id "CWE-1271" ;
    cwe:name "Uninitialized Value on Reset for Registers Holding Security Settings" .

<http://w3id.org/sepses/resource/cwe/CWE-1272> a cwe:CWE ;
    cwe:description "The product performs a power or debug state transition, but it does not clear sensitive information that should no longer be accessible due to changes to information access restrictions." ;
    cwe:id "CWE-1272" ;
    cwe:name "Sensitive Information Uncleared Before Debug/Power State Transition" .

<http://w3id.org/sepses/resource/cwe/CWE-1273> a cwe:CWE ;
    cwe:description "The credentials necessary for unlocking a device are shared across multiple parties and may expose sensitive information." ;
    cwe:id "CWE-1273" ;
    cwe:name "Device Unlock Credential Sharing" .

<http://w3id.org/sepses/resource/cwe/CWE-1274> a cwe:CWE ;
    cwe:description "The product conducts a secure-boot process that transfers bootloader code from Non-Volatile Memory (NVM) into Volatile Memory (VM), but it does not have sufficient access control or other protections for the Volatile Memory." ;
    cwe:id "CWE-1274" ;
    cwe:name "Improper Access Control for Volatile Memory Containing Boot Code" .

<http://w3id.org/sepses/resource/cwe/CWE-1275> a cwe:CWE ;
    cwe:description "The SameSite attribute for sensitive cookies is not set, or an insecure value is used." ;
    cwe:id "CWE-1275" ;
    cwe:name "Sensitive Cookie with Improper SameSite Attribute" .

<http://w3id.org/sepses/resource/cwe/CWE-1276> a cwe:CWE ;
    cwe:description "Signals between a hardware IP and the parent system design are incorrectly connected causing security risks." ;
    cwe:id "CWE-1276" ;
    cwe:name "Hardware Child Block Incorrectly Connected to Parent System" .

<http://w3id.org/sepses/resource/cwe/CWE-1277> a cwe:CWE ;
    cwe:description """The product does not provide its
			users with the ability to update or patch its
			firmware to address any vulnerabilities or
			weaknesses that may be present.""" ;
    cwe:id "CWE-1277" ;
    cwe:name "Firmware Not Updateable" .

<http://w3id.org/sepses/resource/cwe/CWE-1278> a cwe:CWE ;
    cwe:description "Information stored in hardware may be recovered by an attacker with the capability to capture and analyze images of the integrated circuit using techniques such as scanning electron microscopy." ;
    cwe:id "CWE-1278" ;
    cwe:name "Missing Protection Against Hardware Reverse Engineering Using Integrated Circuit (IC) Imaging Techniques" .

<http://w3id.org/sepses/resource/cwe/CWE-1279> a cwe:CWE ;
    cwe:description "Performing cryptographic operations without ensuring that the supporting inputs are ready to supply valid data may compromise the cryptographic result." ;
    cwe:id "CWE-1279" ;
    cwe:name "Cryptographic Operations are run Before Supporting Units are Ready" .

<http://w3id.org/sepses/resource/cwe/CWE-128> a cwe:CWE ;
    cwe:description "Wrap around errors occur whenever a value is incremented past the maximum value for its type and therefore \"wraps around\" to a very small, negative, or undefined value." ;
    cwe:id "CWE-128" ;
    cwe:name "Wrap-around Error" .

<http://w3id.org/sepses/resource/cwe/CWE-1280> a cwe:CWE ;
    cwe:description "A product's hardware-based access control check occurs after the asset has been accessed." ;
    cwe:id "CWE-1280" ;
    cwe:name "Access Control Check Implemented After Asset is Accessed" .

<http://w3id.org/sepses/resource/cwe/CWE-1281> a cwe:CWE ;
    cwe:description "Specific combinations of processor instructions lead to undesirable behavior such as locking the processor until a hard reset performed." ;
    cwe:id "CWE-1281" ;
    cwe:name "Sequence of Processor Instructions Leads to Unexpected Behavior" .

<http://w3id.org/sepses/resource/cwe/CWE-1282> a cwe:CWE ;
    cwe:description "Immutable data, such as a first-stage bootloader, device identifiers, and \"write-once\" configuration settings are stored in writable memory that can be re-programmed or updated in the field." ;
    cwe:id "CWE-1282" ;
    cwe:name "Assumed-Immutable Data is Stored in Writable Memory" .

<http://w3id.org/sepses/resource/cwe/CWE-1283> a cwe:CWE ;
    cwe:description "The register contents used for attestation or measurement reporting data to verify boot flow are modifiable by an adversary." ;
    cwe:id "CWE-1283" ;
    cwe:name "Mutable Attestation or Measurement Reporting Data" .

<http://w3id.org/sepses/resource/cwe/CWE-1284> a cwe:CWE ;
    cwe:description "The product receives input that is expected to specify a quantity (such as size or length), but it does not validate or incorrectly validates that the quantity has the required properties." ;
    cwe:id "CWE-1284" ;
    cwe:name "Improper Validation of Specified Quantity in Input" .

<http://w3id.org/sepses/resource/cwe/CWE-1285> a cwe:CWE ;
    cwe:description "The product receives input that is expected to specify an index, position, or offset into an indexable resource such as a buffer or file, but it does not validate or incorrectly validates that the specified index/position/offset has the required properties." ;
    cwe:id "CWE-1285" ;
    cwe:name "Improper Validation of Specified Index, Position, or Offset in Input" .

<http://w3id.org/sepses/resource/cwe/CWE-1286> a cwe:CWE ;
    cwe:description "The product receives input that is expected to be well-formed - i.e., to comply with a certain syntax - but it does not validate or incorrectly validates that the input complies with the syntax." ;
    cwe:id "CWE-1286" ;
    cwe:name "Improper Validation of Syntactic Correctness of Input" .

<http://w3id.org/sepses/resource/cwe/CWE-1287> a cwe:CWE ;
    cwe:description "The product receives input that is expected to be of a certain type, but it does not validate or incorrectly validates that the input is actually of the expected type." ;
    cwe:id "CWE-1287" ;
    cwe:name "Improper Validation of Specified Type of Input" .

<http://w3id.org/sepses/resource/cwe/CWE-1288> a cwe:CWE ;
    cwe:description "The product receives a complex input with multiple elements or fields that must be consistent with each other, but it does not validate or incorrectly validates that the input is actually consistent." ;
    cwe:id "CWE-1288" ;
    cwe:name "Improper Validation of Consistency within Input" .

<http://w3id.org/sepses/resource/cwe/CWE-1289> a cwe:CWE ;
    cwe:description "The product receives an input value that is used as a resource identifier or other type of reference, but it does not validate or incorrectly validates that the input is equivalent to a potentially-unsafe value." ;
    cwe:id "CWE-1289" ;
    cwe:name "Improper Validation of Unsafe Equivalence in Input" .

<http://w3id.org/sepses/resource/cwe/CWE-129> a cwe:CWE ;
    cwe:description "The product uses untrusted input when calculating or using an array index, but the product does not validate or incorrectly validates the index to ensure the index references a valid position within the array." ;
    cwe:id "CWE-129" ;
    cwe:name "Improper Validation of Array Index" .

<http://w3id.org/sepses/resource/cwe/CWE-1290> a cwe:CWE ;
    cwe:description "The product implements a decoding mechanism to decode certain bus-transaction signals to security identifiers. If the decoding is implemented incorrectly, then untrusted agents can now gain unauthorized access to the asset." ;
    cwe:id "CWE-1290" ;
    cwe:name "Incorrect Decoding of Security Identifiers" .

<http://w3id.org/sepses/resource/cwe/CWE-1291> a cwe:CWE ;
    cwe:description "The same public key is used for signing both debug and production code." ;
    cwe:id "CWE-1291" ;
    cwe:name "Public Key Re-Use for Signing both Debug and Production Code" .

<http://w3id.org/sepses/resource/cwe/CWE-1292> a cwe:CWE ;
    cwe:description "The product implements a conversion mechanism to map certain bus-transaction signals to security identifiers. However, if the conversion is incorrectly implemented, untrusted agents can gain unauthorized access to the asset." ;
    cwe:id "CWE-1292" ;
    cwe:name "Incorrect Conversion of Security Identifiers" .

<http://w3id.org/sepses/resource/cwe/CWE-1293> a cwe:CWE ;
    cwe:description "The product relies on one source of data, preventing the ability to detect if an adversary has compromised a data source." ;
    cwe:id "CWE-1293" ;
    cwe:name "Missing Source Correlation of Multiple Independent Data" .

<http://w3id.org/sepses/resource/cwe/CWE-1294> a cwe:CWE ;
    cwe:description "The System-on-Chip (SoC) implements a Security Identifier mechanism to differentiate what actions are allowed or disallowed when a transaction originates from an entity. However, the Security Identifiers are not correctly implemented." ;
    cwe:id "CWE-1294" ;
    cwe:name "Insecure Security Identifier Mechanism" .

<http://w3id.org/sepses/resource/cwe/CWE-1295> a cwe:CWE ;
    cwe:description "The product fails to adequately prevent the revealing of unnecessary and potentially sensitive system information within debugging messages." ;
    cwe:id "CWE-1295" ;
    cwe:name "Debug Messages Revealing Unnecessary Information" .

<http://w3id.org/sepses/resource/cwe/CWE-1296> a cwe:CWE ;
    cwe:description "The product's debug components contain incorrect chaining or granularity of debug components." ;
    cwe:id "CWE-1296" ;
    cwe:name "Incorrect Chaining or Granularity of Debug Components" .

<http://w3id.org/sepses/resource/cwe/CWE-1297> a cwe:CWE ;
    cwe:description "The product does not adequately protect confidential information on the device from being accessed by Outsourced Semiconductor Assembly and Test (OSAT) vendors." ;
    cwe:id "CWE-1297" ;
    cwe:name "Unprotected Confidential Information on Device is Accessible by OSAT Vendors" .

<http://w3id.org/sepses/resource/cwe/CWE-1298> a cwe:CWE ;
    cwe:description "A race condition in the hardware logic results in undermining security guarantees of the system." ;
    cwe:id "CWE-1298" ;
    cwe:name "Hardware Logic Contains Race Conditions" .

<http://w3id.org/sepses/resource/cwe/CWE-1299> a cwe:CWE ;
    cwe:description """The lack of protections on alternate paths to access
                control-protected assets (such as unprotected shadow registers
                and other external facing unguarded interfaces) allows an
                attacker to bypass existing protections to the asset that are
		only performed against the primary path.""" ;
    cwe:id "CWE-1299" ;
    cwe:name "Missing Protection Mechanism for Alternate Hardware Interface" .

<http://w3id.org/sepses/resource/cwe/CWE-13> a cwe:CWE ;
    cwe:description "Storing a plaintext password in a configuration file allows anyone who can read the file access to the password-protected resource making them an easy target for attackers." ;
    cwe:id "CWE-13" ;
    cwe:name "ASP.NET Misconfiguration: Password in Configuration File" .

<http://w3id.org/sepses/resource/cwe/CWE-130> a cwe:CWE ;
    cwe:description "The product parses a formatted message or structure, but it does not handle or incorrectly handles a length field that is inconsistent with the actual length of the associated data." ;
    cwe:id "CWE-130" ;
    cwe:name "Improper Handling of Length Parameter Inconsistency" .

<http://w3id.org/sepses/resource/cwe/CWE-1300> a cwe:CWE ;
    cwe:description """The device does not contain sufficient protection
	mechanisms to prevent physical side channels from exposing
	sensitive information due to patterns in physically observable
	phenomena such as variations in power consumption,
	electromagnetic emissions (EME), or acoustic emissions.""" ;
    cwe:id "CWE-1300" ;
    cwe:name "Improper Protection of Physical Side Channels" .

<http://w3id.org/sepses/resource/cwe/CWE-1301> a cwe:CWE ;
    cwe:description "The product's data removal process does not completely delete all data and potentially sensitive information within hardware components." ;
    cwe:id "CWE-1301" ;
    cwe:name "Insufficient or Incomplete Data Removal within Hardware Component" .

<http://w3id.org/sepses/resource/cwe/CWE-1302> a cwe:CWE ;
    cwe:description "The product implements a security identifier mechanism to differentiate what actions are allowed or disallowed when a transaction originates from an entity. A transaction is sent without a security identifier." ;
    cwe:id "CWE-1302" ;
    cwe:name "Missing Source Identifier in Entity Transactions on a System-On-Chip (SOC)" .

<http://w3id.org/sepses/resource/cwe/CWE-1303> a cwe:CWE ;
    cwe:description "Hardware structures shared across execution contexts (e.g., caches and branch predictors) can violate the expected architecture isolation between contexts." ;
    cwe:id "CWE-1303" ;
    cwe:name "Non-Transparent Sharing of Microarchitectural Resources" .

<http://w3id.org/sepses/resource/cwe/CWE-1304> a cwe:CWE ;
    cwe:description """The product performs a power save/restore
            operation, but it does not ensure that the integrity of
            the configuration state is maintained and/or verified between
	    the beginning and ending of the operation.""" ;
    cwe:id "CWE-1304" ;
    cwe:name "Improperly Preserved Integrity of Hardware Configuration State During a Power Save/Restore Operation" .

<http://w3id.org/sepses/resource/cwe/CWE-131> a cwe:CWE ;
    cwe:description "The product does not correctly calculate the size to be used when allocating a buffer, which could lead to a buffer overflow." ;
    cwe:id "CWE-131" ;
    cwe:name "Incorrect Calculation of Buffer Size" .

<http://w3id.org/sepses/resource/cwe/CWE-1310> a cwe:CWE ;
    cwe:description "Missing an ability to patch ROM code may leave a System or System-on-Chip (SoC) in a vulnerable state." ;
    cwe:id "CWE-1310" ;
    cwe:name "Missing Ability to Patch ROM Code" .

<http://w3id.org/sepses/resource/cwe/CWE-1311> a cwe:CWE ;
    cwe:description "The bridge incorrectly translates security attributes from either trusted to untrusted or from untrusted to trusted when converting from one fabric protocol to another." ;
    cwe:id "CWE-1311" ;
    cwe:name "Improper Translation of Security Attributes by Fabric Bridge" .

<http://w3id.org/sepses/resource/cwe/CWE-1312> a cwe:CWE ;
    cwe:description "The firewall in an on-chip fabric protects the main addressed region, but it does not protect any mirrored memory or memory-mapped-IO (MMIO) regions." ;
    cwe:id "CWE-1312" ;
    cwe:name "Missing Protection for Mirrored Regions in On-Chip Fabric Firewall" .

<http://w3id.org/sepses/resource/cwe/CWE-1313> a cwe:CWE ;
    cwe:description "During runtime, the hardware allows for test or debug logic (feature) to be activated, which allows for changing the state of the hardware. This feature can alter the intended behavior of the system and allow for alteration and leakage of sensitive data by an adversary." ;
    cwe:id "CWE-1313" ;
    cwe:name "Hardware Allows Activation of Test or Debug Logic at Runtime" .

<http://w3id.org/sepses/resource/cwe/CWE-1314> a cwe:CWE ;
    cwe:description "The device does not write-protect the parametric data values for sensors that scale the sensor value, allowing untrusted software to manipulate the apparent result and potentially damage hardware or cause operational failure." ;
    cwe:id "CWE-1314" ;
    cwe:name "Missing Write Protection for Parametric Data Values" .

<http://w3id.org/sepses/resource/cwe/CWE-1315> a cwe:CWE ;
    cwe:description "The bus controller enables bits in the fabric end-point to allow responder devices to control transactions on the fabric." ;
    cwe:id "CWE-1315" ;
    cwe:name "Improper Setting of Bus Controlling Capability in Fabric End-point" .

<http://w3id.org/sepses/resource/cwe/CWE-1316> a cwe:CWE ;
    cwe:description "The address map of the on-chip fabric has protected and unprotected regions overlapping, allowing an attacker to bypass access control to the overlapping portion of the protected region." ;
    cwe:id "CWE-1316" ;
    cwe:name "Fabric-Address Map Allows Programming of Unwarranted Overlaps of Protected and Unprotected Ranges" .

<http://w3id.org/sepses/resource/cwe/CWE-1317> a cwe:CWE ;
    cwe:description "The product uses a fabric bridge for transactions between two Intellectual Property (IP) blocks, but the bridge does not properly perform the expected privilege, identity, or other access control checks between those IP blocks." ;
    cwe:id "CWE-1317" ;
    cwe:name "Improper Access Control in Fabric Bridge" .

<http://w3id.org/sepses/resource/cwe/CWE-1318> a cwe:CWE ;
    cwe:description "On-chip fabrics or buses either do not support or are not configured to support privilege separation or other security features, such as access control." ;
    cwe:id "CWE-1318" ;
    cwe:name "Missing Support for Security Features in On-chip Fabrics or Buses" .

<http://w3id.org/sepses/resource/cwe/CWE-1319> a cwe:CWE ;
    cwe:description "The device is susceptible to electromagnetic fault injection attacks, causing device internal information to be compromised or security mechanisms to be bypassed." ;
    cwe:id "CWE-1319" ;
    cwe:name "Improper Protection against Electromagnetic Fault Injection (EM-FI)" .

<http://w3id.org/sepses/resource/cwe/CWE-132> a cwe:CWE ;
    cwe:description "This entry has been deprecated because it was a duplicate of CWE-170. All content has been transferred to CWE-170." ;
    cwe:id "CWE-132" ;
    cwe:name "DEPRECATED: Miscalculated Null Termination" .

<http://w3id.org/sepses/resource/cwe/CWE-1320> a cwe:CWE ;
    cwe:description """Untrusted agents can disable alerts about signal conditions exceeding limits or the response mechanism that handles such alerts.
			""" ;
    cwe:id "CWE-1320" ;
    cwe:name "Improper Protection for Outbound Error Messages and Alert Signals" .

<http://w3id.org/sepses/resource/cwe/CWE-1321> a cwe:CWE ;
    cwe:description "The product receives input from an upstream component that specifies attributes that are to be initialized or updated in an object, but it does not properly control modifications of attributes of the object prototype." ;
    cwe:id "CWE-1321" ;
    cwe:name "Improperly Controlled Modification of Object Prototype Attributes ('Prototype Pollution')" .

<http://w3id.org/sepses/resource/cwe/CWE-1322> a cwe:CWE ;
    cwe:description """The product uses a non-blocking model that relies on a single threaded process
			for features such as scalability, but it contains code that can block when it is invoked.""" ;
    cwe:id "CWE-1322" ;
    cwe:name "Use of Blocking Code in Single-threaded, Non-blocking Context" .

<http://w3id.org/sepses/resource/cwe/CWE-1323> a cwe:CWE ;
    cwe:description """Trace data collected from several sources on the
                System-on-Chip (SoC) is stored in unprotected locations or
                transported to untrusted agents.""" ;
    cwe:id "CWE-1323" ;
    cwe:name "Improper Management of Sensitive Trace Data" .

<http://w3id.org/sepses/resource/cwe/CWE-1324> a cwe:CWE ;
    cwe:description "This entry has been deprecated because it was at a lower level of abstraction than supported by CWE. All relevant content has been integrated into CWE-319." ;
    cwe:id "CWE-1324" ;
    cwe:name "DEPRECATED: Sensitive Information Accessible by Physical Probing of JTAG Interface" .

<http://w3id.org/sepses/resource/cwe/CWE-1325> a cwe:CWE ;
    cwe:description "The product manages a group of objects or resources and performs a separate memory allocation for each object, but it does not properly limit the total amount of memory that is consumed by all of the combined objects." ;
    cwe:id "CWE-1325" ;
    cwe:name "Improperly Controlled Sequential Memory Allocation" .

<http://w3id.org/sepses/resource/cwe/CWE-1326> a cwe:CWE ;
    cwe:description "A missing immutable root of trust in the hardware results in the ability to bypass secure boot or execute untrusted or adversarial boot code." ;
    cwe:id "CWE-1326" ;
    cwe:name "Missing Immutable Root of Trust in Hardware" .

<http://w3id.org/sepses/resource/cwe/CWE-1327> a cwe:CWE ;
    cwe:description "The product assigns the address 0.0.0.0 for a database server, a cloud service/instance, or any computing resource that communicates remotely." ;
    cwe:id "CWE-1327" ;
    cwe:name "Binding to an Unrestricted IP Address" .

<http://w3id.org/sepses/resource/cwe/CWE-1328> a cwe:CWE ;
    cwe:description "Security-version number in hardware is mutable, resulting in the ability to downgrade (roll-back) the boot firmware to vulnerable code versions." ;
    cwe:id "CWE-1328" ;
    cwe:name "Security Version Number Mutable to Older Versions" .

<http://w3id.org/sepses/resource/cwe/CWE-1329> a cwe:CWE ;
    cwe:description "The product contains a component that cannot be updated or patched in order to remove vulnerabilities or significant bugs." ;
    cwe:id "CWE-1329" ;
    cwe:name "Reliance on Component That is Not Updateable" .

<http://w3id.org/sepses/resource/cwe/CWE-1330> a cwe:CWE ;
    cwe:description "Confidential information stored in memory circuits is readable or recoverable after being cleared or erased." ;
    cwe:id "CWE-1330" ;
    cwe:name "Remanent Data Readable after Memory Erase" .

<http://w3id.org/sepses/resource/cwe/CWE-1331> a cwe:CWE ;
    cwe:description "The Network On Chip (NoC) does not isolate or incorrectly isolates its on-chip-fabric and internal resources such that they are shared between trusted and untrusted agents, creating timing channels." ;
    cwe:id "CWE-1331" ;
    cwe:name "Improper Isolation of Shared Resources in Network On Chip (NoC)" .

<http://w3id.org/sepses/resource/cwe/CWE-1332> a cwe:CWE ;
    cwe:description "The device is missing or incorrectly implements circuitry or sensors that detect and mitigate the skipping of security-critical CPU instructions when they occur." ;
    cwe:id "CWE-1332" ;
    cwe:name "Improper Handling of Faults that Lead to Instruction Skips" .

<http://w3id.org/sepses/resource/cwe/CWE-1333> a cwe:CWE ;
    cwe:description "The product uses a regular expression with a worst-case computational complexity that is inefficient and possibly exponential." ;
    cwe:id "CWE-1333" ;
    cwe:name "Inefficient Regular Expression Complexity" .

<http://w3id.org/sepses/resource/cwe/CWE-1334> a cwe:CWE ;
    cwe:description "An unauthorized agent can inject errors into a redundant block to deprive the system of redundancy or put the system in a degraded operating mode." ;
    cwe:id "CWE-1334" ;
    cwe:name "Unauthorized Error Injection Can Degrade Hardware Redundancy" .

<http://w3id.org/sepses/resource/cwe/CWE-1335> a cwe:CWE ;
    cwe:description "An integer value is specified to be shifted by a negative amount or an amount greater than or equal to the number of bits contained in the value causing an unexpected or indeterminate result." ;
    cwe:id "CWE-1335" ;
    cwe:name "Incorrect Bitwise Shift of Integer" .

<http://w3id.org/sepses/resource/cwe/CWE-1336> a cwe:CWE ;
    cwe:description "The product uses a template engine to insert or process externally-influenced input, but it does not neutralize or incorrectly neutralizes special elements or syntax that can be interpreted as template expressions or other code directives when processed by the engine." ;
    cwe:id "CWE-1336" ;
    cwe:name "Improper Neutralization of Special Elements Used in a Template Engine" .

<http://w3id.org/sepses/resource/cwe/CWE-1338> a cwe:CWE ;
    cwe:description "A hardware device is missing or has inadequate protection features to prevent overheating." ;
    cwe:id "CWE-1338" ;
    cwe:name "Improper Protections Against Hardware Overheating" .

<http://w3id.org/sepses/resource/cwe/CWE-1339> a cwe:CWE ;
    cwe:description "The product processes a real number with an implementation in which the number's representation does not preserve required accuracy and precision in its fractional part, causing an incorrect result." ;
    cwe:id "CWE-1339" ;
    cwe:name "Insufficient Precision or Accuracy of a Real Number" .

<http://w3id.org/sepses/resource/cwe/CWE-134> a cwe:CWE ;
    cwe:description "The product uses a function that accepts a format string as an argument, but the format string originates from an external source." ;
    cwe:id "CWE-134" ;
    cwe:name "Use of Externally-Controlled Format String" .

<http://w3id.org/sepses/resource/cwe/CWE-1341> a cwe:CWE ;
    cwe:description "The product attempts to close or release a resource or handle more than once, without any successful open between the close operations." ;
    cwe:id "CWE-1341" ;
    cwe:name "Multiple Releases of Same Resource or Handle" .

<http://w3id.org/sepses/resource/cwe/CWE-1342> a cwe:CWE ;
    cwe:description "The processor does not properly clear microarchitectural state after incorrect microcode assists or speculative execution, resulting in transient execution." ;
    cwe:id "CWE-1342" ;
    cwe:name "Information Exposure through Microarchitectural State after Transient Execution" .

<http://w3id.org/sepses/resource/cwe/CWE-135> a cwe:CWE ;
    cwe:description "The product does not correctly calculate the length of strings that can contain wide or multi-byte characters." ;
    cwe:id "CWE-135" ;
    cwe:name "Incorrect Calculation of Multi-Byte String Length" .

<http://w3id.org/sepses/resource/cwe/CWE-1351> a cwe:CWE ;
    cwe:description """A hardware device, or the firmware running on it, is
                missing or has incorrect protection features to maintain
                goals of security primitives when the device is cooled below
                standard operating temperatures.""" ;
    cwe:id "CWE-1351" ;
    cwe:name "Improper Handling of Hardware Behavior in Exceptionally Cold Environments" .

<http://w3id.org/sepses/resource/cwe/CWE-1357> a cwe:CWE ;
    cwe:description "The product is built from multiple separate components, but it uses a component that is not sufficiently trusted to meet expectations for security, reliability, updateability, and maintainability." ;
    cwe:id "CWE-1357" ;
    cwe:name "Reliance on Insufficiently Trustworthy Component" .

<http://w3id.org/sepses/resource/cwe/CWE-138> a cwe:CWE ;
    cwe:description "The product receives input from an upstream component, but it does not neutralize or incorrectly neutralizes special elements that could be interpreted as control elements or syntactic markers when they are sent to a downstream component." ;
    cwe:id "CWE-138" ;
    cwe:name "Improper Neutralization of Special Elements" .

<http://w3id.org/sepses/resource/cwe/CWE-1384> a cwe:CWE ;
    cwe:description "The product does not properly handle unexpected physical or environmental conditions that occur naturally or are artificially induced." ;
    cwe:id "CWE-1384" ;
    cwe:name "Improper Handling of Physical or Environmental Conditions" .

<http://w3id.org/sepses/resource/cwe/CWE-1385> a cwe:CWE ;
    cwe:description "The product uses a WebSocket, but it does not properly verify that the source of data or communication is valid." ;
    cwe:id "CWE-1385" ;
    cwe:name "Missing Origin Validation in WebSockets" .

<http://w3id.org/sepses/resource/cwe/CWE-1386> a cwe:CWE ;
    cwe:description "The product opens a file or directory, but it does not properly prevent the name from being associated with a junction or mount point to a destination that is outside of the intended control sphere." ;
    cwe:id "CWE-1386" ;
    cwe:name "Insecure Operation on Windows Junction / Mount Point" .

<http://w3id.org/sepses/resource/cwe/CWE-1389> a cwe:CWE ;
    cwe:description "The product parses numeric input assuming base 10 (decimal) values, but it does not account for inputs that use a different base number (radix)." ;
    cwe:id "CWE-1389" ;
    cwe:name "Incorrect Parsing of Numbers with Different Radices" .

<http://w3id.org/sepses/resource/cwe/CWE-1390> a cwe:CWE ;
    cwe:description "The product uses an authentication mechanism to restrict access to specific users or identities, but the mechanism does not sufficiently prove that the claimed identity is correct." ;
    cwe:id "CWE-1390" ;
    cwe:name "Weak Authentication" .

<http://w3id.org/sepses/resource/cwe/CWE-1391> a cwe:CWE ;
    cwe:description "The product uses weak credentials (such as a default key or hard-coded password) that can be calculated, derived, reused, or guessed by an attacker." ;
    cwe:id "CWE-1391" ;
    cwe:name "Use of Weak Credentials" .

<http://w3id.org/sepses/resource/cwe/CWE-1392> a cwe:CWE ;
    cwe:description "The product uses default credentials (such as passwords or cryptographic keys) for potentially critical functionality." ;
    cwe:id "CWE-1392" ;
    cwe:name "Use of Default Credentials" .

<http://w3id.org/sepses/resource/cwe/CWE-1393> a cwe:CWE ;
    cwe:description "The product uses default passwords for potentially critical functionality." ;
    cwe:id "CWE-1393" ;
    cwe:name "Use of Default Password" .

<http://w3id.org/sepses/resource/cwe/CWE-1394> a cwe:CWE ;
    cwe:description "The product uses a default cryptographic key for potentially critical functionality." ;
    cwe:id "CWE-1394" ;
    cwe:name "Use of Default Cryptographic Key" .

<http://w3id.org/sepses/resource/cwe/CWE-1395> a cwe:CWE ;
    cwe:description "The product has a dependency on a third-party component that contains one or more known vulnerabilities." ;
    cwe:id "CWE-1395" ;
    cwe:name "Dependency on Vulnerable Third-Party Component" .

<http://w3id.org/sepses/resource/cwe/CWE-14> a cwe:CWE ;
    cwe:description "Sensitive memory is cleared according to the source code, but compiler optimizations leave the memory untouched when it is not read from again, aka \"dead store removal.\"" ;
    cwe:id "CWE-14" ;
    cwe:name "Compiler Removal of Code to Clear Buffers" .

<http://w3id.org/sepses/resource/cwe/CWE-140> a cwe:CWE ;
    cwe:description "The product does not neutralize or incorrectly neutralizes delimiters." ;
    cwe:id "CWE-140" ;
    cwe:name "Improper Neutralization of Delimiters" .

<http://w3id.org/sepses/resource/cwe/CWE-141> a cwe:CWE ;
    cwe:description "The product receives input from an upstream component, but it does not neutralize or incorrectly neutralizes special elements that could be interpreted as parameter or argument delimiters when they are sent to a downstream component." ;
    cwe:id "CWE-141" ;
    cwe:name "Improper Neutralization of Parameter/Argument Delimiters" .

<http://w3id.org/sepses/resource/cwe/CWE-1419> a cwe:CWE ;
    cwe:description "The product attempts to initialize a resource but does not correctly do so, which might leave the resource in an unexpected, incorrect, or insecure state when it is accessed." ;
    cwe:id "CWE-1419" ;
    cwe:name "Incorrect Initialization of Resource" .

<http://w3id.org/sepses/resource/cwe/CWE-142> a cwe:CWE ;
    cwe:description "The product receives input from an upstream component, but it does not neutralize or incorrectly neutralizes special elements that could be interpreted as value delimiters when they are sent to a downstream component." ;
    cwe:id "CWE-142" ;
    cwe:name "Improper Neutralization of Value Delimiters" .

<http://w3id.org/sepses/resource/cwe/CWE-1420> a cwe:CWE ;
    cwe:description "A processor event or prediction may allow incorrect operations (or correct operations with incorrect data) to execute transiently, potentially exposing data over a covert channel." ;
    cwe:id "CWE-1420" ;
    cwe:name "Exposure of Sensitive Information during Transient Execution" .

<http://w3id.org/sepses/resource/cwe/CWE-1421> a cwe:CWE ;
    cwe:description """
			A processor event may allow transient operations to access
			architecturally restricted data (for example, in another address
			space) in a shared microarchitectural structure (for example, a CPU
			cache), potentially exposing the data over a covert channel.
		  """ ;
    cwe:id "CWE-1421" ;
    cwe:name "Exposure of Sensitive Information in Shared Microarchitectural Structures during Transient Execution" .

<http://w3id.org/sepses/resource/cwe/CWE-1422> a cwe:CWE ;
    cwe:description """A processor event or prediction may allow incorrect or stale data to
		  be forwarded to transient operations, potentially exposing data over a
		  covert channel.""" ;
    cwe:id "CWE-1422" ;
    cwe:name "Exposure of Sensitive Information caused by Incorrect Data Forwarding during Transient Execution" .

<http://w3id.org/sepses/resource/cwe/CWE-1423> a cwe:CWE ;
    cwe:description """Shared microarchitectural predictor state may allow code to influence
				transient execution across a hardware boundary, potentially exposing
				data that is accessible beyond the boundary over a covert channel.
			""" ;
    cwe:id "CWE-1423" ;
    cwe:name "Exposure of Sensitive Information caused by Shared Microarchitectural Predictor State that Influences Transient Execution" .

<http://w3id.org/sepses/resource/cwe/CWE-1426> a cwe:CWE ;
    cwe:description """The product invokes a generative AI/ML
			component whose behaviors and outputs cannot be directly
			controlled, but the product does not validate or
			insufficiently validates the outputs to ensure that they
			align with the intended security, content, or privacy
			policy.""" ;
    cwe:id "CWE-1426" ;
    cwe:name "Improper Validation of Generative AI Output" .

<http://w3id.org/sepses/resource/cwe/CWE-1427> a cwe:CWE ;
    cwe:description """The product uses externally-provided data to build prompts provided to
large language models (LLMs), but the way these prompts are constructed
causes the LLM to fail to distinguish between user-supplied inputs and
developer provided system directives.""" ;
    cwe:id "CWE-1427" ;
    cwe:name "Improper Neutralization of Input Used for LLM Prompting" .

<http://w3id.org/sepses/resource/cwe/CWE-1428> a cwe:CWE ;
    cwe:description "The product provides or relies on use of HTTP communications when HTTPS is available." ;
    cwe:id "CWE-1428" ;
    cwe:name "Reliance on HTTP instead of HTTPS" .

<http://w3id.org/sepses/resource/cwe/CWE-1429> a cwe:CWE ;
    cwe:description """The product has a hardware interface that silently discards operations
			in situations for which feedback would be security-relevant, such as
			the timely detection of failures or attacks.""" ;
    cwe:id "CWE-1429" ;
    cwe:name "Missing Security-Relevant Feedback for Unexecuted Operations in Hardware Interface" .

<http://w3id.org/sepses/resource/cwe/CWE-143> a cwe:CWE ;
    cwe:description "The product receives input from an upstream component, but it does not neutralize or incorrectly neutralizes special elements that could be interpreted as record delimiters when they are sent to a downstream component." ;
    cwe:id "CWE-143" ;
    cwe:name "Improper Neutralization of Record Delimiters" .

<http://w3id.org/sepses/resource/cwe/CWE-1431> a cwe:CWE ;
    cwe:description """The product uses a hardware module implementing a cryptographic
		  algorithm that writes sensitive information about the intermediate
		  state or results of its cryptographic operations via one of its output
		  wires (typically the output port containing the final result).""" ;
    cwe:id "CWE-1431" ;
    cwe:name "Driving Intermediate Cryptographic State/Results to Hardware Module Outputs" .

<http://w3id.org/sepses/resource/cwe/CWE-1434> a cwe:CWE ;
    cwe:description """The product has a component that relies on a
	  generative AI/ML model configured with inference parameters that
	  produce an unacceptably high rate of erroneous or unexpected
	  outputs.""" ;
    cwe:id "CWE-1434" ;
    cwe:name "Insecure Setting of Generative AI/ML Model Inference Parameters" .

<http://w3id.org/sepses/resource/cwe/CWE-144> a cwe:CWE ;
    cwe:description "The product receives input from an upstream component, but it does not neutralize or incorrectly neutralizes special elements that could be interpreted as line delimiters when they are sent to a downstream component." ;
    cwe:id "CWE-144" ;
    cwe:name "Improper Neutralization of Line Delimiters" .

<http://w3id.org/sepses/resource/cwe/CWE-145> a cwe:CWE ;
    cwe:description "The product receives input from an upstream component, but it does not neutralize or incorrectly neutralizes special elements that could be interpreted as section delimiters when they are sent to a downstream component." ;
    cwe:id "CWE-145" ;
    cwe:name "Improper Neutralization of Section Delimiters" .

<http://w3id.org/sepses/resource/cwe/CWE-146> a cwe:CWE ;
    cwe:description "The product receives input from an upstream component, but it does not neutralize or incorrectly neutralizes special elements that could be interpreted as expression or command delimiters when they are sent to a downstream component." ;
    cwe:id "CWE-146" ;
    cwe:name "Improper Neutralization of Expression/Command Delimiters" .

<http://w3id.org/sepses/resource/cwe/CWE-147> a cwe:CWE ;
    cwe:description "The product receives input from an upstream component, but it does not neutralize or incorrectly neutralizes special elements that could be interpreted as input terminators when they are sent to a downstream component." ;
    cwe:id "CWE-147" ;
    cwe:name "Improper Neutralization of Input Terminators" .

<http://w3id.org/sepses/resource/cwe/CWE-148> a cwe:CWE ;
    cwe:description "The product does not properly handle when a leading character or sequence (\"leader\") is missing or malformed, or if multiple leaders are used when only one should be allowed." ;
    cwe:id "CWE-148" ;
    cwe:name "Improper Neutralization of Input Leaders" .

<http://w3id.org/sepses/resource/cwe/CWE-149> a cwe:CWE ;
    cwe:description "Quotes injected into a product can be used to compromise a system. As data are parsed, an injected/absent/duplicate/malformed use of quotes may cause the process to take unexpected actions." ;
    cwe:id "CWE-149" ;
    cwe:name "Improper Neutralization of Quoting Syntax" .

<http://w3id.org/sepses/resource/cwe/CWE-15> a cwe:CWE ;
    cwe:description "One or more system settings or configuration elements can be externally controlled by a user." ;
    cwe:id "CWE-15" ;
    cwe:name "External Control of System or Configuration Setting" .

<http://w3id.org/sepses/resource/cwe/CWE-150> a cwe:CWE ;
    cwe:description "The product receives input from an upstream component, but it does not neutralize or incorrectly neutralizes special elements that could be interpreted as escape, meta, or control character sequences when they are sent to a downstream component." ;
    cwe:id "CWE-150" ;
    cwe:name "Improper Neutralization of Escape, Meta, or Control Sequences" .

<http://w3id.org/sepses/resource/cwe/CWE-151> a cwe:CWE ;
    cwe:description "The product receives input from an upstream component, but it does not neutralize or incorrectly neutralizes special elements that could be interpreted as comment delimiters when they are sent to a downstream component." ;
    cwe:id "CWE-151" ;
    cwe:name "Improper Neutralization of Comment Delimiters" .

<http://w3id.org/sepses/resource/cwe/CWE-152> a cwe:CWE ;
    cwe:description "The product receives input from an upstream component, but it does not neutralize or incorrectly neutralizes special elements that could be interpreted as macro symbols when they are sent to a downstream component." ;
    cwe:id "CWE-152" ;
    cwe:name "Improper Neutralization of Macro Symbols" .

<http://w3id.org/sepses/resource/cwe/CWE-153> a cwe:CWE ;
    cwe:description "The product receives input from an upstream component, but it does not neutralize or incorrectly neutralizes special elements that could be interpreted as substitution characters when they are sent to a downstream component." ;
    cwe:id "CWE-153" ;
    cwe:name "Improper Neutralization of Substitution Characters" .

<http://w3id.org/sepses/resource/cwe/CWE-154> a cwe:CWE ;
    cwe:description "The product receives input from an upstream component, but it does not neutralize or incorrectly neutralizes special elements that could be interpreted as variable name delimiters when they are sent to a downstream component." ;
    cwe:id "CWE-154" ;
    cwe:name "Improper Neutralization of Variable Name Delimiters" .

<http://w3id.org/sepses/resource/cwe/CWE-155> a cwe:CWE ;
    cwe:description "The product receives input from an upstream component, but it does not neutralize or incorrectly neutralizes special elements that could be interpreted as wildcards or matching symbols when they are sent to a downstream component." ;
    cwe:id "CWE-155" ;
    cwe:name "Improper Neutralization of Wildcards or Matching Symbols" .

<http://w3id.org/sepses/resource/cwe/CWE-156> a cwe:CWE ;
    cwe:description "The product receives input from an upstream component, but it does not neutralize or incorrectly neutralizes special elements that could be interpreted as whitespace when they are sent to a downstream component." ;
    cwe:id "CWE-156" ;
    cwe:name "Improper Neutralization of Whitespace" .

<http://w3id.org/sepses/resource/cwe/CWE-157> a cwe:CWE ;
    cwe:description "The product does not properly handle the characters that are used to mark the beginning and ending of a group of entities, such as parentheses, brackets, and braces." ;
    cwe:id "CWE-157" ;
    cwe:name "Failure to Sanitize Paired Delimiters" .

<http://w3id.org/sepses/resource/cwe/CWE-158> a cwe:CWE ;
    cwe:description "The product receives input from an upstream component, but it does not neutralize or incorrectly neutralizes NUL characters or null bytes when they are sent to a downstream component." ;
    cwe:id "CWE-158" ;
    cwe:name "Improper Neutralization of Null Byte or NUL Character" .

<http://w3id.org/sepses/resource/cwe/CWE-159> a cwe:CWE ;
    cwe:description "The product does not properly filter, remove, quote, or otherwise manage the invalid use of special elements in user-controlled input, which could cause adverse effect on its behavior and integrity." ;
    cwe:id "CWE-159" ;
    cwe:name "Improper Handling of Invalid Use of Special Elements" .

<http://w3id.org/sepses/resource/cwe/CWE-160> a cwe:CWE ;
    cwe:description "The product receives input from an upstream component, but it does not neutralize or incorrectly neutralizes leading special elements that could be interpreted in unexpected ways when they are sent to a downstream component." ;
    cwe:id "CWE-160" ;
    cwe:name "Improper Neutralization of Leading Special Elements" .

<http://w3id.org/sepses/resource/cwe/CWE-161> a cwe:CWE ;
    cwe:description "The product receives input from an upstream component, but it does not neutralize or incorrectly neutralizes multiple leading special elements that could be interpreted in unexpected ways when they are sent to a downstream component." ;
    cwe:id "CWE-161" ;
    cwe:name "Improper Neutralization of Multiple Leading Special Elements" .

<http://w3id.org/sepses/resource/cwe/CWE-162> a cwe:CWE ;
    cwe:description "The product receives input from an upstream component, but it does not neutralize or incorrectly neutralizes trailing special elements that could be interpreted in unexpected ways when they are sent to a downstream component." ;
    cwe:id "CWE-162" ;
    cwe:name "Improper Neutralization of Trailing Special Elements" .

<http://w3id.org/sepses/resource/cwe/CWE-163> a cwe:CWE ;
    cwe:description "The product receives input from an upstream component, but it does not neutralize or incorrectly neutralizes multiple trailing special elements that could be interpreted in unexpected ways when they are sent to a downstream component." ;
    cwe:id "CWE-163" ;
    cwe:name "Improper Neutralization of Multiple Trailing Special Elements" .

<http://w3id.org/sepses/resource/cwe/CWE-164> a cwe:CWE ;
    cwe:description "The product receives input from an upstream component, but it does not neutralize or incorrectly neutralizes internal special elements that could be interpreted in unexpected ways when they are sent to a downstream component." ;
    cwe:id "CWE-164" ;
    cwe:name "Improper Neutralization of Internal Special Elements" .

<http://w3id.org/sepses/resource/cwe/CWE-165> a cwe:CWE ;
    cwe:description "The product receives input from an upstream component, but it does not neutralize or incorrectly neutralizes multiple internal special elements that could be interpreted in unexpected ways when they are sent to a downstream component." ;
    cwe:id "CWE-165" ;
    cwe:name "Improper Neutralization of Multiple Internal Special Elements" .

<http://w3id.org/sepses/resource/cwe/CWE-166> a cwe:CWE ;
    cwe:description "The product receives input from an upstream component, but it does not handle or incorrectly handles when an expected special element is missing." ;
    cwe:id "CWE-166" ;
    cwe:name "Improper Handling of Missing Special Element" .

<http://w3id.org/sepses/resource/cwe/CWE-167> a cwe:CWE ;
    cwe:description "The product receives input from an upstream component, but it does not handle or incorrectly handles when an additional unexpected special element is provided." ;
    cwe:id "CWE-167" ;
    cwe:name "Improper Handling of Additional Special Element" .

<http://w3id.org/sepses/resource/cwe/CWE-168> a cwe:CWE ;
    cwe:description "The product does not properly handle input in which an inconsistency exists between two or more special characters or reserved words." ;
    cwe:id "CWE-168" ;
    cwe:name "Improper Handling of Inconsistent Special Elements" .

<http://w3id.org/sepses/resource/cwe/CWE-170> a cwe:CWE ;
    cwe:description "The product does not terminate or incorrectly terminates a string or array with a null character or equivalent terminator." ;
    cwe:id "CWE-170" ;
    cwe:name "Improper Null Termination" .

<http://w3id.org/sepses/resource/cwe/CWE-172> a cwe:CWE ;
    cwe:description "The product does not properly encode or decode the data, resulting in unexpected values." ;
    cwe:id "CWE-172" ;
    cwe:name "Encoding Error" .

<http://w3id.org/sepses/resource/cwe/CWE-173> a cwe:CWE ;
    cwe:description "The product does not properly handle when an input uses an alternate encoding that is valid for the control sphere to which the input is being sent." ;
    cwe:id "CWE-173" ;
    cwe:name "Improper Handling of Alternate Encoding" .

<http://w3id.org/sepses/resource/cwe/CWE-174> a cwe:CWE ;
    cwe:description "The product decodes the same input twice, which can limit the effectiveness of any protection mechanism that occurs in between the decoding operations." ;
    cwe:id "CWE-174" ;
    cwe:name "Double Decoding of the Same Data" .

<http://w3id.org/sepses/resource/cwe/CWE-175> a cwe:CWE ;
    cwe:description "The product does not properly handle when the same input uses several different (mixed) encodings." ;
    cwe:id "CWE-175" ;
    cwe:name "Improper Handling of Mixed Encoding" .

<http://w3id.org/sepses/resource/cwe/CWE-176> a cwe:CWE ;
    cwe:description "The product does not properly handle when an input contains Unicode encoding." ;
    cwe:id "CWE-176" ;
    cwe:name "Improper Handling of Unicode Encoding" .

<http://w3id.org/sepses/resource/cwe/CWE-177> a cwe:CWE ;
    cwe:description "The product does not properly handle when all or part of an input has been URL encoded." ;
    cwe:id "CWE-177" ;
    cwe:name "Improper Handling of URL Encoding (Hex Encoding)" .

<http://w3id.org/sepses/resource/cwe/CWE-178> a cwe:CWE ;
    cwe:description "The product does not properly account for differences in case sensitivity when accessing or determining the properties of a resource, leading to inconsistent results." ;
    cwe:id "CWE-178" ;
    cwe:name "Improper Handling of Case Sensitivity" .

<http://w3id.org/sepses/resource/cwe/CWE-179> a cwe:CWE ;
    cwe:description "The product validates input before applying protection mechanisms that modify the input, which could allow an attacker to bypass the validation via dangerous inputs that only arise after the modification." ;
    cwe:id "CWE-179" ;
    cwe:name "Incorrect Behavior Order: Early Validation" .

<http://w3id.org/sepses/resource/cwe/CWE-180> a cwe:CWE ;
    cwe:description "The product validates input before it is canonicalized, which prevents the product from detecting data that becomes invalid after the canonicalization step." ;
    cwe:id "CWE-180" ;
    cwe:name "Incorrect Behavior Order: Validate Before Canonicalize" .

<http://w3id.org/sepses/resource/cwe/CWE-181> a cwe:CWE ;
    cwe:description "The product validates data before it has been filtered, which prevents the product from detecting data that becomes invalid after the filtering step." ;
    cwe:id "CWE-181" ;
    cwe:name "Incorrect Behavior Order: Validate Before Filter" .

<http://w3id.org/sepses/resource/cwe/CWE-182> a cwe:CWE ;
    cwe:description "The product filters data in a way that causes it to be reduced or \"collapsed\" into an unsafe value that violates an expected security property." ;
    cwe:id "CWE-182" ;
    cwe:name "Collapse of Data into Unsafe Value" .

<http://w3id.org/sepses/resource/cwe/CWE-183> a cwe:CWE ;
    cwe:description "The product implements a protection mechanism that relies on a list of inputs (or properties of inputs) that are explicitly allowed by policy because the inputs are assumed to be safe, but the list is too permissive - that is, it allows an input that is unsafe, leading to resultant weaknesses." ;
    cwe:id "CWE-183" ;
    cwe:name "Permissive List of Allowed Inputs" .

<http://w3id.org/sepses/resource/cwe/CWE-184> a cwe:CWE ;
    cwe:description "The product implements a protection mechanism that relies on a list of inputs (or properties of inputs) that are not allowed by policy or otherwise require other action to neutralize before additional processing takes place, but the list is incomplete." ;
    cwe:id "CWE-184" ;
    cwe:name "Incomplete List of Disallowed Inputs" .

<http://w3id.org/sepses/resource/cwe/CWE-185> a cwe:CWE ;
    cwe:description "The product specifies a regular expression in a way that causes data to be improperly matched or compared." ;
    cwe:id "CWE-185" ;
    cwe:name "Incorrect Regular Expression" .

<http://w3id.org/sepses/resource/cwe/CWE-186> a cwe:CWE ;
    cwe:description "A regular expression is overly restrictive, which prevents dangerous values from being detected." ;
    cwe:id "CWE-186" ;
    cwe:name "Overly Restrictive Regular Expression" .

<http://w3id.org/sepses/resource/cwe/CWE-187> a cwe:CWE ;
    cwe:description "The product performs a comparison that only examines a portion of a factor before determining whether there is a match, such as a substring, leading to resultant weaknesses." ;
    cwe:id "CWE-187" ;
    cwe:name "Partial String Comparison" .

<http://w3id.org/sepses/resource/cwe/CWE-188> a cwe:CWE ;
    cwe:description "The product makes invalid assumptions about how protocol data or memory is organized at a lower level, resulting in unintended program behavior." ;
    cwe:id "CWE-188" ;
    cwe:name "Reliance on Data/Memory Layout" .

<http://w3id.org/sepses/resource/cwe/CWE-190> a cwe:CWE ;
    cwe:description """The product performs a calculation that can
         produce an integer overflow or wraparound when the logic
         assumes that the resulting value will always be larger than
         the original value. This occurs when an integer value is
         incremented to a value that is too large to store in the
         associated representation. When this occurs, the value may
         become a very small or negative number.""" ;
    cwe:id "CWE-190" ;
    cwe:name "Integer Overflow or Wraparound" .

<http://w3id.org/sepses/resource/cwe/CWE-191> a cwe:CWE ;
    cwe:description "The product subtracts one value from another, such that the result is less than the minimum allowable integer value, which produces a value that is not equal to the correct result." ;
    cwe:id "CWE-191" ;
    cwe:name "Integer Underflow (Wrap or Wraparound)" .

<http://w3id.org/sepses/resource/cwe/CWE-192> a cwe:CWE ;
    cwe:description "Integer coercion refers to a set of flaws pertaining to the type casting, extension, or truncation of primitive data types." ;
    cwe:id "CWE-192" ;
    cwe:name "Integer Coercion Error" .

<http://w3id.org/sepses/resource/cwe/CWE-193> a cwe:CWE ;
    cwe:description "A product calculates or uses an incorrect maximum or minimum value that is 1 more, or 1 less, than the correct value." ;
    cwe:id "CWE-193" ;
    cwe:name "Off-by-one Error" .

<http://w3id.org/sepses/resource/cwe/CWE-194> a cwe:CWE ;
    cwe:description "The product performs an operation on a number that causes it to be sign extended when it is transformed into a larger data type. When the original number is negative, this can produce unexpected values that lead to resultant weaknesses." ;
    cwe:id "CWE-194" ;
    cwe:name "Unexpected Sign Extension" .

<http://w3id.org/sepses/resource/cwe/CWE-195> a cwe:CWE ;
    cwe:description "The product uses a signed primitive and performs a cast to an unsigned primitive, which can produce an unexpected value if the value of the signed primitive can not be represented using an unsigned primitive." ;
    cwe:id "CWE-195" ;
    cwe:name "Signed to Unsigned Conversion Error" .

<http://w3id.org/sepses/resource/cwe/CWE-196> a cwe:CWE ;
    cwe:description "The product uses an unsigned primitive and performs a cast to a signed primitive, which can produce an unexpected value if the value of the unsigned primitive can not be represented using a signed primitive." ;
    cwe:id "CWE-196" ;
    cwe:name "Unsigned to Signed Conversion Error" .

<http://w3id.org/sepses/resource/cwe/CWE-197> a cwe:CWE ;
    cwe:description "Truncation errors occur when a primitive is cast to a primitive of a smaller size and data is lost in the conversion." ;
    cwe:id "CWE-197" ;
    cwe:name "Numeric Truncation Error" .

<http://w3id.org/sepses/resource/cwe/CWE-198> a cwe:CWE ;
    cwe:description "The product receives input from an upstream component, but it does not account for byte ordering (e.g. big-endian and little-endian) when processing the input, causing an incorrect number or value to be used." ;
    cwe:id "CWE-198" ;
    cwe:name "Use of Incorrect Byte Ordering" .

<http://w3id.org/sepses/resource/cwe/CWE-20> a cwe:CWE ;
    cwe:description """The product receives input or data, but it does
        not validate or incorrectly validates that the input has the
        properties that are required to process the data safely and
        correctly.""" ;
    cwe:id "CWE-20" ;
    cwe:name "Improper Input Validation" .

<http://w3id.org/sepses/resource/cwe/CWE-200> a cwe:CWE ;
    cwe:description "The product exposes sensitive information to an actor that is not explicitly authorized to have access to that information." ;
    cwe:id "CWE-200" ;
    cwe:name "Exposure of Sensitive Information to an Unauthorized Actor" .

<http://w3id.org/sepses/resource/cwe/CWE-201> a cwe:CWE ;
    cwe:description "The code transmits data to another actor, but a portion of the data includes sensitive information that should not be accessible to that actor." ;
    cwe:id "CWE-201" ;
    cwe:name "Insertion of Sensitive Information Into Sent Data" .

<http://w3id.org/sepses/resource/cwe/CWE-202> a cwe:CWE ;
    cwe:description "When trying to keep information confidential, an attacker can often infer some of the information by using statistics." ;
    cwe:id "CWE-202" ;
    cwe:name "Exposure of Sensitive Information Through Data Queries" .

<http://w3id.org/sepses/resource/cwe/CWE-203> a cwe:CWE ;
    cwe:description "The product behaves differently or sends different responses under different circumstances in a way that is observable to an unauthorized actor." ;
    cwe:id "CWE-203" ;
    cwe:name "Observable Discrepancy" .

<http://w3id.org/sepses/resource/cwe/CWE-204> a cwe:CWE ;
    cwe:description "The product provides different responses to incoming requests in a way that reveals internal state information to an unauthorized actor outside of the intended control sphere." ;
    cwe:id "CWE-204" ;
    cwe:name "Observable Response Discrepancy" .

<http://w3id.org/sepses/resource/cwe/CWE-205> a cwe:CWE ;
    cwe:description "The product's behaviors indicate important differences that may be observed by unauthorized actors in a way that reveals (1) its internal state or decision process, or (2) differences from other products with equivalent functionality." ;
    cwe:id "CWE-205" ;
    cwe:name "Observable Behavioral Discrepancy" .

<http://w3id.org/sepses/resource/cwe/CWE-206> a cwe:CWE ;
    cwe:description "The product performs multiple behaviors that are combined to produce a single result, but the individual behaviors are observable separately in a way that allows attackers to reveal internal state or internal decision points." ;
    cwe:id "CWE-206" ;
    cwe:name "Observable Internal Behavioral Discrepancy" .

<http://w3id.org/sepses/resource/cwe/CWE-207> a cwe:CWE ;
    cwe:description "The product operates in an environment in which its existence or specific identity should not be known, but it behaves differently than other products with equivalent functionality, in a way that is observable to an attacker." ;
    cwe:id "CWE-207" ;
    cwe:name "Observable Behavioral Discrepancy With Equivalent Products" .

<http://w3id.org/sepses/resource/cwe/CWE-208> a cwe:CWE ;
    cwe:description "Two separate operations in a product require different amounts of time to complete, in a way that is observable to an actor and reveals security-relevant information about the state of the product, such as whether a particular operation was successful or not." ;
    cwe:id "CWE-208" ;
    cwe:name "Observable Timing Discrepancy" .

<http://w3id.org/sepses/resource/cwe/CWE-209> a cwe:CWE ;
    cwe:description "The product generates an error message that includes sensitive information about its environment, users, or associated data." ;
    cwe:id "CWE-209" ;
    cwe:name "Generation of Error Message Containing Sensitive Information" .

<http://w3id.org/sepses/resource/cwe/CWE-210> a cwe:CWE ;
    cwe:description "The product identifies an error condition and creates its own diagnostic or error messages that contain sensitive information." ;
    cwe:id "CWE-210" ;
    cwe:name "Self-generated Error Message Containing Sensitive Information" .

<http://w3id.org/sepses/resource/cwe/CWE-211> a cwe:CWE ;
    cwe:description "The product performs an operation that triggers an external diagnostic or error message that is not directly generated or controlled by the product, such as an error generated by the programming language interpreter that a software application uses. The error can contain sensitive system information." ;
    cwe:id "CWE-211" ;
    cwe:name "Externally-Generated Error Message Containing Sensitive Information" .

<http://w3id.org/sepses/resource/cwe/CWE-212> a cwe:CWE ;
    cwe:description "The product stores, transfers, or shares a resource that contains sensitive information, but it does not properly remove that information before the product makes the resource available to unauthorized actors." ;
    cwe:id "CWE-212" ;
    cwe:name "Improper Removal of Sensitive Information Before Storage or Transfer" .

<http://w3id.org/sepses/resource/cwe/CWE-213> a cwe:CWE ;
    cwe:description "The product's intended functionality exposes information to certain actors in accordance with the developer's security policy, but this information is regarded as sensitive according to the intended security policies of other stakeholders such as the product's administrator, users, or others whose information is being processed." ;
    cwe:id "CWE-213" ;
    cwe:name "Exposure of Sensitive Information Due to Incompatible Policies" .

<http://w3id.org/sepses/resource/cwe/CWE-214> a cwe:CWE ;
    cwe:description "A process is invoked with sensitive command-line arguments, environment variables, or other elements that can be seen by other processes on the operating system." ;
    cwe:id "CWE-214" ;
    cwe:name "Invocation of Process Using Visible Sensitive Information" .

<http://w3id.org/sepses/resource/cwe/CWE-215> a cwe:CWE ;
    cwe:description "The product inserts sensitive information into debugging code, which could expose this information if the debugging code is not disabled in production." ;
    cwe:id "CWE-215" ;
    cwe:name "Insertion of Sensitive Information Into Debugging Code" .

<http://w3id.org/sepses/resource/cwe/CWE-216> a cwe:CWE ;
    cwe:description "This entry has been deprecated, as it was not effective as a weakness and was structured more like a category. In addition, the name is inappropriate, since the \"container\" term is widely understood by developers in different ways than originally intended by PLOVER, the original source for this entry." ;
    cwe:id "CWE-216" ;
    cwe:name "DEPRECATED: Containment Errors (Container Errors)" .

<http://w3id.org/sepses/resource/cwe/CWE-217> a cwe:CWE ;
    cwe:description "This entry has been deprecated because it incorporated and confused multiple weaknesses. The issues formerly covered in this entry can be found at CWE-766 and CWE-767." ;
    cwe:id "CWE-217" ;
    cwe:name "DEPRECATED: Failure to Protect Stored Data from Modification" .

<http://w3id.org/sepses/resource/cwe/CWE-218> a cwe:CWE ;
    cwe:description "This weakness has been deprecated because it was a duplicate of CWE-493. All content has been transferred to CWE-493." ;
    cwe:id "CWE-218" ;
    cwe:name "DEPRECATED: Failure to provide confidentiality for stored data" .

<http://w3id.org/sepses/resource/cwe/CWE-219> a cwe:CWE ;
    cwe:description "The product stores sensitive data under the web document root with insufficient access control, which might make it accessible to untrusted parties." ;
    cwe:id "CWE-219" ;
    cwe:name "Storage of File with Sensitive Data Under Web Root" .

<http://w3id.org/sepses/resource/cwe/CWE-22> a cwe:CWE ;
    cwe:description "The product uses external input to construct a pathname that is intended to identify a file or directory that is located underneath a restricted parent directory, but the product does not properly neutralize special elements within the pathname that can cause the pathname to resolve to a location that is outside of the restricted directory." ;
    cwe:id "CWE-22" ;
    cwe:name "Improper Limitation of a Pathname to a Restricted Directory ('Path Traversal')" .

<http://w3id.org/sepses/resource/cwe/CWE-220> a cwe:CWE ;
    cwe:description "The product stores sensitive data under the FTP server root with insufficient access control, which might make it accessible to untrusted parties." ;
    cwe:id "CWE-220" ;
    cwe:name "Storage of File With Sensitive Data Under FTP Root" .

<http://w3id.org/sepses/resource/cwe/CWE-221> a cwe:CWE ;
    cwe:description "The product does not record, or improperly records, security-relevant information that leads to an incorrect decision or hampers later analysis." ;
    cwe:id "CWE-221" ;
    cwe:name "Information Loss or Omission" .

<http://w3id.org/sepses/resource/cwe/CWE-222> a cwe:CWE ;
    cwe:description "The product truncates the display, recording, or processing of security-relevant information in a way that can obscure the source or nature of an attack." ;
    cwe:id "CWE-222" ;
    cwe:name "Truncation of Security-relevant Information" .

<http://w3id.org/sepses/resource/cwe/CWE-223> a cwe:CWE ;
    cwe:description "The product does not record or display information that would be important for identifying the source or nature of an attack, or determining if an action is safe." ;
    cwe:id "CWE-223" ;
    cwe:name "Omission of Security-relevant Information" .

<http://w3id.org/sepses/resource/cwe/CWE-224> a cwe:CWE ;
    cwe:description "The product records security-relevant information according to an alternate name of the affected entity, instead of the canonical name." ;
    cwe:id "CWE-224" ;
    cwe:name "Obscured Security-relevant Information by Alternate Name" .

<http://w3id.org/sepses/resource/cwe/CWE-225> a cwe:CWE ;
    cwe:description "This weakness can be found at CWE-199." ;
    cwe:id "CWE-225" ;
    cwe:name "DEPRECATED: General Information Management Problems" .

<http://w3id.org/sepses/resource/cwe/CWE-226> a cwe:CWE ;
    cwe:description "The product releases a resource such as memory or a file so that it can be made available for reuse, but it does not clear or \"zeroize\" the information contained in the resource before the product performs a critical state transition or makes the resource available for reuse by other entities." ;
    cwe:id "CWE-226" ;
    cwe:name "Sensitive Information in Resource Not Removed Before Reuse" .

<http://w3id.org/sepses/resource/cwe/CWE-228> a cwe:CWE ;
    cwe:description "The product does not handle or incorrectly handles input that is not syntactically well-formed with respect to the associated specification." ;
    cwe:id "CWE-228" ;
    cwe:name "Improper Handling of Syntactically Invalid Structure" .

<http://w3id.org/sepses/resource/cwe/CWE-229> a cwe:CWE ;
    cwe:description "The product does not properly handle when the expected number of values for parameters, fields, or arguments is not provided in input, or if those values are undefined." ;
    cwe:id "CWE-229" ;
    cwe:name "Improper Handling of Values" .

<http://w3id.org/sepses/resource/cwe/CWE-23> a cwe:CWE ;
    cwe:description "The product uses external input to construct a pathname that should be within a restricted directory, but it does not properly neutralize sequences such as \"..\" that can resolve to a location that is outside of that directory." ;
    cwe:id "CWE-23" ;
    cwe:name "Relative Path Traversal" .

<http://w3id.org/sepses/resource/cwe/CWE-230> a cwe:CWE ;
    cwe:description "The product does not handle or incorrectly handles when a parameter, field, or argument name is specified, but the associated value is missing, i.e. it is empty, blank, or null." ;
    cwe:id "CWE-230" ;
    cwe:name "Improper Handling of Missing Values" .

<http://w3id.org/sepses/resource/cwe/CWE-231> a cwe:CWE ;
    cwe:description "The product does not handle or incorrectly handles when more values are provided than expected." ;
    cwe:id "CWE-231" ;
    cwe:name "Improper Handling of Extra Values" .

<http://w3id.org/sepses/resource/cwe/CWE-232> a cwe:CWE ;
    cwe:description "The product does not handle or incorrectly handles when a value is not defined or supported for the associated parameter, field, or argument name." ;
    cwe:id "CWE-232" ;
    cwe:name "Improper Handling of Undefined Values" .

<http://w3id.org/sepses/resource/cwe/CWE-233> a cwe:CWE ;
    cwe:description "The product does not properly handle when the expected number of parameters, fields, or arguments is not provided in input, or if those parameters are undefined." ;
    cwe:id "CWE-233" ;
    cwe:name "Improper Handling of Parameters" .

<http://w3id.org/sepses/resource/cwe/CWE-234> a cwe:CWE ;
    cwe:description "If too few arguments are sent to a function, the function will still pop the expected number of arguments from the stack. Potentially, a variable number of arguments could be exhausted in a function as well." ;
    cwe:id "CWE-234" ;
    cwe:name "Failure to Handle Missing Parameter" .

<http://w3id.org/sepses/resource/cwe/CWE-235> a cwe:CWE ;
    cwe:description "The product does not handle or incorrectly handles when the number of parameters, fields, or arguments with the same name exceeds the expected amount." ;
    cwe:id "CWE-235" ;
    cwe:name "Improper Handling of Extra Parameters" .

<http://w3id.org/sepses/resource/cwe/CWE-236> a cwe:CWE ;
    cwe:description "The product does not handle or incorrectly handles when a particular parameter, field, or argument name is not defined or supported by the product." ;
    cwe:id "CWE-236" ;
    cwe:name "Improper Handling of Undefined Parameters" .

<http://w3id.org/sepses/resource/cwe/CWE-237> a cwe:CWE ;
    cwe:description "The product does not handle or incorrectly handles inputs that are related to complex structures." ;
    cwe:id "CWE-237" ;
    cwe:name "Improper Handling of Structural Elements" .

<http://w3id.org/sepses/resource/cwe/CWE-238> a cwe:CWE ;
    cwe:description "The product does not handle or incorrectly handles when a particular structural element is not completely specified." ;
    cwe:id "CWE-238" ;
    cwe:name "Improper Handling of Incomplete Structural Elements" .

<http://w3id.org/sepses/resource/cwe/CWE-239> a cwe:CWE ;
    cwe:description "The product does not properly handle when a particular element is not completely specified." ;
    cwe:id "CWE-239" ;
    cwe:name "Failure to Handle Incomplete Element" .

<http://w3id.org/sepses/resource/cwe/CWE-24> a cwe:CWE ;
    cwe:description "The product uses external input to construct a pathname that should be within a restricted directory, but it does not properly neutralize \"../\" sequences that can resolve to a location that is outside of that directory." ;
    cwe:id "CWE-24" ;
    cwe:name "Path Traversal: '../filedir'" .

<http://w3id.org/sepses/resource/cwe/CWE-240> a cwe:CWE ;
    cwe:description "The product does not handle or incorrectly handles when two or more structural elements should be consistent, but are not." ;
    cwe:id "CWE-240" ;
    cwe:name "Improper Handling of Inconsistent Structural Elements" .

<http://w3id.org/sepses/resource/cwe/CWE-241> a cwe:CWE ;
    cwe:description "The product does not handle or incorrectly handles when a particular element is not the expected type, e.g. it expects a digit (0-9) but is provided with a letter (A-Z)." ;
    cwe:id "CWE-241" ;
    cwe:name "Improper Handling of Unexpected Data Type" .

<http://w3id.org/sepses/resource/cwe/CWE-242> a cwe:CWE ;
    cwe:description "The product calls a function that can never be guaranteed to work safely." ;
    cwe:id "CWE-242" ;
    cwe:name "Use of Inherently Dangerous Function" .

<http://w3id.org/sepses/resource/cwe/CWE-243> a cwe:CWE ;
    cwe:description "The product uses the chroot() system call to create a jail, but does not change the working directory afterward. This does not prevent access to files outside of the jail." ;
    cwe:id "CWE-243" ;
    cwe:name "Creation of chroot Jail Without Changing Working Directory" .

<http://w3id.org/sepses/resource/cwe/CWE-244> a cwe:CWE ;
    cwe:description "Using realloc() to resize buffers that store sensitive information can leave the sensitive information exposed to attack, because it is not removed from memory." ;
    cwe:id "CWE-244" ;
    cwe:name "Improper Clearing of Heap Memory Before Release ('Heap Inspection')" .

<http://w3id.org/sepses/resource/cwe/CWE-245> a cwe:CWE ;
    cwe:description "The J2EE application directly manages connections, instead of using the container's connection management facilities." ;
    cwe:id "CWE-245" ;
    cwe:name "J2EE Bad Practices: Direct Management of Connections" .

<http://w3id.org/sepses/resource/cwe/CWE-246> a cwe:CWE ;
    cwe:description "The J2EE application directly uses sockets instead of using framework method calls." ;
    cwe:id "CWE-246" ;
    cwe:name "J2EE Bad Practices: Direct Use of Sockets" .

<http://w3id.org/sepses/resource/cwe/CWE-247> a cwe:CWE ;
    cwe:description "This entry has been deprecated because it was a duplicate of CWE-350. All content has been transferred to CWE-350." ;
    cwe:id "CWE-247" ;
    cwe:name "DEPRECATED: Reliance on DNS Lookups in a Security Decision" .

<http://w3id.org/sepses/resource/cwe/CWE-248> a cwe:CWE ;
    cwe:description "An exception is thrown from a function, but it is not caught." ;
    cwe:id "CWE-248" ;
    cwe:name "Uncaught Exception" .

<http://w3id.org/sepses/resource/cwe/CWE-249> a cwe:CWE ;
    cwe:description """This entry has been deprecated because of name
	confusion and an accidental combination of multiple
	weaknesses. Most of its content has been transferred to
	CWE-785.""" ;
    cwe:id "CWE-249" ;
    cwe:name "DEPRECATED: Often Misused: Path Manipulation" .

<http://w3id.org/sepses/resource/cwe/CWE-25> a cwe:CWE ;
    cwe:description "The product uses external input to construct a pathname that should be within a restricted directory, but it does not properly neutralize \"/../\" sequences that can resolve to a location that is outside of that directory." ;
    cwe:id "CWE-25" ;
    cwe:name "Path Traversal: '/../filedir'" .

<http://w3id.org/sepses/resource/cwe/CWE-250> a cwe:CWE ;
    cwe:description "The product performs an operation at a privilege level that is higher than the minimum level required, which creates new weaknesses or amplifies the consequences of other weaknesses." ;
    cwe:id "CWE-250" ;
    cwe:name "Execution with Unnecessary Privileges" .

<http://w3id.org/sepses/resource/cwe/CWE-252> a cwe:CWE ;
    cwe:description "The product does not check the return value from a method or function, which can prevent it from detecting unexpected states and conditions." ;
    cwe:id "CWE-252" ;
    cwe:name "Unchecked Return Value" .

<http://w3id.org/sepses/resource/cwe/CWE-253> a cwe:CWE ;
    cwe:description "The product incorrectly checks a return value from a function, which prevents it from detecting errors or exceptional conditions." ;
    cwe:id "CWE-253" ;
    cwe:name "Incorrect Check of Function Return Value" .

<http://w3id.org/sepses/resource/cwe/CWE-256> a cwe:CWE ;
    cwe:description "The product stores a password in plaintext within resources such as memory or files." ;
    cwe:id "CWE-256" ;
    cwe:name "Plaintext Storage of a Password" .

<http://w3id.org/sepses/resource/cwe/CWE-257> a cwe:CWE ;
    cwe:description "The storage of passwords in a recoverable format makes them subject to password reuse attacks by malicious users. In fact, it should be noted that recoverable encrypted passwords provide no significant benefit over plaintext passwords since they are subject not only to reuse by malicious attackers but also by malicious insiders. If a system administrator can recover a password directly, or use a brute force search on the available information, the administrator can use the password on other accounts." ;
    cwe:id "CWE-257" ;
    cwe:name "Storing Passwords in a Recoverable Format" .

<http://w3id.org/sepses/resource/cwe/CWE-258> a cwe:CWE ;
    cwe:description "Using an empty string as a password is insecure." ;
    cwe:id "CWE-258" ;
    cwe:name "Empty Password in Configuration File" .

<http://w3id.org/sepses/resource/cwe/CWE-259> a cwe:CWE ;
    cwe:description "The product contains a hard-coded password, which it uses for its own inbound authentication or for outbound communication to external components." ;
    cwe:id "CWE-259" ;
    cwe:name "Use of Hard-coded Password" .

<http://w3id.org/sepses/resource/cwe/CWE-26> a cwe:CWE ;
    cwe:description "The product uses external input to construct a pathname that should be within a restricted directory, but it does not properly neutralize \"/dir/../filename\" sequences that can resolve to a location that is outside of that directory." ;
    cwe:id "CWE-26" ;
    cwe:name "Path Traversal: '/dir/../filename'" .

<http://w3id.org/sepses/resource/cwe/CWE-260> a cwe:CWE ;
    cwe:description "The product stores a password in a configuration file that might be accessible to actors who do not know the password." ;
    cwe:id "CWE-260" ;
    cwe:name "Password in Configuration File" .

<http://w3id.org/sepses/resource/cwe/CWE-261> a cwe:CWE ;
    cwe:description "Obscuring a password with a trivial encoding does not protect the password." ;
    cwe:id "CWE-261" ;
    cwe:name "Weak Encoding for Password" .

<http://w3id.org/sepses/resource/cwe/CWE-262> a cwe:CWE ;
    cwe:description "The product does not have a mechanism in place for managing password aging." ;
    cwe:id "CWE-262" ;
    cwe:name "Not Using Password Aging" .

<http://w3id.org/sepses/resource/cwe/CWE-263> a cwe:CWE ;
    cwe:description "The product supports password aging, but the expiration period is too long." ;
    cwe:id "CWE-263" ;
    cwe:name "Password Aging with Long Expiration" .

<http://w3id.org/sepses/resource/cwe/CWE-266> a cwe:CWE ;
    cwe:description "A product incorrectly assigns a privilege to a particular actor, creating an unintended sphere of control for that actor." ;
    cwe:id "CWE-266" ;
    cwe:name "Incorrect Privilege Assignment" .

<http://w3id.org/sepses/resource/cwe/CWE-267> a cwe:CWE ;
    cwe:description "A particular privilege, role, capability, or right can be used to perform unsafe actions that were not intended, even when it is assigned to the correct entity." ;
    cwe:id "CWE-267" ;
    cwe:name "Privilege Defined With Unsafe Actions" .

<http://w3id.org/sepses/resource/cwe/CWE-268> a cwe:CWE ;
    cwe:description "Two distinct privileges, roles, capabilities, or rights can be combined in a way that allows an entity to perform unsafe actions that would not be allowed without that combination." ;
    cwe:id "CWE-268" ;
    cwe:name "Privilege Chaining" .

<http://w3id.org/sepses/resource/cwe/CWE-269> a cwe:CWE ;
    cwe:description "The product does not properly assign, modify, track, or check privileges for an actor, creating an unintended sphere of control for that actor." ;
    cwe:id "CWE-269" ;
    cwe:name "Improper Privilege Management" .

<http://w3id.org/sepses/resource/cwe/CWE-27> a cwe:CWE ;
    cwe:description "The product uses external input to construct a pathname that should be within a restricted directory, but it does not properly neutralize multiple internal \"../\" sequences that can resolve to a location that is outside of that directory." ;
    cwe:id "CWE-27" ;
    cwe:name "Path Traversal: 'dir/../../filename'" .

<http://w3id.org/sepses/resource/cwe/CWE-270> a cwe:CWE ;
    cwe:description "The product does not properly manage privileges while it is switching between different contexts that have different privileges or spheres of control." ;
    cwe:id "CWE-270" ;
    cwe:name "Privilege Context Switching Error" .

<http://w3id.org/sepses/resource/cwe/CWE-271> a cwe:CWE ;
    cwe:description "The product does not drop privileges before passing control of a resource to an actor that does not have those privileges." ;
    cwe:id "CWE-271" ;
    cwe:name "Privilege Dropping / Lowering Errors" .

<http://w3id.org/sepses/resource/cwe/CWE-272> a cwe:CWE ;
    cwe:description "The elevated privilege level required to perform operations such as chroot() should be dropped immediately after the operation is performed." ;
    cwe:id "CWE-272" ;
    cwe:name "Least Privilege Violation" .

<http://w3id.org/sepses/resource/cwe/CWE-273> a cwe:CWE ;
    cwe:description "The product attempts to drop privileges but does not check or incorrectly checks to see if the drop succeeded." ;
    cwe:id "CWE-273" ;
    cwe:name "Improper Check for Dropped Privileges" .

<http://w3id.org/sepses/resource/cwe/CWE-274> a cwe:CWE ;
    cwe:description "The product does not handle or incorrectly handles when it has insufficient privileges to perform an operation, leading to resultant weaknesses." ;
    cwe:id "CWE-274" ;
    cwe:name "Improper Handling of Insufficient Privileges" .

<http://w3id.org/sepses/resource/cwe/CWE-276> a cwe:CWE ;
    cwe:description "During installation, installed file permissions are set to allow anyone to modify those files." ;
    cwe:id "CWE-276" ;
    cwe:name "Incorrect Default Permissions" .

<http://w3id.org/sepses/resource/cwe/CWE-277> a cwe:CWE ;
    cwe:description "A product defines a set of insecure permissions that are inherited by objects that are created by the program." ;
    cwe:id "CWE-277" ;
    cwe:name "Insecure Inherited Permissions" .

<http://w3id.org/sepses/resource/cwe/CWE-278> a cwe:CWE ;
    cwe:description "A product inherits a set of insecure permissions for an object, e.g. when copying from an archive file, without user awareness or involvement." ;
    cwe:id "CWE-278" ;
    cwe:name "Insecure Preserved Inherited Permissions" .

<http://w3id.org/sepses/resource/cwe/CWE-279> a cwe:CWE ;
    cwe:description "While it is executing, the product sets the permissions of an object in a way that violates the intended permissions that have been specified by the user." ;
    cwe:id "CWE-279" ;
    cwe:name "Incorrect Execution-Assigned Permissions" .

<http://w3id.org/sepses/resource/cwe/CWE-28> a cwe:CWE ;
    cwe:description "The product uses external input to construct a pathname that should be within a restricted directory, but it does not properly neutralize \"..\\\" sequences that can resolve to a location that is outside of that directory." ;
    cwe:id "CWE-28" ;
    cwe:name "Path Traversal: '..\\filedir'" .

<http://w3id.org/sepses/resource/cwe/CWE-280> a cwe:CWE ;
    cwe:description "The product does not handle or incorrectly handles when it has insufficient privileges to access resources or functionality as specified by their permissions. This may cause it to follow unexpected code paths that may leave the product in an invalid state." ;
    cwe:id "CWE-280" ;
    cwe:name "Improper Handling of Insufficient Permissions or Privileges" .

<http://w3id.org/sepses/resource/cwe/CWE-281> a cwe:CWE ;
    cwe:description "The product does not preserve permissions or incorrectly preserves permissions when copying, restoring, or sharing objects, which can cause them to have less restrictive permissions than intended." ;
    cwe:id "CWE-281" ;
    cwe:name "Improper Preservation of Permissions" .

<http://w3id.org/sepses/resource/cwe/CWE-282> a cwe:CWE ;
    cwe:description "The product assigns the wrong ownership, or does not properly verify the ownership, of an object or resource." ;
    cwe:id "CWE-282" ;
    cwe:name "Improper Ownership Management" .

<http://w3id.org/sepses/resource/cwe/CWE-283> a cwe:CWE ;
    cwe:description "The product does not properly verify that a critical resource is owned by the proper entity." ;
    cwe:id "CWE-283" ;
    cwe:name "Unverified Ownership" .

<http://w3id.org/sepses/resource/cwe/CWE-284> a cwe:CWE ;
    cwe:description "The product does not restrict or incorrectly restricts access to a resource from an unauthorized actor." ;
    cwe:id "CWE-284" ;
    cwe:name "Improper Access Control" .

<http://w3id.org/sepses/resource/cwe/CWE-285> a cwe:CWE ;
    cwe:description "The product does not perform or incorrectly performs an authorization check when an actor attempts to access a resource or perform an action." ;
    cwe:id "CWE-285" ;
    cwe:name "Improper Authorization" .

<http://w3id.org/sepses/resource/cwe/CWE-286> a cwe:CWE ;
    cwe:description "The product does not properly manage a user within its environment." ;
    cwe:id "CWE-286" ;
    cwe:name "Incorrect User Management" .

<http://w3id.org/sepses/resource/cwe/CWE-287> a cwe:CWE ;
    cwe:description "When an actor claims to have a given identity, the product does not prove or insufficiently proves that the claim is correct." ;
    cwe:id "CWE-287" ;
    cwe:name "Improper Authentication" .

<http://w3id.org/sepses/resource/cwe/CWE-288> a cwe:CWE ;
    cwe:description "The product requires authentication, but the product has an alternate path or channel that does not require authentication." ;
    cwe:id "CWE-288" ;
    cwe:name "Authentication Bypass Using an Alternate Path or Channel" .

<http://w3id.org/sepses/resource/cwe/CWE-289> a cwe:CWE ;
    cwe:description "The product performs authentication based on the name of a resource being accessed, or the name of the actor performing the access, but it does not properly check all possible names for that resource or actor." ;
    cwe:id "CWE-289" ;
    cwe:name "Authentication Bypass by Alternate Name" .

<http://w3id.org/sepses/resource/cwe/CWE-29> a cwe:CWE ;
    cwe:description "The product uses external input to construct a pathname that should be within a restricted directory, but it does not properly neutralize '\\..\\filename' (leading backslash dot dot) sequences that can resolve to a location that is outside of that directory." ;
    cwe:id "CWE-29" ;
    cwe:name "Path Traversal: '\\..\\filename'" .

<http://w3id.org/sepses/resource/cwe/CWE-290> a cwe:CWE ;
    cwe:description "This attack-focused weakness is caused by incorrectly implemented authentication schemes that are subject to spoofing attacks." ;
    cwe:id "CWE-290" ;
    cwe:name "Authentication Bypass by Spoofing" .

<http://w3id.org/sepses/resource/cwe/CWE-291> a cwe:CWE ;
    cwe:description "The product uses an IP address for authentication." ;
    cwe:id "CWE-291" ;
    cwe:name "Reliance on IP Address for Authentication" .

<http://w3id.org/sepses/resource/cwe/CWE-292> a cwe:CWE ;
    cwe:description "This entry has been deprecated because it was a duplicate of CWE-350. All content has been transferred to CWE-350." ;
    cwe:id "CWE-292" ;
    cwe:name "DEPRECATED: Trusting Self-reported DNS Name" .

<http://w3id.org/sepses/resource/cwe/CWE-293> a cwe:CWE ;
    cwe:description "The referer field in HTTP requests can be easily modified and, as such, is not a valid means of message integrity checking." ;
    cwe:id "CWE-293" ;
    cwe:name "Using Referer Field for Authentication" .

<http://w3id.org/sepses/resource/cwe/CWE-294> a cwe:CWE ;
    cwe:description "A capture-replay flaw exists when the design of the product makes it possible for a malicious user to sniff network traffic and bypass authentication by replaying it to the server in question to the same effect as the original message (or with minor changes)." ;
    cwe:id "CWE-294" ;
    cwe:name "Authentication Bypass by Capture-replay" .

<http://w3id.org/sepses/resource/cwe/CWE-295> a cwe:CWE ;
    cwe:description "The product does not validate, or incorrectly validates, a certificate." ;
    cwe:id "CWE-295" ;
    cwe:name "Improper Certificate Validation" .

<http://w3id.org/sepses/resource/cwe/CWE-296> a cwe:CWE ;
    cwe:description "The product does not follow, or incorrectly follows, the chain of trust for a certificate back to a trusted root certificate." ;
    cwe:id "CWE-296" ;
    cwe:name "Improper Following of a Certificate's Chain of Trust" .

<http://w3id.org/sepses/resource/cwe/CWE-297> a cwe:CWE ;
    cwe:description "The product communicates with a host that provides a certificate, but the product does not properly ensure that the certificate is actually associated with that host." ;
    cwe:id "CWE-297" ;
    cwe:name "Improper Validation of Certificate with Host Mismatch" .

<http://w3id.org/sepses/resource/cwe/CWE-298> a cwe:CWE ;
    cwe:description "A certificate expiration is not validated or is incorrectly validated." ;
    cwe:id "CWE-298" ;
    cwe:name "Improper Validation of Certificate Expiration" .

<http://w3id.org/sepses/resource/cwe/CWE-299> a cwe:CWE ;
    cwe:description "The product does not check or incorrectly checks the revocation status of a certificate, which may cause it to use a certificate that has been compromised." ;
    cwe:id "CWE-299" ;
    cwe:name "Improper Check for Certificate Revocation" .

<http://w3id.org/sepses/resource/cwe/CWE-30> a cwe:CWE ;
    cwe:description "The product uses external input to construct a pathname that should be within a restricted directory, but it does not properly neutralize '\\dir\\..\\filename' (leading backslash dot dot) sequences that can resolve to a location that is outside of that directory." ;
    cwe:id "CWE-30" ;
    cwe:name "Path Traversal: '\\dir\\..\\filename'" .

<http://w3id.org/sepses/resource/cwe/CWE-300> a cwe:CWE ;
    cwe:description "The product does not adequately verify the identity of actors at both ends of a communication channel, or does not adequately ensure the integrity of the channel, in a way that allows the channel to be accessed or influenced by an actor that is not an endpoint." ;
    cwe:id "CWE-300" ;
    cwe:name "Channel Accessible by Non-Endpoint" .

<http://w3id.org/sepses/resource/cwe/CWE-301> a cwe:CWE ;
    cwe:description "Simple authentication protocols are subject to reflection attacks if a malicious user can use the target machine to impersonate a trusted user." ;
    cwe:id "CWE-301" ;
    cwe:name "Reflection Attack in an Authentication Protocol" .

<http://w3id.org/sepses/resource/cwe/CWE-302> a cwe:CWE ;
    cwe:description "The authentication scheme or implementation uses key data elements that are assumed to be immutable, but can be controlled or modified by the attacker." ;
    cwe:id "CWE-302" ;
    cwe:name "Authentication Bypass by Assumed-Immutable Data" .

<http://w3id.org/sepses/resource/cwe/CWE-303> a cwe:CWE ;
    cwe:description "The requirements for the product dictate the use of an established authentication algorithm, but the implementation of the algorithm is incorrect." ;
    cwe:id "CWE-303" ;
    cwe:name "Incorrect Implementation of Authentication Algorithm" .

<http://w3id.org/sepses/resource/cwe/CWE-304> a cwe:CWE ;
    cwe:description "The product implements an authentication technique, but it skips a step that weakens the technique." ;
    cwe:id "CWE-304" ;
    cwe:name "Missing Critical Step in Authentication" .

<http://w3id.org/sepses/resource/cwe/CWE-305> a cwe:CWE ;
    cwe:description "The authentication algorithm is sound, but the implemented mechanism can be bypassed as the result of a separate weakness that is primary to the authentication error." ;
    cwe:id "CWE-305" ;
    cwe:name "Authentication Bypass by Primary Weakness" .

<http://w3id.org/sepses/resource/cwe/CWE-306> a cwe:CWE ;
    cwe:description "The product does not perform any authentication for functionality that requires a provable user identity or consumes a significant amount of resources." ;
    cwe:id "CWE-306" ;
    cwe:name "Missing Authentication for Critical Function" .

<http://w3id.org/sepses/resource/cwe/CWE-307> a cwe:CWE ;
    cwe:description "The product does not implement sufficient measures to prevent multiple failed authentication attempts within a short time frame." ;
    cwe:id "CWE-307" ;
    cwe:name "Improper Restriction of Excessive Authentication Attempts" .

<http://w3id.org/sepses/resource/cwe/CWE-308> a cwe:CWE ;
    cwe:description "The product uses an authentication algorithm that uses a single factor (e.g., a password) in a security context that should require more than one factor." ;
    cwe:id "CWE-308" ;
    cwe:name "Use of Single-factor Authentication" .

<http://w3id.org/sepses/resource/cwe/CWE-309> a cwe:CWE ;
    cwe:description "The use of password systems as the primary means of authentication may be subject to several flaws or shortcomings, each reducing the effectiveness of the mechanism." ;
    cwe:id "CWE-309" ;
    cwe:name "Use of Password System for Primary Authentication" .

<http://w3id.org/sepses/resource/cwe/CWE-31> a cwe:CWE ;
    cwe:description "The product uses external input to construct a pathname that should be within a restricted directory, but it does not properly neutralize 'dir\\..\\..\\filename' (multiple internal backslash dot dot) sequences that can resolve to a location that is outside of that directory." ;
    cwe:id "CWE-31" ;
    cwe:name "Path Traversal: 'dir\\..\\..\\filename'" .

<http://w3id.org/sepses/resource/cwe/CWE-311> a cwe:CWE ;
    cwe:description "The product does not encrypt sensitive or critical information before storage or transmission." ;
    cwe:id "CWE-311" ;
    cwe:name "Missing Encryption of Sensitive Data" .

<http://w3id.org/sepses/resource/cwe/CWE-312> a cwe:CWE ;
    cwe:description "The product stores sensitive information in cleartext within a resource that might be accessible to another control sphere." ;
    cwe:id "CWE-312" ;
    cwe:name "Cleartext Storage of Sensitive Information" .

<http://w3id.org/sepses/resource/cwe/CWE-313> a cwe:CWE ;
    cwe:description "The product stores sensitive information in cleartext in a file, or on disk." ;
    cwe:id "CWE-313" ;
    cwe:name "Cleartext Storage in a File or on Disk" .

<http://w3id.org/sepses/resource/cwe/CWE-314> a cwe:CWE ;
    cwe:description "The product stores sensitive information in cleartext in the registry." ;
    cwe:id "CWE-314" ;
    cwe:name "Cleartext Storage in the Registry" .

<http://w3id.org/sepses/resource/cwe/CWE-315> a cwe:CWE ;
    cwe:description "The product stores sensitive information in cleartext in a cookie." ;
    cwe:id "CWE-315" ;
    cwe:name "Cleartext Storage of Sensitive Information in a Cookie" .

<http://w3id.org/sepses/resource/cwe/CWE-316> a cwe:CWE ;
    cwe:description "The product stores sensitive information in cleartext in memory." ;
    cwe:id "CWE-316" ;
    cwe:name "Cleartext Storage of Sensitive Information in Memory" .

<http://w3id.org/sepses/resource/cwe/CWE-317> a cwe:CWE ;
    cwe:description "The product stores sensitive information in cleartext within the GUI." ;
    cwe:id "CWE-317" ;
    cwe:name "Cleartext Storage of Sensitive Information in GUI" .

<http://w3id.org/sepses/resource/cwe/CWE-318> a cwe:CWE ;
    cwe:description "The product stores sensitive information in cleartext in an executable." ;
    cwe:id "CWE-318" ;
    cwe:name "Cleartext Storage of Sensitive Information in Executable" .

<http://w3id.org/sepses/resource/cwe/CWE-319> a cwe:CWE ;
    cwe:description "The product transmits sensitive or security-critical data in cleartext in a communication channel that can be sniffed by unauthorized actors." ;
    cwe:id "CWE-319" ;
    cwe:name "Cleartext Transmission of Sensitive Information" .

<http://w3id.org/sepses/resource/cwe/CWE-32> a cwe:CWE ;
    cwe:description "The product uses external input to construct a pathname that should be within a restricted directory, but it does not properly neutralize '...' (triple dot) sequences that can resolve to a location that is outside of that directory." ;
    cwe:id "CWE-32" ;
    cwe:name "Path Traversal: '...' (Triple Dot)" .

<http://w3id.org/sepses/resource/cwe/CWE-321> a cwe:CWE ;
    cwe:description "The product uses a hard-coded, unchangeable cryptographic key." ;
    cwe:id "CWE-321" ;
    cwe:name "Use of Hard-coded Cryptographic Key" .

<http://w3id.org/sepses/resource/cwe/CWE-322> a cwe:CWE ;
    cwe:description "The product performs a key exchange with an actor without verifying the identity of that actor." ;
    cwe:id "CWE-322" ;
    cwe:name "Key Exchange without Entity Authentication" .

<http://w3id.org/sepses/resource/cwe/CWE-323> a cwe:CWE ;
    cwe:description "Nonces should be used for the present occasion and only once." ;
    cwe:id "CWE-323" ;
    cwe:name "Reusing a Nonce, Key Pair in Encryption" .

<http://w3id.org/sepses/resource/cwe/CWE-324> a cwe:CWE ;
    cwe:description "The product uses a cryptographic key or password past its expiration date, which diminishes its safety significantly by increasing the timing window for cracking attacks against that key." ;
    cwe:id "CWE-324" ;
    cwe:name "Use of a Key Past its Expiration Date" .

<http://w3id.org/sepses/resource/cwe/CWE-325> a cwe:CWE ;
    cwe:description "The product does not implement a required step in a cryptographic algorithm, resulting in weaker encryption than advertised by the algorithm." ;
    cwe:id "CWE-325" ;
    cwe:name "Missing Cryptographic Step" .

<http://w3id.org/sepses/resource/cwe/CWE-326> a cwe:CWE ;
    cwe:description "The product stores or transmits sensitive data using an encryption scheme that is theoretically sound, but is not strong enough for the level of protection required." ;
    cwe:id "CWE-326" ;
    cwe:name "Inadequate Encryption Strength" .

<http://w3id.org/sepses/resource/cwe/CWE-327> a cwe:CWE ;
    cwe:description "The product uses a broken or risky cryptographic algorithm or protocol." ;
    cwe:id "CWE-327" ;
    cwe:name "Use of a Broken or Risky Cryptographic Algorithm" .

<http://w3id.org/sepses/resource/cwe/CWE-328> a cwe:CWE ;
    cwe:description "The product uses an algorithm that produces a digest (output value) that does not meet security expectations for a hash function that allows an adversary to reasonably determine the original input (preimage attack), find another input that can produce the same hash (2nd preimage attack), or find multiple inputs that evaluate to the same hash (birthday attack)." ;
    cwe:id "CWE-328" ;
    cwe:name "Use of Weak Hash" .

<http://w3id.org/sepses/resource/cwe/CWE-329> a cwe:CWE ;
    cwe:description "The product generates and uses a predictable initialization Vector (IV) with Cipher Block Chaining (CBC) Mode, which causes algorithms to be susceptible to dictionary attacks when they are encrypted under the same key." ;
    cwe:id "CWE-329" ;
    cwe:name "Generation of Predictable IV with CBC Mode" .

<http://w3id.org/sepses/resource/cwe/CWE-33> a cwe:CWE ;
    cwe:description "The product uses external input to construct a pathname that should be within a restricted directory, but it does not properly neutralize '....' (multiple dot) sequences that can resolve to a location that is outside of that directory." ;
    cwe:id "CWE-33" ;
    cwe:name "Path Traversal: '....' (Multiple Dot)" .

<http://w3id.org/sepses/resource/cwe/CWE-330> a cwe:CWE ;
    cwe:description "The product uses insufficiently random numbers or values in a security context that depends on unpredictable numbers." ;
    cwe:id "CWE-330" ;
    cwe:name "Use of Insufficiently Random Values" .

<http://w3id.org/sepses/resource/cwe/CWE-331> a cwe:CWE ;
    cwe:description "The product uses an algorithm or scheme that produces insufficient entropy, leaving patterns or clusters of values that are more likely to occur than others." ;
    cwe:id "CWE-331" ;
    cwe:name "Insufficient Entropy" .

<http://w3id.org/sepses/resource/cwe/CWE-332> a cwe:CWE ;
    cwe:description "The lack of entropy available for, or used by, a Pseudo-Random Number Generator (PRNG) can be a stability and security threat." ;
    cwe:id "CWE-332" ;
    cwe:name "Insufficient Entropy in PRNG" .

<http://w3id.org/sepses/resource/cwe/CWE-333> a cwe:CWE ;
    cwe:description "True random number generators (TRNG) generally have a limited source of entropy and therefore can fail or block." ;
    cwe:id "CWE-333" ;
    cwe:name "Improper Handling of Insufficient Entropy in TRNG" .

<http://w3id.org/sepses/resource/cwe/CWE-334> a cwe:CWE ;
    cwe:description "The number of possible random values is smaller than needed by the product, making it more susceptible to brute force attacks." ;
    cwe:id "CWE-334" ;
    cwe:name "Small Space of Random Values" .

<http://w3id.org/sepses/resource/cwe/CWE-335> a cwe:CWE ;
    cwe:description "The product uses a Pseudo-Random Number Generator (PRNG) but does not correctly manage seeds." ;
    cwe:id "CWE-335" ;
    cwe:name "Incorrect Usage of Seeds in Pseudo-Random Number Generator (PRNG)" .

<http://w3id.org/sepses/resource/cwe/CWE-336> a cwe:CWE ;
    cwe:description "A Pseudo-Random Number Generator (PRNG) uses the same seed each time the product is initialized." ;
    cwe:id "CWE-336" ;
    cwe:name "Same Seed in Pseudo-Random Number Generator (PRNG)" .

<http://w3id.org/sepses/resource/cwe/CWE-337> a cwe:CWE ;
    cwe:description "A Pseudo-Random Number Generator (PRNG) is initialized from a predictable seed, such as the process ID or system time." ;
    cwe:id "CWE-337" ;
    cwe:name "Predictable Seed in Pseudo-Random Number Generator (PRNG)" .

<http://w3id.org/sepses/resource/cwe/CWE-338> a cwe:CWE ;
    cwe:description "The product uses a Pseudo-Random Number Generator (PRNG) in a security context, but the PRNG's algorithm is not cryptographically strong." ;
    cwe:id "CWE-338" ;
    cwe:name "Use of Cryptographically Weak Pseudo-Random Number Generator (PRNG)" .

<http://w3id.org/sepses/resource/cwe/CWE-339> a cwe:CWE ;
    cwe:description "A Pseudo-Random Number Generator (PRNG) uses a relatively small seed space, which makes it more susceptible to brute force attacks." ;
    cwe:id "CWE-339" ;
    cwe:name "Small Seed Space in PRNG" .

<http://w3id.org/sepses/resource/cwe/CWE-34> a cwe:CWE ;
    cwe:description "The product uses external input to construct a pathname that should be within a restricted directory, but it does not properly neutralize '....//' (doubled dot dot slash) sequences that can resolve to a location that is outside of that directory." ;
    cwe:id "CWE-34" ;
    cwe:name "Path Traversal: '....//'" .

<http://w3id.org/sepses/resource/cwe/CWE-340> a cwe:CWE ;
    cwe:description "The product uses a scheme that generates numbers or identifiers that are more predictable than required." ;
    cwe:id "CWE-340" ;
    cwe:name "Generation of Predictable Numbers or Identifiers" .

<http://w3id.org/sepses/resource/cwe/CWE-341> a cwe:CWE ;
    cwe:description "A number or object is predictable based on observations that the attacker can make about the state of the system or network, such as time, process ID, etc." ;
    cwe:id "CWE-341" ;
    cwe:name "Predictable from Observable State" .

<http://w3id.org/sepses/resource/cwe/CWE-342> a cwe:CWE ;
    cwe:description "An exact value or random number can be precisely predicted by observing previous values." ;
    cwe:id "CWE-342" ;
    cwe:name "Predictable Exact Value from Previous Values" .

<http://w3id.org/sepses/resource/cwe/CWE-343> a cwe:CWE ;
    cwe:description "The product's random number generator produces a series of values which, when observed, can be used to infer a relatively small range of possibilities for the next value that could be generated." ;
    cwe:id "CWE-343" ;
    cwe:name "Predictable Value Range from Previous Values" .

<http://w3id.org/sepses/resource/cwe/CWE-344> a cwe:CWE ;
    cwe:description "The product uses a constant value, name, or reference, but this value can (or should) vary across different environments." ;
    cwe:id "CWE-344" ;
    cwe:name "Use of Invariant Value in Dynamically Changing Context" .

<http://w3id.org/sepses/resource/cwe/CWE-345> a cwe:CWE ;
    cwe:description "The product does not sufficiently verify the origin or authenticity of data, in a way that causes it to accept invalid data." ;
    cwe:id "CWE-345" ;
    cwe:name "Insufficient Verification of Data Authenticity" .

<http://w3id.org/sepses/resource/cwe/CWE-346> a cwe:CWE ;
    cwe:description "The product does not properly verify that the source of data or communication is valid." ;
    cwe:id "CWE-346" ;
    cwe:name "Origin Validation Error" .

<http://w3id.org/sepses/resource/cwe/CWE-347> a cwe:CWE ;
    cwe:description "The product does not verify, or incorrectly verifies, the cryptographic signature for data." ;
    cwe:id "CWE-347" ;
    cwe:name "Improper Verification of Cryptographic Signature" .

<http://w3id.org/sepses/resource/cwe/CWE-348> a cwe:CWE ;
    cwe:description "The product has two different sources of the same data or information, but it uses the source that has less support for verification, is less trusted, or is less resistant to attack." ;
    cwe:id "CWE-348" ;
    cwe:name "Use of Less Trusted Source" .

<http://w3id.org/sepses/resource/cwe/CWE-349> a cwe:CWE ;
    cwe:description "The product, when processing trusted data, accepts any untrusted data that is also included with the trusted data, treating the untrusted data as if it were trusted." ;
    cwe:id "CWE-349" ;
    cwe:name "Acceptance of Extraneous Untrusted Data With Trusted Data" .

<http://w3id.org/sepses/resource/cwe/CWE-35> a cwe:CWE ;
    cwe:description "The product uses external input to construct a pathname that should be within a restricted directory, but it does not properly neutralize '.../...//' (doubled triple dot slash) sequences that can resolve to a location that is outside of that directory." ;
    cwe:id "CWE-35" ;
    cwe:name "Path Traversal: '.../...//'" .

<http://w3id.org/sepses/resource/cwe/CWE-350> a cwe:CWE ;
    cwe:description "The product performs reverse DNS resolution on an IP address to obtain the hostname and make a security decision, but it does not properly ensure that the IP address is truly associated with the hostname." ;
    cwe:id "CWE-350" ;
    cwe:name "Reliance on Reverse DNS Resolution for a Security-Critical Action" .

<http://w3id.org/sepses/resource/cwe/CWE-351> a cwe:CWE ;
    cwe:description "The product does not properly distinguish between different types of elements in a way that leads to insecure behavior." ;
    cwe:id "CWE-351" ;
    cwe:name "Insufficient Type Distinction" .

<http://w3id.org/sepses/resource/cwe/CWE-352> a cwe:CWE ;
    cwe:description "The web application does not, or cannot, sufficiently verify whether a request was intentionally provided by the user who sent the request, which could have originated from an unauthorized actor. " ;
    cwe:id "CWE-352" ;
    cwe:name "Cross-Site Request Forgery (CSRF)" .

<http://w3id.org/sepses/resource/cwe/CWE-353> a cwe:CWE ;
    cwe:description "The product uses a transmission protocol that does not include a mechanism for verifying the integrity of the data during transmission, such as a checksum." ;
    cwe:id "CWE-353" ;
    cwe:name "Missing Support for Integrity Check" .

<http://w3id.org/sepses/resource/cwe/CWE-354> a cwe:CWE ;
    cwe:description "The product does not validate or incorrectly validates the integrity check values or \"checksums\" of a message. This may prevent it from detecting if the data has been modified or corrupted in transmission." ;
    cwe:id "CWE-354" ;
    cwe:name "Improper Validation of Integrity Check Value" .

<http://w3id.org/sepses/resource/cwe/CWE-356> a cwe:CWE ;
    cwe:description "The product's user interface does not warn the user before undertaking an unsafe action on behalf of that user. This makes it easier for attackers to trick users into inflicting damage to their system." ;
    cwe:id "CWE-356" ;
    cwe:name "Product UI does not Warn User of Unsafe Actions" .

<http://w3id.org/sepses/resource/cwe/CWE-357> a cwe:CWE ;
    cwe:description "The user interface provides a warning to a user regarding dangerous or sensitive operations, but the warning is not noticeable enough to warrant attention." ;
    cwe:id "CWE-357" ;
    cwe:name "Insufficient UI Warning of Dangerous Operations" .

<http://w3id.org/sepses/resource/cwe/CWE-358> a cwe:CWE ;
    cwe:description "The product does not implement or incorrectly implements one or more security-relevant checks as specified by the design of a standardized algorithm, protocol, or technique." ;
    cwe:id "CWE-358" ;
    cwe:name "Improperly Implemented Security Check for Standard" .

<http://w3id.org/sepses/resource/cwe/CWE-359> a cwe:CWE ;
    cwe:description "The product does not properly prevent a person's private, personal information from being accessed by actors who either (1) are not explicitly authorized to access the information or (2) do not have the implicit consent of the person about whom the information is collected." ;
    cwe:id "CWE-359" ;
    cwe:name "Exposure of Private Personal Information to an Unauthorized Actor" .

<http://w3id.org/sepses/resource/cwe/CWE-36> a cwe:CWE ;
    cwe:description "The product uses external input to construct a pathname that should be within a restricted directory, but it does not properly neutralize absolute path sequences such as \"/abs/path\" that can resolve to a location that is outside of that directory." ;
    cwe:id "CWE-36" ;
    cwe:name "Absolute Path Traversal" .

<http://w3id.org/sepses/resource/cwe/CWE-360> a cwe:CWE ;
    cwe:description "Security based on event locations are insecure and can be spoofed." ;
    cwe:id "CWE-360" ;
    cwe:name "Trust of System Event Data" .

<http://w3id.org/sepses/resource/cwe/CWE-362> a cwe:CWE ;
    cwe:description "The product contains a concurrent code sequence that requires temporary, exclusive access to a shared resource, but a timing window exists in which the shared resource can be modified by another code sequence operating concurrently." ;
    cwe:id "CWE-362" ;
    cwe:name "Concurrent Execution using Shared Resource with Improper Synchronization ('Race Condition')" .

<http://w3id.org/sepses/resource/cwe/CWE-363> a cwe:CWE ;
    cwe:description "The product checks the status of a file or directory before accessing it, which produces a race condition in which the file can be replaced with a link before the access is performed, causing the product to access the wrong file." ;
    cwe:id "CWE-363" ;
    cwe:name "Race Condition Enabling Link Following" .

<http://w3id.org/sepses/resource/cwe/CWE-364> a cwe:CWE ;
    cwe:description "The product uses a signal handler that introduces a race condition." ;
    cwe:id "CWE-364" ;
    cwe:name "Signal Handler Race Condition" .

<http://w3id.org/sepses/resource/cwe/CWE-365> a cwe:CWE ;
    cwe:description "This entry has been deprecated. There are no documented cases in which a switch's control expression is evaluated more than once." ;
    cwe:id "CWE-365" ;
    cwe:name "DEPRECATED: Race Condition in Switch" .

<http://w3id.org/sepses/resource/cwe/CWE-366> a cwe:CWE ;
    cwe:description "If two threads of execution use a resource simultaneously, there exists the possibility that resources may be used while invalid, in turn making the state of execution undefined." ;
    cwe:id "CWE-366" ;
    cwe:name "Race Condition within a Thread" .

<http://w3id.org/sepses/resource/cwe/CWE-367> a cwe:CWE ;
    cwe:description "The product checks the state of a resource before using that resource, but the resource's state can change between the check and the use in a way that invalidates the results of the check." ;
    cwe:id "CWE-367" ;
    cwe:name "Time-of-check Time-of-use (TOCTOU) Race Condition" .

<http://w3id.org/sepses/resource/cwe/CWE-368> a cwe:CWE ;
    cwe:description "A product performs a series of non-atomic actions to switch between contexts that cross privilege or other security boundaries, but a race condition allows an attacker to modify or misrepresent the product's behavior during the switch." ;
    cwe:id "CWE-368" ;
    cwe:name "Context Switching Race Condition" .

<http://w3id.org/sepses/resource/cwe/CWE-369> a cwe:CWE ;
    cwe:description "The product divides a value by zero." ;
    cwe:id "CWE-369" ;
    cwe:name "Divide By Zero" .

<http://w3id.org/sepses/resource/cwe/CWE-37> a cwe:CWE ;
    cwe:description "The product accepts input in the form of a slash absolute path ('/absolute/pathname/here') without appropriate validation, which can allow an attacker to traverse the file system to unintended locations or access arbitrary files." ;
    cwe:id "CWE-37" ;
    cwe:name "Path Traversal: '/absolute/pathname/here'" .

<http://w3id.org/sepses/resource/cwe/CWE-370> a cwe:CWE ;
    cwe:description "The product does not check the revocation status of a certificate after its initial revocation check, which can cause the product to perform privileged actions even after the certificate is revoked at a later time." ;
    cwe:id "CWE-370" ;
    cwe:name "Missing Check for Certificate Revocation after Initial Check" .

<http://w3id.org/sepses/resource/cwe/CWE-372> a cwe:CWE ;
    cwe:description "The product does not properly determine which state it is in, causing it to assume it is in state X when in fact it is in state Y, causing it to perform incorrect operations in a security-relevant manner." ;
    cwe:id "CWE-372" ;
    cwe:name "Incomplete Internal State Distinction" .

<http://w3id.org/sepses/resource/cwe/CWE-373> a cwe:CWE ;
    cwe:description "This entry was deprecated because it overlapped the same concepts as race condition (CWE-362) and Improper Synchronization (CWE-662)." ;
    cwe:id "CWE-373" ;
    cwe:name "DEPRECATED: State Synchronization Error" .

<http://w3id.org/sepses/resource/cwe/CWE-374> a cwe:CWE ;
    cwe:description "The product sends non-cloned mutable data as an argument to a method or function." ;
    cwe:id "CWE-374" ;
    cwe:name "Passing Mutable Objects to an Untrusted Method" .

<http://w3id.org/sepses/resource/cwe/CWE-375> a cwe:CWE ;
    cwe:description "Sending non-cloned mutable data as a return value may result in that data being altered or deleted by the calling function." ;
    cwe:id "CWE-375" ;
    cwe:name "Returning a Mutable Object to an Untrusted Caller" .

<http://w3id.org/sepses/resource/cwe/CWE-377> a cwe:CWE ;
    cwe:description "Creating and using insecure temporary files can leave application and system data vulnerable to attack." ;
    cwe:id "CWE-377" ;
    cwe:name "Insecure Temporary File" .

<http://w3id.org/sepses/resource/cwe/CWE-378> a cwe:CWE ;
    cwe:description "Opening temporary files without appropriate measures or controls can leave the file, its contents and any function that it impacts vulnerable to attack." ;
    cwe:id "CWE-378" ;
    cwe:name "Creation of Temporary File With Insecure Permissions" .

<http://w3id.org/sepses/resource/cwe/CWE-379> a cwe:CWE ;
    cwe:description "The product creates a temporary file in a directory whose permissions allow unintended actors to determine the file's existence or otherwise access that file." ;
    cwe:id "CWE-379" ;
    cwe:name "Creation of Temporary File in Directory with Insecure Permissions" .

<http://w3id.org/sepses/resource/cwe/CWE-38> a cwe:CWE ;
    cwe:description "The product accepts input in the form of a backslash absolute path ('\\absolute\\pathname\\here') without appropriate validation, which can allow an attacker to traverse the file system to unintended locations or access arbitrary files." ;
    cwe:id "CWE-38" ;
    cwe:name "Path Traversal: '\\absolute\\pathname\\here'" .

<http://w3id.org/sepses/resource/cwe/CWE-382> a cwe:CWE ;
    cwe:description "A J2EE application uses System.exit(), which also shuts down its container." ;
    cwe:id "CWE-382" ;
    cwe:name "J2EE Bad Practices: Use of System.exit()" .

<http://w3id.org/sepses/resource/cwe/CWE-383> a cwe:CWE ;
    cwe:description "Thread management in a Web application is forbidden in some circumstances and is always highly error prone." ;
    cwe:id "CWE-383" ;
    cwe:name "J2EE Bad Practices: Direct Use of Threads" .

<http://w3id.org/sepses/resource/cwe/CWE-384> a cwe:CWE ;
    cwe:description "Authenticating a user, or otherwise establishing a new user session, without invalidating any existing session identifier gives an attacker the opportunity to steal authenticated sessions." ;
    cwe:id "CWE-384" ;
    cwe:name "Session Fixation" .

<http://w3id.org/sepses/resource/cwe/CWE-385> a cwe:CWE ;
    cwe:description "Covert timing channels convey information by modulating some aspect of system behavior over time, so that the program receiving the information can observe system behavior and infer protected information." ;
    cwe:id "CWE-385" ;
    cwe:name "Covert Timing Channel" .

<http://w3id.org/sepses/resource/cwe/CWE-386> a cwe:CWE ;
    cwe:description "A constant symbolic reference to an object is used, even though the reference can resolve to a different object over time." ;
    cwe:id "CWE-386" ;
    cwe:name "Symbolic Name not Mapping to Correct Object" .

<http://w3id.org/sepses/resource/cwe/CWE-39> a cwe:CWE ;
    cwe:description "The product accepts input that contains a drive letter or Windows volume letter ('C:dirname') that potentially redirects access to an unintended location or arbitrary file." ;
    cwe:id "CWE-39" ;
    cwe:name "Path Traversal: 'C:dirname'" .

<http://w3id.org/sepses/resource/cwe/CWE-390> a cwe:CWE ;
    cwe:description "The product detects a specific error, but takes no actions to handle the error." ;
    cwe:id "CWE-390" ;
    cwe:name "Detection of Error Condition Without Action" .

<http://w3id.org/sepses/resource/cwe/CWE-391> a cwe:CWE ;
    cwe:description "[PLANNED FOR DEPRECATION. SEE MAINTENANCE NOTES AND CONSIDER CWE-252, CWE-248, OR CWE-1069.] Ignoring exceptions and other error conditions may allow an attacker to induce unexpected behavior unnoticed." ;
    cwe:id "CWE-391" ;
    cwe:name "Unchecked Error Condition" .

<http://w3id.org/sepses/resource/cwe/CWE-392> a cwe:CWE ;
    cwe:description "The product encounters an error but does not provide a status code or return value to indicate that an error has occurred." ;
    cwe:id "CWE-392" ;
    cwe:name "Missing Report of Error Condition" .

<http://w3id.org/sepses/resource/cwe/CWE-393> a cwe:CWE ;
    cwe:description "A function or operation returns an incorrect return value or status code that does not indicate the true result of execution, causing the product to modify its behavior based on the incorrect result." ;
    cwe:id "CWE-393" ;
    cwe:name "Return of Wrong Status Code" .

<http://w3id.org/sepses/resource/cwe/CWE-394> a cwe:CWE ;
    cwe:description "The product does not properly check when a function or operation returns a value that is legitimate for the function, but is not expected by the product." ;
    cwe:id "CWE-394" ;
    cwe:name "Unexpected Status Code or Return Value" .

<http://w3id.org/sepses/resource/cwe/CWE-395> a cwe:CWE ;
    cwe:description "Catching NullPointerException should not be used as an alternative to programmatic checks to prevent dereferencing a null pointer." ;
    cwe:id "CWE-395" ;
    cwe:name "Use of NullPointerException Catch to Detect NULL Pointer Dereference" .

<http://w3id.org/sepses/resource/cwe/CWE-396> a cwe:CWE ;
    cwe:description "Catching overly broad exceptions promotes complex error handling code that is more likely to contain security vulnerabilities." ;
    cwe:id "CWE-396" ;
    cwe:name "Declaration of Catch for Generic Exception" .

<http://w3id.org/sepses/resource/cwe/CWE-397> a cwe:CWE ;
    cwe:description "The product throws or raises an overly broad exceptions that can hide important details and produce inappropriate responses to certain conditions." ;
    cwe:id "CWE-397" ;
    cwe:name "Declaration of Throws for Generic Exception" .

<http://w3id.org/sepses/resource/cwe/CWE-40> a cwe:CWE ;
    cwe:description "The product accepts input that identifies a Windows UNC share ('\\\\UNC\\share\\name') that potentially redirects access to an unintended location or arbitrary file." ;
    cwe:id "CWE-40" ;
    cwe:name "Path Traversal: '\\\\UNC\\share\\name\\' (Windows UNC Share)" .

<http://w3id.org/sepses/resource/cwe/CWE-400> a cwe:CWE ;
    cwe:description "The product does not properly control the allocation and maintenance of a limited resource." ;
    cwe:id "CWE-400" ;
    cwe:name "Uncontrolled Resource Consumption" .

<http://w3id.org/sepses/resource/cwe/CWE-401> a cwe:CWE ;
    cwe:description "The product does not sufficiently track and release allocated memory after it has been used, making the memory unavailable for reallocation and reuse." ;
    cwe:id "CWE-401" ;
    cwe:name "Missing Release of Memory after Effective Lifetime" .

<http://w3id.org/sepses/resource/cwe/CWE-402> a cwe:CWE ;
    cwe:description "The product makes resources available to untrusted parties when those resources are only intended to be accessed by the product." ;
    cwe:id "CWE-402" ;
    cwe:name "Transmission of Private Resources into a New Sphere ('Resource Leak')" .

<http://w3id.org/sepses/resource/cwe/CWE-403> a cwe:CWE ;
    cwe:description "A process does not close sensitive file descriptors before invoking a child process, which allows the child to perform unauthorized I/O operations using those descriptors." ;
    cwe:id "CWE-403" ;
    cwe:name "Exposure of File Descriptor to Unintended Control Sphere ('File Descriptor Leak')" .

<http://w3id.org/sepses/resource/cwe/CWE-404> a cwe:CWE ;
    cwe:description "The product does not release or incorrectly releases a resource before it is made available for re-use." ;
    cwe:id "CWE-404" ;
    cwe:name "Improper Resource Shutdown or Release" .

<http://w3id.org/sepses/resource/cwe/CWE-405> a cwe:CWE ;
    cwe:description "The product does not properly control situations in which an adversary can cause the product to consume or produce excessive resources without requiring the adversary to invest equivalent work or otherwise prove authorization, i.e., the adversary's influence is \"asymmetric.\"" ;
    cwe:id "CWE-405" ;
    cwe:name "Asymmetric Resource Consumption (Amplification)" .

<http://w3id.org/sepses/resource/cwe/CWE-406> a cwe:CWE ;
    cwe:description "The product does not sufficiently monitor or control transmitted network traffic volume, so that an actor can cause the product to transmit more traffic than should be allowed for that actor." ;
    cwe:id "CWE-406" ;
    cwe:name "Insufficient Control of Network Message Volume (Network Amplification)" .

<http://w3id.org/sepses/resource/cwe/CWE-407> a cwe:CWE ;
    cwe:description "An algorithm in a product has an inefficient worst-case computational complexity that may be detrimental to system performance and can be triggered by an attacker, typically using crafted manipulations that ensure that the worst case is being reached." ;
    cwe:id "CWE-407" ;
    cwe:name "Inefficient Algorithmic Complexity" .

<http://w3id.org/sepses/resource/cwe/CWE-408> a cwe:CWE ;
    cwe:description "The product allows an entity to perform a legitimate but expensive operation before authentication or authorization has taken place." ;
    cwe:id "CWE-408" ;
    cwe:name "Incorrect Behavior Order: Early Amplification" .

<http://w3id.org/sepses/resource/cwe/CWE-409> a cwe:CWE ;
    cwe:description "The product does not handle or incorrectly handles a compressed input with a very high compression ratio that produces a large output." ;
    cwe:id "CWE-409" ;
    cwe:name "Improper Handling of Highly Compressed Data (Data Amplification)" .

<http://w3id.org/sepses/resource/cwe/CWE-41> a cwe:CWE ;
    cwe:description "The product is vulnerable to file system contents disclosure through path equivalence. Path equivalence involves the use of special characters in file and directory names. The associated manipulations are intended to generate multiple names for the same object." ;
    cwe:id "CWE-41" ;
    cwe:name "Improper Resolution of Path Equivalence" .

<http://w3id.org/sepses/resource/cwe/CWE-410> a cwe:CWE ;
    cwe:description "The product's resource pool is not large enough to handle peak demand, which allows an attacker to prevent others from accessing the resource by using a (relatively) large number of requests for resources." ;
    cwe:id "CWE-410" ;
    cwe:name "Insufficient Resource Pool" .

<http://w3id.org/sepses/resource/cwe/CWE-412> a cwe:CWE ;
    cwe:description "The product properly checks for the existence of a lock, but the lock can be externally controlled or influenced by an actor that is outside of the intended sphere of control." ;
    cwe:id "CWE-412" ;
    cwe:name "Unrestricted Externally Accessible Lock" .

<http://w3id.org/sepses/resource/cwe/CWE-413> a cwe:CWE ;
    cwe:description "The product does not lock or does not correctly lock a resource when the product must have exclusive access to the resource." ;
    cwe:id "CWE-413" ;
    cwe:name "Improper Resource Locking" .

<http://w3id.org/sepses/resource/cwe/CWE-414> a cwe:CWE ;
    cwe:description "A product does not check to see if a lock is present before performing sensitive operations on a resource." ;
    cwe:id "CWE-414" ;
    cwe:name "Missing Lock Check" .

<http://w3id.org/sepses/resource/cwe/CWE-415> a cwe:CWE ;
    cwe:description "The product calls free() twice on the same memory address." ;
    cwe:id "CWE-415" ;
    cwe:name "Double Free" .

<http://w3id.org/sepses/resource/cwe/CWE-416> a cwe:CWE ;
    cwe:description "The product reuses or references memory after it has been freed. At some point afterward, the memory may be allocated again and saved in another pointer, while the original pointer references a location somewhere within the new allocation. Any operations using the original pointer are no longer valid because the memory \"belongs\" to the code that operates on the new pointer." ;
    cwe:id "CWE-416" ;
    cwe:name "Use After Free" .

<http://w3id.org/sepses/resource/cwe/CWE-419> a cwe:CWE ;
    cwe:description "The product uses a primary channel for administration or restricted functionality, but it does not properly protect the channel." ;
    cwe:id "CWE-419" ;
    cwe:name "Unprotected Primary Channel" .

<http://w3id.org/sepses/resource/cwe/CWE-42> a cwe:CWE ;
    cwe:description "The product accepts path input in the form of trailing dot ('filedir.') without appropriate validation, which can lead to ambiguous path resolution and allow an attacker to traverse the file system to unintended locations or access arbitrary files." ;
    cwe:id "CWE-42" ;
    cwe:name "Path Equivalence: 'filename.' (Trailing Dot)" .

<http://w3id.org/sepses/resource/cwe/CWE-420> a cwe:CWE ;
    cwe:description "The product protects a primary channel, but it does not use the same level of protection for an alternate channel." ;
    cwe:id "CWE-420" ;
    cwe:name "Unprotected Alternate Channel" .

<http://w3id.org/sepses/resource/cwe/CWE-421> a cwe:CWE ;
    cwe:description "The product opens an alternate channel to communicate with an authorized user, but the channel is accessible to other actors." ;
    cwe:id "CWE-421" ;
    cwe:name "Race Condition During Access to Alternate Channel" .

<http://w3id.org/sepses/resource/cwe/CWE-422> a cwe:CWE ;
    cwe:description "The product does not properly verify the source of a message in the Windows Messaging System while running at elevated privileges, creating an alternate channel through which an attacker can directly send a message to the product." ;
    cwe:id "CWE-422" ;
    cwe:name "Unprotected Windows Messaging Channel ('Shatter')" .

<http://w3id.org/sepses/resource/cwe/CWE-423> a cwe:CWE ;
    cwe:description "This entry has been deprecated because it was a duplicate of CWE-441. All content has been transferred to CWE-441." ;
    cwe:id "CWE-423" ;
    cwe:name "DEPRECATED: Proxied Trusted Channel" .

<http://w3id.org/sepses/resource/cwe/CWE-424> a cwe:CWE ;
    cwe:description "The product does not sufficiently protect all possible paths that a user can take to access restricted functionality or resources." ;
    cwe:id "CWE-424" ;
    cwe:name "Improper Protection of Alternate Path" .

<http://w3id.org/sepses/resource/cwe/CWE-425> a cwe:CWE ;
    cwe:description "The web application does not adequately enforce appropriate authorization on all restricted URLs, scripts, or files." ;
    cwe:id "CWE-425" ;
    cwe:name "Direct Request ('Forced Browsing')" .

<http://w3id.org/sepses/resource/cwe/CWE-426> a cwe:CWE ;
    cwe:description "The product searches for critical resources using an externally-supplied search path that can point to resources that are not under the product's direct control." ;
    cwe:id "CWE-426" ;
    cwe:name "Untrusted Search Path" .

<http://w3id.org/sepses/resource/cwe/CWE-427> a cwe:CWE ;
    cwe:description "The product uses a fixed or controlled search path to find resources, but one or more locations in that path can be under the control of unintended actors." ;
    cwe:id "CWE-427" ;
    cwe:name "Uncontrolled Search Path Element" .

<http://w3id.org/sepses/resource/cwe/CWE-428> a cwe:CWE ;
    cwe:description "The product uses a search path that contains an unquoted element, in which the element contains whitespace or other separators. This can cause the product to access resources in a parent path." ;
    cwe:id "CWE-428" ;
    cwe:name "Unquoted Search Path or Element" .

<http://w3id.org/sepses/resource/cwe/CWE-43> a cwe:CWE ;
    cwe:description "The product accepts path input in the form of multiple trailing dot ('filedir....') without appropriate validation, which can lead to ambiguous path resolution and allow an attacker to traverse the file system to unintended locations or access arbitrary files." ;
    cwe:id "CWE-43" ;
    cwe:name "Path Equivalence: 'filename....' (Multiple Trailing Dot)" .

<http://w3id.org/sepses/resource/cwe/CWE-430> a cwe:CWE ;
    cwe:description "The wrong \"handler\" is assigned to process an object." ;
    cwe:id "CWE-430" ;
    cwe:name "Deployment of Wrong Handler" .

<http://w3id.org/sepses/resource/cwe/CWE-431> a cwe:CWE ;
    cwe:description "A handler is not available or implemented." ;
    cwe:id "CWE-431" ;
    cwe:name "Missing Handler" .

<http://w3id.org/sepses/resource/cwe/CWE-432> a cwe:CWE ;
    cwe:description "The product uses a signal handler that shares state with other signal handlers, but it does not properly mask or prevent those signal handlers from being invoked while the original signal handler is still running." ;
    cwe:id "CWE-432" ;
    cwe:name "Dangerous Signal Handler not Disabled During Sensitive Operations" .

<http://w3id.org/sepses/resource/cwe/CWE-433> a cwe:CWE ;
    cwe:description "The product stores raw content or supporting code under the web document root with an extension that is not specifically handled by the server." ;
    cwe:id "CWE-433" ;
    cwe:name "Unparsed Raw Web Content Delivery" .

<http://w3id.org/sepses/resource/cwe/CWE-434> a cwe:CWE ;
    cwe:description "The product allows the upload or transfer of dangerous file types that are automatically processed within its environment." ;
    cwe:id "CWE-434" ;
    cwe:name "Unrestricted Upload of File with Dangerous Type" .

<http://w3id.org/sepses/resource/cwe/CWE-435> a cwe:CWE ;
    cwe:description "An interaction error occurs when two entities have correct behavior when running independently of each other, but when they are integrated as components in a larger system or process, they introduce incorrect behaviors that may cause resultant weaknesses." ;
    cwe:id "CWE-435" ;
    cwe:name "Improper Interaction Between Multiple Correctly-Behaving Entities" .

<http://w3id.org/sepses/resource/cwe/CWE-436> a cwe:CWE ;
    cwe:description "Product A handles inputs or steps differently than Product B, which causes A to perform incorrect actions based on its perception of B's state." ;
    cwe:id "CWE-436" ;
    cwe:name "Interpretation Conflict" .

<http://w3id.org/sepses/resource/cwe/CWE-437> a cwe:CWE ;
    cwe:description "A product acts as an intermediary or monitor between two or more endpoints, but it does not have a complete model of an endpoint's features, behaviors, or state, potentially causing the product to perform incorrect actions based on this incomplete model." ;
    cwe:id "CWE-437" ;
    cwe:name "Incomplete Model of Endpoint Features" .

<http://w3id.org/sepses/resource/cwe/CWE-439> a cwe:CWE ;
    cwe:description "A's behavior or functionality changes with a new version of A, or a new environment, which is not known (or manageable) by B." ;
    cwe:id "CWE-439" ;
    cwe:name "Behavioral Change in New Version or Environment" .

<http://w3id.org/sepses/resource/cwe/CWE-44> a cwe:CWE ;
    cwe:description "The product accepts path input in the form of internal dot ('file.ordir') without appropriate validation, which can lead to ambiguous path resolution and allow an attacker to traverse the file system to unintended locations or access arbitrary files." ;
    cwe:id "CWE-44" ;
    cwe:name "Path Equivalence: 'file.name' (Internal Dot)" .

<http://w3id.org/sepses/resource/cwe/CWE-440> a cwe:CWE ;
    cwe:description "A feature, API, or function does not perform according to its specification." ;
    cwe:id "CWE-440" ;
    cwe:name "Expected Behavior Violation" .

<http://w3id.org/sepses/resource/cwe/CWE-441> a cwe:CWE ;
    cwe:description "The product receives a request, message, or directive from an upstream component, but the product does not sufficiently preserve the original source of the request before forwarding the request to an external actor that is outside of the product's control sphere. This causes the product to appear to be the source of the request, leading it to act as a proxy or other intermediary between the upstream component and the external actor." ;
    cwe:id "CWE-441" ;
    cwe:name "Unintended Proxy or Intermediary ('Confused Deputy')" .

<http://w3id.org/sepses/resource/cwe/CWE-443> a cwe:CWE ;
    cwe:description "This weakness can be found at CWE-113." ;
    cwe:id "CWE-443" ;
    cwe:name "DEPRECATED: HTTP response splitting" .

<http://w3id.org/sepses/resource/cwe/CWE-444> a cwe:CWE ;
    cwe:description """The product acts as an intermediary HTTP agent
         (such as a proxy or firewall) in the data flow between two
         entities such as a client and server, but it does not
         interpret malformed HTTP requests or responses in ways that
         are consistent with how the messages will be processed by
         those entities that are at the ultimate destination.""" ;
    cwe:id "CWE-444" ;
    cwe:name "Inconsistent Interpretation of HTTP Requests ('HTTP Request/Response Smuggling')" .

<http://w3id.org/sepses/resource/cwe/CWE-446> a cwe:CWE ;
    cwe:description "The user interface does not correctly enable or configure a security feature, but the interface provides feedback that causes the user to believe that the feature is in a secure state." ;
    cwe:id "CWE-446" ;
    cwe:name "UI Discrepancy for Security Feature" .

<http://w3id.org/sepses/resource/cwe/CWE-447> a cwe:CWE ;
    cwe:description "A UI function for a security feature appears to be supported and gives feedback to the user that suggests that it is supported, but the underlying functionality is not implemented." ;
    cwe:id "CWE-447" ;
    cwe:name "Unimplemented or Unsupported Feature in UI" .

<http://w3id.org/sepses/resource/cwe/CWE-448> a cwe:CWE ;
    cwe:description "A UI function is obsolete and the product does not warn the user." ;
    cwe:id "CWE-448" ;
    cwe:name "Obsolete Feature in UI" .

<http://w3id.org/sepses/resource/cwe/CWE-449> a cwe:CWE ;
    cwe:description "The UI performs the wrong action with respect to the user's request." ;
    cwe:id "CWE-449" ;
    cwe:name "The UI Performs the Wrong Action" .

<http://w3id.org/sepses/resource/cwe/CWE-45> a cwe:CWE ;
    cwe:description "The product accepts path input in the form of multiple internal dot ('file...dir') without appropriate validation, which can lead to ambiguous path resolution and allow an attacker to traverse the file system to unintended locations or access arbitrary files." ;
    cwe:id "CWE-45" ;
    cwe:name "Path Equivalence: 'file...name' (Multiple Internal Dot)" .

<http://w3id.org/sepses/resource/cwe/CWE-450> a cwe:CWE ;
    cwe:description "The UI has multiple interpretations of user input but does not prompt the user when it selects the less secure interpretation." ;
    cwe:id "CWE-450" ;
    cwe:name "Multiple Interpretations of UI Input" .

<http://w3id.org/sepses/resource/cwe/CWE-451> a cwe:CWE ;
    cwe:description "The user interface (UI) does not properly represent critical information to the user, allowing the information - or its source - to be obscured or spoofed. This is often a component in phishing attacks." ;
    cwe:id "CWE-451" ;
    cwe:name "User Interface (UI) Misrepresentation of Critical Information" .

<http://w3id.org/sepses/resource/cwe/CWE-453> a cwe:CWE ;
    cwe:description "The product, by default, initializes an internal variable with an insecure or less secure value than is possible." ;
    cwe:id "CWE-453" ;
    cwe:name "Insecure Default Variable Initialization" .

<http://w3id.org/sepses/resource/cwe/CWE-454> a cwe:CWE ;
    cwe:description "The product initializes critical internal variables or data stores using inputs that can be modified by untrusted actors." ;
    cwe:id "CWE-454" ;
    cwe:name "External Initialization of Trusted Variables or Data Stores" .

<http://w3id.org/sepses/resource/cwe/CWE-455> a cwe:CWE ;
    cwe:description "The product does not exit or otherwise modify its operation when security-relevant errors occur during initialization, such as when a configuration file has a format error or a hardware security module (HSM) cannot be activated, which can cause the product to execute in a less secure fashion than intended by the administrator." ;
    cwe:id "CWE-455" ;
    cwe:name "Non-exit on Failed Initialization" .

<http://w3id.org/sepses/resource/cwe/CWE-456> a cwe:CWE ;
    cwe:description "The product does not initialize critical variables, which causes the execution environment to use unexpected values." ;
    cwe:id "CWE-456" ;
    cwe:name "Missing Initialization of a Variable" .

<http://w3id.org/sepses/resource/cwe/CWE-457> a cwe:CWE ;
    cwe:description "The code uses a variable that has not been initialized, leading to unpredictable or unintended results." ;
    cwe:id "CWE-457" ;
    cwe:name "Use of Uninitialized Variable" .

<http://w3id.org/sepses/resource/cwe/CWE-458> a cwe:CWE ;
    cwe:description "This weakness has been deprecated because its name and description did not match. The description duplicated CWE-454, while the name suggested a more abstract initialization problem. Please refer to CWE-665 for the more abstract problem." ;
    cwe:id "CWE-458" ;
    cwe:name "DEPRECATED: Incorrect Initialization" .

<http://w3id.org/sepses/resource/cwe/CWE-459> a cwe:CWE ;
    cwe:description "The product does not properly \"clean up\" and remove temporary or supporting resources after they have been used." ;
    cwe:id "CWE-459" ;
    cwe:name "Incomplete Cleanup" .

<http://w3id.org/sepses/resource/cwe/CWE-46> a cwe:CWE ;
    cwe:description "The product accepts path input in the form of trailing space ('filedir ') without appropriate validation, which can lead to ambiguous path resolution and allow an attacker to traverse the file system to unintended locations or access arbitrary files." ;
    cwe:id "CWE-46" ;
    cwe:name "Path Equivalence: 'filename ' (Trailing Space)" .

<http://w3id.org/sepses/resource/cwe/CWE-460> a cwe:CWE ;
    cwe:description "The product does not clean up its state or incorrectly cleans up its state when an exception is thrown, leading to unexpected state or control flow." ;
    cwe:id "CWE-460" ;
    cwe:name "Improper Cleanup on Thrown Exception" .

<http://w3id.org/sepses/resource/cwe/CWE-462> a cwe:CWE ;
    cwe:description "Duplicate keys in associative lists can lead to non-unique keys being mistaken for an error." ;
    cwe:id "CWE-462" ;
    cwe:name "Duplicate Key in Associative List (Alist)" .

<http://w3id.org/sepses/resource/cwe/CWE-463> a cwe:CWE ;
    cwe:description "The accidental deletion of a data-structure sentinel can cause serious programming logic problems." ;
    cwe:id "CWE-463" ;
    cwe:name "Deletion of Data Structure Sentinel" .

<http://w3id.org/sepses/resource/cwe/CWE-464> a cwe:CWE ;
    cwe:description "The accidental addition of a data-structure sentinel can cause serious programming logic problems." ;
    cwe:id "CWE-464" ;
    cwe:name "Addition of Data Structure Sentinel" .

<http://w3id.org/sepses/resource/cwe/CWE-466> a cwe:CWE ;
    cwe:description "A function can return a pointer to memory that is outside of the buffer that the pointer is expected to reference." ;
    cwe:id "CWE-466" ;
    cwe:name "Return of Pointer Value Outside of Expected Range" .

<http://w3id.org/sepses/resource/cwe/CWE-467> a cwe:CWE ;
    cwe:description "The code calls sizeof() on a pointer type, which can be an incorrect calculation if the programmer intended to determine the size of the data that is being pointed to." ;
    cwe:id "CWE-467" ;
    cwe:name "Use of sizeof() on a Pointer Type" .

<http://w3id.org/sepses/resource/cwe/CWE-468> a cwe:CWE ;
    cwe:description "In C and C++, one may often accidentally refer to the wrong memory due to the semantics of when math operations are implicitly scaled." ;
    cwe:id "CWE-468" ;
    cwe:name "Incorrect Pointer Scaling" .

<http://w3id.org/sepses/resource/cwe/CWE-469> a cwe:CWE ;
    cwe:description "The product subtracts one pointer from another in order to determine size, but this calculation can be incorrect if the pointers do not exist in the same memory chunk." ;
    cwe:id "CWE-469" ;
    cwe:name "Use of Pointer Subtraction to Determine Size" .

<http://w3id.org/sepses/resource/cwe/CWE-47> a cwe:CWE ;
    cwe:description "The product accepts path input in the form of leading space (' filedir') without appropriate validation, which can lead to ambiguous path resolution and allow an attacker to traverse the file system to unintended locations or access arbitrary files." ;
    cwe:id "CWE-47" ;
    cwe:name "Path Equivalence: ' filename' (Leading Space)" .

<http://w3id.org/sepses/resource/cwe/CWE-470> a cwe:CWE ;
    cwe:description "The product uses external input with reflection to select which classes or code to use, but it does not sufficiently prevent the input from selecting improper classes or code." ;
    cwe:id "CWE-470" ;
    cwe:name "Use of Externally-Controlled Input to Select Classes or Code ('Unsafe Reflection')" .

<http://w3id.org/sepses/resource/cwe/CWE-471> a cwe:CWE ;
    cwe:description "The product does not properly protect an assumed-immutable element from being modified by an attacker." ;
    cwe:id "CWE-471" ;
    cwe:name "Modification of Assumed-Immutable Data (MAID)" .

<http://w3id.org/sepses/resource/cwe/CWE-472> a cwe:CWE ;
    cwe:description "The web application does not sufficiently verify inputs that are assumed to be immutable but are actually externally controllable, such as hidden form fields." ;
    cwe:id "CWE-472" ;
    cwe:name "External Control of Assumed-Immutable Web Parameter" .

<http://w3id.org/sepses/resource/cwe/CWE-473> a cwe:CWE ;
    cwe:description "A PHP application does not properly protect against the modification of variables from external sources, such as query parameters or cookies. This can expose the application to numerous weaknesses that would not exist otherwise." ;
    cwe:id "CWE-473" ;
    cwe:name "PHP External Variable Modification" .

<http://w3id.org/sepses/resource/cwe/CWE-474> a cwe:CWE ;
    cwe:description "The code uses a function that has inconsistent implementations across operating systems and versions." ;
    cwe:id "CWE-474" ;
    cwe:name "Use of Function with Inconsistent Implementations" .

<http://w3id.org/sepses/resource/cwe/CWE-475> a cwe:CWE ;
    cwe:description "The behavior of this function is undefined unless its control parameter is set to a specific value." ;
    cwe:id "CWE-475" ;
    cwe:name "Undefined Behavior for Input to API" .

<http://w3id.org/sepses/resource/cwe/CWE-476> a cwe:CWE ;
    cwe:description "The product dereferences a pointer that it expects to be valid but is NULL." ;
    cwe:id "CWE-476" ;
    cwe:name "NULL Pointer Dereference" .

<http://w3id.org/sepses/resource/cwe/CWE-477> a cwe:CWE ;
    cwe:description "The code uses deprecated or obsolete functions, which suggests that the code has not been actively reviewed or maintained." ;
    cwe:id "CWE-477" ;
    cwe:name "Use of Obsolete Function" .

<http://w3id.org/sepses/resource/cwe/CWE-478> a cwe:CWE ;
    cwe:description "The code does not have a default case in an expression with multiple conditions, such as a switch statement." ;
    cwe:id "CWE-478" ;
    cwe:name "Missing Default Case in Multiple Condition Expression" .

<http://w3id.org/sepses/resource/cwe/CWE-479> a cwe:CWE ;
    cwe:description "The product defines a signal handler that calls a non-reentrant function." ;
    cwe:id "CWE-479" ;
    cwe:name "Signal Handler Use of a Non-reentrant Function" .

<http://w3id.org/sepses/resource/cwe/CWE-48> a cwe:CWE ;
    cwe:description "The product accepts path input in the form of internal space ('file(SPACE)name') without appropriate validation, which can lead to ambiguous path resolution and allow an attacker to traverse the file system to unintended locations or access arbitrary files." ;
    cwe:id "CWE-48" ;
    cwe:name "Path Equivalence: 'file name' (Internal Whitespace)" .

<http://w3id.org/sepses/resource/cwe/CWE-480> a cwe:CWE ;
    cwe:description "The product accidentally uses the wrong operator, which changes the logic in security-relevant ways." ;
    cwe:id "CWE-480" ;
    cwe:name "Use of Incorrect Operator" .

<http://w3id.org/sepses/resource/cwe/CWE-481> a cwe:CWE ;
    cwe:description "The code uses an operator for assignment when the intention was to perform a comparison." ;
    cwe:id "CWE-481" ;
    cwe:name "Assigning instead of Comparing" .

<http://w3id.org/sepses/resource/cwe/CWE-482> a cwe:CWE ;
    cwe:description "The code uses an operator for comparison when the intention was to perform an assignment." ;
    cwe:id "CWE-482" ;
    cwe:name "Comparing instead of Assigning" .

<http://w3id.org/sepses/resource/cwe/CWE-483> a cwe:CWE ;
    cwe:description "The code does not explicitly delimit a block that is intended to contain 2 or more statements, creating a logic error." ;
    cwe:id "CWE-483" ;
    cwe:name "Incorrect Block Delimitation" .

<http://w3id.org/sepses/resource/cwe/CWE-484> a cwe:CWE ;
    cwe:description "The product omits a break statement within a switch or similar construct, causing code associated with multiple conditions to execute. This can cause problems when the programmer only intended to execute code associated with one condition." ;
    cwe:id "CWE-484" ;
    cwe:name "Omitted Break Statement in Switch" .

<http://w3id.org/sepses/resource/cwe/CWE-486> a cwe:CWE ;
    cwe:description "The product compares classes by name, which can cause it to use the wrong class when multiple classes can have the same name." ;
    cwe:id "CWE-486" ;
    cwe:name "Comparison of Classes by Name" .

<http://w3id.org/sepses/resource/cwe/CWE-487> a cwe:CWE ;
    cwe:description "Java packages are not inherently closed; therefore, relying on them for code security is not a good practice." ;
    cwe:id "CWE-487" ;
    cwe:name "Reliance on Package-level Scope" .

<http://w3id.org/sepses/resource/cwe/CWE-488> a cwe:CWE ;
    cwe:description "The product does not sufficiently enforce boundaries between the states of different sessions, causing data to be provided to, or used by, the wrong session." ;
    cwe:id "CWE-488" ;
    cwe:name "Exposure of Data Element to Wrong Session" .

<http://w3id.org/sepses/resource/cwe/CWE-489> a cwe:CWE ;
    cwe:description "The product is released with debugging code still enabled or active." ;
    cwe:id "CWE-489" ;
    cwe:name "Active Debug Code" .

<http://w3id.org/sepses/resource/cwe/CWE-49> a cwe:CWE ;
    cwe:description "The product accepts path input in the form of trailing slash ('filedir/') without appropriate validation, which can lead to ambiguous path resolution and allow an attacker to traverse the file system to unintended locations or access arbitrary files." ;
    cwe:id "CWE-49" ;
    cwe:name "Path Equivalence: 'filename/' (Trailing Slash)" .

<http://w3id.org/sepses/resource/cwe/CWE-491> a cwe:CWE ;
    cwe:description "A class has a cloneable() method that is not declared final, which allows an object to be created without calling the constructor. This can cause the object to be in an unexpected state." ;
    cwe:id "CWE-491" ;
    cwe:name "Public cloneable() Method Without Final ('Object Hijack')" .

<http://w3id.org/sepses/resource/cwe/CWE-492> a cwe:CWE ;
    cwe:description "Inner classes are translated into classes that are accessible at package scope and may expose code that the programmer intended to keep private to attackers." ;
    cwe:id "CWE-492" ;
    cwe:name "Use of Inner Class Containing Sensitive Data" .

<http://w3id.org/sepses/resource/cwe/CWE-493> a cwe:CWE ;
    cwe:description "The product has a critical public variable that is not final, which allows the variable to be modified to contain unexpected values." ;
    cwe:id "CWE-493" ;
    cwe:name "Critical Public Variable Without Final Modifier" .

<http://w3id.org/sepses/resource/cwe/CWE-494> a cwe:CWE ;
    cwe:description "The product downloads source code or an executable from a remote location and executes the code without sufficiently verifying the origin and integrity of the code." ;
    cwe:id "CWE-494" ;
    cwe:name "Download of Code Without Integrity Check" .

<http://w3id.org/sepses/resource/cwe/CWE-495> a cwe:CWE ;
    cwe:description "The product has a method that is declared public, but returns a reference to a private data structure, which could then be modified in unexpected ways." ;
    cwe:id "CWE-495" ;
    cwe:name "Private Data Structure Returned From A Public Method" .

<http://w3id.org/sepses/resource/cwe/CWE-496> a cwe:CWE ;
    cwe:description "Assigning public data to a private array is equivalent to giving public access to the array." ;
    cwe:id "CWE-496" ;
    cwe:name "Public Data Assigned to Private Array-Typed Field" .

<http://w3id.org/sepses/resource/cwe/CWE-497> a cwe:CWE ;
    cwe:description "The product does not properly prevent sensitive system-level information from being accessed by unauthorized actors who do not have the same level of access to the underlying system as the product does." ;
    cwe:id "CWE-497" ;
    cwe:name "Exposure of Sensitive System Information to an Unauthorized Control Sphere" .

<http://w3id.org/sepses/resource/cwe/CWE-498> a cwe:CWE ;
    cwe:description "The code contains a class with sensitive data, but the class is cloneable. The data can then be accessed by cloning the class." ;
    cwe:id "CWE-498" ;
    cwe:name "Cloneable Class Containing Sensitive Information" .

<http://w3id.org/sepses/resource/cwe/CWE-499> a cwe:CWE ;
    cwe:description "The code contains a class with sensitive data, but the class does not explicitly deny serialization. The data can be accessed by serializing the class through another class." ;
    cwe:id "CWE-499" ;
    cwe:name "Serializable Class Containing Sensitive Data" .

<http://w3id.org/sepses/resource/cwe/CWE-5> a cwe:CWE ;
    cwe:description "Information sent over a network can be compromised while in transit. An attacker may be able to read or modify the contents if the data are sent in plaintext or are weakly encrypted." ;
    cwe:id "CWE-5" ;
    cwe:name "J2EE Misconfiguration: Data Transmission Without Encryption" .

<http://w3id.org/sepses/resource/cwe/CWE-50> a cwe:CWE ;
    cwe:description "The product accepts path input in the form of multiple leading slash ('//multiple/leading/slash') without appropriate validation, which can lead to ambiguous path resolution and allow an attacker to traverse the file system to unintended locations or access arbitrary files." ;
    cwe:id "CWE-50" ;
    cwe:name "Path Equivalence: '//multiple/leading/slash'" .

<http://w3id.org/sepses/resource/cwe/CWE-500> a cwe:CWE ;
    cwe:description "An object contains a public static field that is not marked final, which might allow it to be modified in unexpected ways." ;
    cwe:id "CWE-500" ;
    cwe:name "Public Static Field Not Marked Final" .

<http://w3id.org/sepses/resource/cwe/CWE-501> a cwe:CWE ;
    cwe:description "The product mixes trusted and untrusted data in the same data structure or structured message." ;
    cwe:id "CWE-501" ;
    cwe:name "Trust Boundary Violation" .

<http://w3id.org/sepses/resource/cwe/CWE-502> a cwe:CWE ;
    cwe:description "The product deserializes untrusted data without sufficiently ensuring that the resulting data will be valid." ;
    cwe:id "CWE-502" ;
    cwe:name "Deserialization of Untrusted Data" .

<http://w3id.org/sepses/resource/cwe/CWE-506> a cwe:CWE ;
    cwe:description "The product contains code that appears to be malicious in nature." ;
    cwe:id "CWE-506" ;
    cwe:name "Embedded Malicious Code" .

<http://w3id.org/sepses/resource/cwe/CWE-507> a cwe:CWE ;
    cwe:description "The product appears to contain benign or useful functionality, but it also contains code that is hidden from normal operation that violates the intended security policy of the user or the system administrator." ;
    cwe:id "CWE-507" ;
    cwe:name "Trojan Horse" .

<http://w3id.org/sepses/resource/cwe/CWE-508> a cwe:CWE ;
    cwe:description "Non-replicating malicious code only resides on the target system or product that is attacked; it does not attempt to spread to other systems." ;
    cwe:id "CWE-508" ;
    cwe:name "Non-Replicating Malicious Code" .

<http://w3id.org/sepses/resource/cwe/CWE-509> a cwe:CWE ;
    cwe:description "Replicating malicious code, including viruses and worms, will attempt to attack other systems once it has successfully compromised the target system or the product." ;
    cwe:id "CWE-509" ;
    cwe:name "Replicating Malicious Code (Virus or Worm)" .

<http://w3id.org/sepses/resource/cwe/CWE-51> a cwe:CWE ;
    cwe:description "The product accepts path input in the form of multiple internal slash ('/multiple//internal/slash/') without appropriate validation, which can lead to ambiguous path resolution and allow an attacker to traverse the file system to unintended locations or access arbitrary files." ;
    cwe:id "CWE-51" ;
    cwe:name "Path Equivalence: '/multiple//internal/slash'" .

<http://w3id.org/sepses/resource/cwe/CWE-510> a cwe:CWE ;
    cwe:description "A trapdoor is a hidden piece of code that responds to a special input, allowing its user access to resources without passing through the normal security enforcement mechanism." ;
    cwe:id "CWE-510" ;
    cwe:name "Trapdoor" .

<http://w3id.org/sepses/resource/cwe/CWE-511> a cwe:CWE ;
    cwe:description "The product contains code that is designed to disrupt the legitimate operation of the product (or its environment) when a certain time passes, or when a certain logical condition is met." ;
    cwe:id "CWE-511" ;
    cwe:name "Logic/Time Bomb" .

<http://w3id.org/sepses/resource/cwe/CWE-512> a cwe:CWE ;
    cwe:description "The product collects personally identifiable information about a human user or the user's activities, but the product accesses this information using other resources besides itself, and it does not require that user's explicit approval or direct input into the product." ;
    cwe:id "CWE-512" ;
    cwe:name "Spyware" .

<http://w3id.org/sepses/resource/cwe/CWE-514> a cwe:CWE ;
    cwe:description "A covert channel is a path that can be used to transfer information in a way not intended by the system's designers." ;
    cwe:id "CWE-514" ;
    cwe:name "Covert Channel" .

<http://w3id.org/sepses/resource/cwe/CWE-515> a cwe:CWE ;
    cwe:description "A covert storage channel transfers information through the setting of bits by one program and the reading of those bits by another. What distinguishes this case from that of ordinary operation is that the bits are used to convey encoded information." ;
    cwe:id "CWE-515" ;
    cwe:name "Covert Storage Channel" .

<http://w3id.org/sepses/resource/cwe/CWE-516> a cwe:CWE ;
    cwe:description "This weakness can be found at CWE-385." ;
    cwe:id "CWE-516" ;
    cwe:name "DEPRECATED: Covert Timing Channel" .

<http://w3id.org/sepses/resource/cwe/CWE-52> a cwe:CWE ;
    cwe:description "The product accepts path input in the form of multiple trailing slash ('/multiple/trailing/slash//') without appropriate validation, which can lead to ambiguous path resolution and allow an attacker to traverse the file system to unintended locations or access arbitrary files." ;
    cwe:id "CWE-52" ;
    cwe:name "Path Equivalence: '/multiple/trailing/slash//'" .

<http://w3id.org/sepses/resource/cwe/CWE-520> a cwe:CWE ;
    cwe:description "Allowing a .NET application to run at potentially escalated levels of access to the underlying operating and file systems can be dangerous and result in various forms of attacks." ;
    cwe:id "CWE-520" ;
    cwe:name ".NET Misconfiguration: Use of Impersonation" .

<http://w3id.org/sepses/resource/cwe/CWE-521> a cwe:CWE ;
    cwe:description "The product does not require that users should have strong passwords." ;
    cwe:id "CWE-521" ;
    cwe:name "Weak Password Requirements" .

<http://w3id.org/sepses/resource/cwe/CWE-522> a cwe:CWE ;
    cwe:description "The product transmits or stores authentication credentials, but it uses an insecure method that is susceptible to unauthorized interception and/or retrieval." ;
    cwe:id "CWE-522" ;
    cwe:name "Insufficiently Protected Credentials" .

<http://w3id.org/sepses/resource/cwe/CWE-523> a cwe:CWE ;
    cwe:description "Login pages do not use adequate measures to protect the user name and password while they are in transit from the client to the server." ;
    cwe:id "CWE-523" ;
    cwe:name "Unprotected Transport of Credentials" .

<http://w3id.org/sepses/resource/cwe/CWE-524> a cwe:CWE ;
    cwe:description "The code uses a cache that contains sensitive information, but the cache can be read by an actor outside of the intended control sphere." ;
    cwe:id "CWE-524" ;
    cwe:name "Use of Cache Containing Sensitive Information" .

<http://w3id.org/sepses/resource/cwe/CWE-525> a cwe:CWE ;
    cwe:description "The web application does not use an appropriate caching policy that specifies the extent to which each web page and associated form fields should be cached." ;
    cwe:id "CWE-525" ;
    cwe:name "Use of Web Browser Cache Containing Sensitive Information" .

<http://w3id.org/sepses/resource/cwe/CWE-526> a cwe:CWE ;
    cwe:description "The product uses an environment variable to store unencrypted sensitive information." ;
    cwe:id "CWE-526" ;
    cwe:name "Cleartext Storage of Sensitive Information in an Environment Variable" .

<http://w3id.org/sepses/resource/cwe/CWE-527> a cwe:CWE ;
    cwe:description "The product stores a CVS, git, or other repository in a directory, archive, or other resource that is stored, transferred, or otherwise made accessible to unauthorized actors." ;
    cwe:id "CWE-527" ;
    cwe:name "Exposure of Version-Control Repository to an Unauthorized Control Sphere" .

<http://w3id.org/sepses/resource/cwe/CWE-528> a cwe:CWE ;
    cwe:description "The product generates a core dump file in a directory, archive, or other resource that is stored, transferred, or otherwise made accessible to unauthorized actors." ;
    cwe:id "CWE-528" ;
    cwe:name "Exposure of Core Dump File to an Unauthorized Control Sphere" .

<http://w3id.org/sepses/resource/cwe/CWE-529> a cwe:CWE ;
    cwe:description "The product stores access control list files in a directory or other container that is accessible to actors outside of the intended control sphere." ;
    cwe:id "CWE-529" ;
    cwe:name "Exposure of Access Control List Files to an Unauthorized Control Sphere" .

<http://w3id.org/sepses/resource/cwe/CWE-53> a cwe:CWE ;
    cwe:description "The product accepts path input in the form of multiple internal backslash ('\\multiple\\trailing\\\\slash') without appropriate validation, which can lead to ambiguous path resolution and allow an attacker to traverse the file system to unintended locations or access arbitrary files." ;
    cwe:id "CWE-53" ;
    cwe:name "Path Equivalence: '\\multiple\\\\internal\\backslash'" .

<http://w3id.org/sepses/resource/cwe/CWE-530> a cwe:CWE ;
    cwe:description "A backup file is stored in a directory or archive that is made accessible to unauthorized actors." ;
    cwe:id "CWE-530" ;
    cwe:name "Exposure of Backup File to an Unauthorized Control Sphere" .

<http://w3id.org/sepses/resource/cwe/CWE-531> a cwe:CWE ;
    cwe:description "Accessible test applications can pose a variety of security risks. Since developers or administrators rarely consider that someone besides themselves would even know about the existence of these applications, it is common for them to contain sensitive information or functions." ;
    cwe:id "CWE-531" ;
    cwe:name "Inclusion of Sensitive Information in Test Code" .

<http://w3id.org/sepses/resource/cwe/CWE-532> a cwe:CWE ;
    cwe:description "The product writes sensitive information to a log file." ;
    cwe:id "CWE-532" ;
    cwe:name "Insertion of Sensitive Information into Log File" .

<http://w3id.org/sepses/resource/cwe/CWE-533> a cwe:CWE ;
    cwe:description "This entry has been deprecated because its abstraction was too low-level.  See CWE-532." ;
    cwe:id "CWE-533" ;
    cwe:name "DEPRECATED: Information Exposure Through Server Log Files" .

<http://w3id.org/sepses/resource/cwe/CWE-534> a cwe:CWE ;
    cwe:description "This entry has been deprecated because its abstraction was too low-level.  See CWE-532." ;
    cwe:id "CWE-534" ;
    cwe:name "DEPRECATED: Information Exposure Through Debug Log Files" .

<http://w3id.org/sepses/resource/cwe/CWE-535> a cwe:CWE ;
    cwe:description "A command shell error message indicates that there exists an unhandled exception in the web application code. In many cases, an attacker can leverage the conditions that cause these errors in order to gain unauthorized access to the system." ;
    cwe:id "CWE-535" ;
    cwe:name "Exposure of Information Through Shell Error Message" .

<http://w3id.org/sepses/resource/cwe/CWE-536> a cwe:CWE ;
    cwe:description "A servlet error message indicates that there exists an unhandled exception in the web application code and may provide useful information to an attacker." ;
    cwe:id "CWE-536" ;
    cwe:name "Servlet Runtime Error Message Containing Sensitive Information" .

<http://w3id.org/sepses/resource/cwe/CWE-537> a cwe:CWE ;
    cwe:description "In many cases, an attacker can leverage the conditions that cause unhandled exception errors in order to gain unauthorized access to the system." ;
    cwe:id "CWE-537" ;
    cwe:name "Java Runtime Error Message Containing Sensitive Information" .

<http://w3id.org/sepses/resource/cwe/CWE-538> a cwe:CWE ;
    cwe:description "The product places sensitive information into files or directories that are accessible to actors who are allowed to have access to the files, but not to the sensitive information." ;
    cwe:id "CWE-538" ;
    cwe:name "Insertion of Sensitive Information into Externally-Accessible File or Directory" .

<http://w3id.org/sepses/resource/cwe/CWE-539> a cwe:CWE ;
    cwe:description "The web application uses persistent cookies, but the cookies contain sensitive information." ;
    cwe:id "CWE-539" ;
    cwe:name "Use of Persistent Cookies Containing Sensitive Information" .

<http://w3id.org/sepses/resource/cwe/CWE-54> a cwe:CWE ;
    cwe:description "The product accepts path input in the form of trailing backslash ('filedir\\') without appropriate validation, which can lead to ambiguous path resolution and allow an attacker to traverse the file system to unintended locations or access arbitrary files." ;
    cwe:id "CWE-54" ;
    cwe:name "Path Equivalence: 'filedir\\' (Trailing Backslash)" .

<http://w3id.org/sepses/resource/cwe/CWE-540> a cwe:CWE ;
    cwe:description "Source code on a web server or repository often contains sensitive information and should generally not be accessible to users." ;
    cwe:id "CWE-540" ;
    cwe:name "Inclusion of Sensitive Information in Source Code" .

<http://w3id.org/sepses/resource/cwe/CWE-541> a cwe:CWE ;
    cwe:description "If an include file source is accessible, the file can contain usernames and passwords, as well as sensitive information pertaining to the application and system." ;
    cwe:id "CWE-541" ;
    cwe:name "Inclusion of Sensitive Information in an Include File" .

<http://w3id.org/sepses/resource/cwe/CWE-542> a cwe:CWE ;
    cwe:description "This entry has been deprecated because its abstraction was too low-level.  See CWE-532." ;
    cwe:id "CWE-542" ;
    cwe:name "DEPRECATED: Information Exposure Through Cleanup Log Files" .

<http://w3id.org/sepses/resource/cwe/CWE-543> a cwe:CWE ;
    cwe:description "The product uses the singleton pattern when creating a resource within a multithreaded environment." ;
    cwe:id "CWE-543" ;
    cwe:name "Use of Singleton Pattern Without Synchronization in a Multithreaded Context" .

<http://w3id.org/sepses/resource/cwe/CWE-544> a cwe:CWE ;
    cwe:description "The product does not use a standardized method for handling errors throughout the code, which might introduce inconsistent error handling and resultant weaknesses." ;
    cwe:id "CWE-544" ;
    cwe:name "Missing Standardized Error Handling Mechanism" .

<http://w3id.org/sepses/resource/cwe/CWE-545> a cwe:CWE ;
    cwe:description "This weakness has been deprecated because it partially overlaps CWE-470, it describes legitimate programmer behavior, and other portions will need to be integrated into other entries." ;
    cwe:id "CWE-545" ;
    cwe:name "DEPRECATED: Use of Dynamic Class Loading" .

<http://w3id.org/sepses/resource/cwe/CWE-546> a cwe:CWE ;
    cwe:description "The code contains comments that suggest the presence of bugs, incomplete functionality, or weaknesses." ;
    cwe:id "CWE-546" ;
    cwe:name "Suspicious Comment" .

<http://w3id.org/sepses/resource/cwe/CWE-547> a cwe:CWE ;
    cwe:description "The product uses hard-coded constants instead of symbolic names for security-critical values, which increases the likelihood of mistakes during code maintenance or security policy change." ;
    cwe:id "CWE-547" ;
    cwe:name "Use of Hard-coded, Security-relevant Constants" .

<http://w3id.org/sepses/resource/cwe/CWE-548> a cwe:CWE ;
    cwe:description "The product inappropriately exposes a directory listing with an index of all the resources located inside of the directory." ;
    cwe:id "CWE-548" ;
    cwe:name "Exposure of Information Through Directory Listing" .

<http://w3id.org/sepses/resource/cwe/CWE-549> a cwe:CWE ;
    cwe:description "The product does not mask passwords during entry, increasing the potential for attackers to observe and capture passwords." ;
    cwe:id "CWE-549" ;
    cwe:name "Missing Password Field Masking" .

<http://w3id.org/sepses/resource/cwe/CWE-55> a cwe:CWE ;
    cwe:description "The product accepts path input in the form of single dot directory exploit ('/./') without appropriate validation, which can lead to ambiguous path resolution and allow an attacker to traverse the file system to unintended locations or access arbitrary files." ;
    cwe:id "CWE-55" ;
    cwe:name "Path Equivalence: '/./' (Single Dot Directory)" .

<http://w3id.org/sepses/resource/cwe/CWE-550> a cwe:CWE ;
    cwe:description "Certain conditions, such as network failure, will cause a server error message to be displayed." ;
    cwe:id "CWE-550" ;
    cwe:name "Server-generated Error Message Containing Sensitive Information" .

<http://w3id.org/sepses/resource/cwe/CWE-551> a cwe:CWE ;
    cwe:description "If a web server does not fully parse requested URLs before it examines them for authorization, it may be possible for an attacker to bypass authorization protection." ;
    cwe:id "CWE-551" ;
    cwe:name "Incorrect Behavior Order: Authorization Before Parsing and Canonicalization" .

<http://w3id.org/sepses/resource/cwe/CWE-552> a cwe:CWE ;
    cwe:description "The product makes files or directories accessible to unauthorized actors, even though they should not be." ;
    cwe:id "CWE-552" ;
    cwe:name "Files or Directories Accessible to External Parties" .

<http://w3id.org/sepses/resource/cwe/CWE-553> a cwe:CWE ;
    cwe:description "A possible shell file exists in /cgi-bin/ or other accessible directories. This is extremely dangerous and can be used by an attacker to execute commands on the web server." ;
    cwe:id "CWE-553" ;
    cwe:name "Command Shell in Externally Accessible Directory" .

<http://w3id.org/sepses/resource/cwe/CWE-554> a cwe:CWE ;
    cwe:description "The ASP.NET application does not use an input validation framework." ;
    cwe:id "CWE-554" ;
    cwe:name "ASP.NET Misconfiguration: Not Using Input Validation Framework" .

<http://w3id.org/sepses/resource/cwe/CWE-555> a cwe:CWE ;
    cwe:description "The J2EE application stores a plaintext password in a configuration file." ;
    cwe:id "CWE-555" ;
    cwe:name "J2EE Misconfiguration: Plaintext Password in Configuration File" .

<http://w3id.org/sepses/resource/cwe/CWE-556> a cwe:CWE ;
    cwe:description "Configuring an ASP.NET application to run with impersonated credentials may give the application unnecessary privileges." ;
    cwe:id "CWE-556" ;
    cwe:name "ASP.NET Misconfiguration: Use of Identity Impersonation" .

<http://w3id.org/sepses/resource/cwe/CWE-558> a cwe:CWE ;
    cwe:description "The product uses the getlogin() function in a multithreaded context, potentially causing it to return incorrect values." ;
    cwe:id "CWE-558" ;
    cwe:name "Use of getlogin() in Multithreaded Application" .

<http://w3id.org/sepses/resource/cwe/CWE-56> a cwe:CWE ;
    cwe:description "The product accepts path input in the form of asterisk wildcard ('filedir*') without appropriate validation, which can lead to ambiguous path resolution and allow an attacker to traverse the file system to unintended locations or access arbitrary files." ;
    cwe:id "CWE-56" ;
    cwe:name "Path Equivalence: 'filedir*' (Wildcard)" .

<http://w3id.org/sepses/resource/cwe/CWE-560> a cwe:CWE ;
    cwe:description "The product calls umask() with an incorrect argument that is specified as if it is an argument to chmod()." ;
    cwe:id "CWE-560" ;
    cwe:name "Use of umask() with chmod-style Argument" .

<http://w3id.org/sepses/resource/cwe/CWE-561> a cwe:CWE ;
    cwe:description "The product contains dead code, which can never be executed." ;
    cwe:id "CWE-561" ;
    cwe:name "Dead Code" .

<http://w3id.org/sepses/resource/cwe/CWE-562> a cwe:CWE ;
    cwe:description "A function returns the address of a stack variable, which will cause unintended program behavior, typically in the form of a crash." ;
    cwe:id "CWE-562" ;
    cwe:name "Return of Stack Variable Address" .

<http://w3id.org/sepses/resource/cwe/CWE-563> a cwe:CWE ;
    cwe:description "The variable's value is assigned but never used, making it a dead store." ;
    cwe:id "CWE-563" ;
    cwe:name "Assignment to Variable without Use" .

<http://w3id.org/sepses/resource/cwe/CWE-564> a cwe:CWE ;
    cwe:description "Using Hibernate to execute a dynamic SQL statement built with user-controlled input can allow an attacker to modify the statement's meaning or to execute arbitrary SQL commands." ;
    cwe:id "CWE-564" ;
    cwe:name "SQL Injection: Hibernate" .

<http://w3id.org/sepses/resource/cwe/CWE-565> a cwe:CWE ;
    cwe:description "The product relies on the existence or values of cookies when performing security-critical operations, but it does not properly ensure that the setting is valid for the associated user." ;
    cwe:id "CWE-565" ;
    cwe:name "Reliance on Cookies without Validation and Integrity Checking" .

<http://w3id.org/sepses/resource/cwe/CWE-566> a cwe:CWE ;
    cwe:description "The product uses a database table that includes records that should not be accessible to an actor, but it executes a SQL statement with a primary key that can be controlled by that actor." ;
    cwe:id "CWE-566" ;
    cwe:name "Authorization Bypass Through User-Controlled SQL Primary Key" .

<http://w3id.org/sepses/resource/cwe/CWE-567> a cwe:CWE ;
    cwe:description "The product does not properly synchronize shared data, such as static variables across threads, which can lead to undefined behavior and unpredictable data changes." ;
    cwe:id "CWE-567" ;
    cwe:name "Unsynchronized Access to Shared Data in a Multithreaded Context" .

<http://w3id.org/sepses/resource/cwe/CWE-568> a cwe:CWE ;
    cwe:description "The product contains a finalize() method that does not call super.finalize()." ;
    cwe:id "CWE-568" ;
    cwe:name "finalize() Method Without super.finalize()" .

<http://w3id.org/sepses/resource/cwe/CWE-57> a cwe:CWE ;
    cwe:description "The product contains protection mechanisms to restrict access to 'realdir/filename', but it constructs pathnames using external input in the form of 'fakedir/../realdir/filename' that are not handled by those mechanisms. This allows attackers to perform unauthorized actions against the targeted file." ;
    cwe:id "CWE-57" ;
    cwe:name "Path Equivalence: 'fakedir/../realdir/filename'" .

<http://w3id.org/sepses/resource/cwe/CWE-570> a cwe:CWE ;
    cwe:description "The product contains an expression that will always evaluate to false." ;
    cwe:id "CWE-570" ;
    cwe:name "Expression is Always False" .

<http://w3id.org/sepses/resource/cwe/CWE-571> a cwe:CWE ;
    cwe:description "The product contains an expression that will always evaluate to true." ;
    cwe:id "CWE-571" ;
    cwe:name "Expression is Always True" .

<http://w3id.org/sepses/resource/cwe/CWE-572> a cwe:CWE ;
    cwe:description "The product calls a thread's run() method instead of calling start(), which causes the code to run in the thread of the caller instead of the callee." ;
    cwe:id "CWE-572" ;
    cwe:name "Call to Thread run() instead of start()" .

<http://w3id.org/sepses/resource/cwe/CWE-573> a cwe:CWE ;
    cwe:description "The product does not follow or incorrectly follows the specifications as required by the implementation language, environment, framework, protocol, or platform." ;
    cwe:id "CWE-573" ;
    cwe:name "Improper Following of Specification by Caller" .

<http://w3id.org/sepses/resource/cwe/CWE-574> a cwe:CWE ;
    cwe:description "The product violates the Enterprise JavaBeans (EJB) specification by using thread synchronization primitives." ;
    cwe:id "CWE-574" ;
    cwe:name "EJB Bad Practices: Use of Synchronization Primitives" .

<http://w3id.org/sepses/resource/cwe/CWE-575> a cwe:CWE ;
    cwe:description "The product violates the Enterprise JavaBeans (EJB) specification by using AWT/Swing." ;
    cwe:id "CWE-575" ;
    cwe:name "EJB Bad Practices: Use of AWT Swing" .

<http://w3id.org/sepses/resource/cwe/CWE-576> a cwe:CWE ;
    cwe:description "The product violates the Enterprise JavaBeans (EJB) specification by using the java.io package." ;
    cwe:id "CWE-576" ;
    cwe:name "EJB Bad Practices: Use of Java I/O" .

<http://w3id.org/sepses/resource/cwe/CWE-577> a cwe:CWE ;
    cwe:description "The product violates the Enterprise JavaBeans (EJB) specification by using sockets." ;
    cwe:id "CWE-577" ;
    cwe:name "EJB Bad Practices: Use of Sockets" .

<http://w3id.org/sepses/resource/cwe/CWE-578> a cwe:CWE ;
    cwe:description "The product violates the Enterprise JavaBeans (EJB) specification by using the class loader." ;
    cwe:id "CWE-578" ;
    cwe:name "EJB Bad Practices: Use of Class Loader" .

<http://w3id.org/sepses/resource/cwe/CWE-579> a cwe:CWE ;
    cwe:description "The product stores a non-serializable object as an HttpSession attribute, which can hurt reliability." ;
    cwe:id "CWE-579" ;
    cwe:name "J2EE Bad Practices: Non-serializable Object Stored in Session" .

<http://w3id.org/sepses/resource/cwe/CWE-58> a cwe:CWE ;
    cwe:description "The product contains a protection mechanism that restricts access to a long filename on a Windows operating system, but it does not properly restrict access to the equivalent short \"8.3\" filename." ;
    cwe:id "CWE-58" ;
    cwe:name "Path Equivalence: Windows 8.3 Filename" .

<http://w3id.org/sepses/resource/cwe/CWE-580> a cwe:CWE ;
    cwe:description "The product contains a clone() method that does not call super.clone() to obtain the new object." ;
    cwe:id "CWE-580" ;
    cwe:name "clone() Method Without super.clone()" .

<http://w3id.org/sepses/resource/cwe/CWE-581> a cwe:CWE ;
    cwe:description "The product does not maintain equal hashcodes for equal objects." ;
    cwe:id "CWE-581" ;
    cwe:name "Object Model Violation: Just One of Equals and Hashcode Defined" .

<http://w3id.org/sepses/resource/cwe/CWE-582> a cwe:CWE ;
    cwe:description "The product declares an array public, final, and static, which is not sufficient to prevent the array's contents from being modified." ;
    cwe:id "CWE-582" ;
    cwe:name "Array Declared Public, Final, and Static" .

<http://w3id.org/sepses/resource/cwe/CWE-583> a cwe:CWE ;
    cwe:description "The product violates secure coding principles for mobile code by declaring a finalize() method public." ;
    cwe:id "CWE-583" ;
    cwe:name "finalize() Method Declared Public" .

<http://w3id.org/sepses/resource/cwe/CWE-584> a cwe:CWE ;
    cwe:description "The code has a return statement inside a finally block, which will cause any thrown exception in the try block to be discarded." ;
    cwe:id "CWE-584" ;
    cwe:name "Return Inside Finally Block" .

<http://w3id.org/sepses/resource/cwe/CWE-585> a cwe:CWE ;
    cwe:description "The product contains an empty synchronized block." ;
    cwe:id "CWE-585" ;
    cwe:name "Empty Synchronized Block" .

<http://w3id.org/sepses/resource/cwe/CWE-586> a cwe:CWE ;
    cwe:description "The product makes an explicit call to the finalize() method from outside the finalizer." ;
    cwe:id "CWE-586" ;
    cwe:name "Explicit Call to Finalize()" .

<http://w3id.org/sepses/resource/cwe/CWE-587> a cwe:CWE ;
    cwe:description "The product sets a pointer to a specific address other than NULL or 0." ;
    cwe:id "CWE-587" ;
    cwe:name "Assignment of a Fixed Address to a Pointer" .

<http://w3id.org/sepses/resource/cwe/CWE-588> a cwe:CWE ;
    cwe:description "Casting a non-structure type to a structure type and accessing a field can lead to memory access errors or data corruption." ;
    cwe:id "CWE-588" ;
    cwe:name "Attempt to Access Child of a Non-structure Pointer" .

<http://w3id.org/sepses/resource/cwe/CWE-589> a cwe:CWE ;
    cwe:description "The product uses an API function that does not exist on all versions of the target platform. This could cause portability problems or inconsistencies that allow denial of service or other consequences." ;
    cwe:id "CWE-589" ;
    cwe:name "Call to Non-ubiquitous API" .

<http://w3id.org/sepses/resource/cwe/CWE-59> a cwe:CWE ;
    cwe:description "The product attempts to access a file based on the filename, but it does not properly prevent that filename from identifying a link or shortcut that resolves to an unintended resource." ;
    cwe:id "CWE-59" ;
    cwe:name "Improper Link Resolution Before File Access ('Link Following')" .

<http://w3id.org/sepses/resource/cwe/CWE-590> a cwe:CWE ;
    cwe:description "The product calls free() on a pointer to memory that was not allocated using associated heap allocation functions such as malloc(), calloc(), or realloc()." ;
    cwe:id "CWE-590" ;
    cwe:name "Free of Memory not on the Heap" .

<http://w3id.org/sepses/resource/cwe/CWE-591> a cwe:CWE ;
    cwe:description "The product stores sensitive data in memory that is not locked, or that has been incorrectly locked, which might cause the memory to be written to swap files on disk by the virtual memory manager. This can make the data more accessible to external actors." ;
    cwe:id "CWE-591" ;
    cwe:name "Sensitive Data Storage in Improperly Locked Memory" .

<http://w3id.org/sepses/resource/cwe/CWE-592> a cwe:CWE ;
    cwe:description "This weakness has been deprecated because it covered redundant concepts already described in CWE-287." ;
    cwe:id "CWE-592" ;
    cwe:name "DEPRECATED: Authentication Bypass Issues" .

<http://w3id.org/sepses/resource/cwe/CWE-593> a cwe:CWE ;
    cwe:description "The product modifies the SSL context after connection creation has begun." ;
    cwe:id "CWE-593" ;
    cwe:name "Authentication Bypass: OpenSSL CTX Object Modified after SSL Objects are Created" .

<http://w3id.org/sepses/resource/cwe/CWE-594> a cwe:CWE ;
    cwe:description "When the J2EE container attempts to write unserializable objects to disk there is no guarantee that the process will complete successfully." ;
    cwe:id "CWE-594" ;
    cwe:name "J2EE Framework: Saving Unserializable Objects to Disk" .

<http://w3id.org/sepses/resource/cwe/CWE-595> a cwe:CWE ;
    cwe:description "The product compares object references instead of the contents of the objects themselves, preventing it from detecting equivalent objects." ;
    cwe:id "CWE-595" ;
    cwe:name "Comparison of Object References Instead of Object Contents" .

<http://w3id.org/sepses/resource/cwe/CWE-596> a cwe:CWE ;
    cwe:description "This weakness has been deprecated.  It was poorly described and difficult to distinguish from other entries.  It was also inappropriate to assign a separate ID solely because of domain-specific considerations.  Its closest equivalent is CWE-1023." ;
    cwe:id "CWE-596" ;
    cwe:name "DEPRECATED: Incorrect Semantic Object Comparison" .

<http://w3id.org/sepses/resource/cwe/CWE-597> a cwe:CWE ;
    cwe:description "The product uses the wrong operator when comparing a string, such as using \"==\" when the .equals() method should be used instead." ;
    cwe:id "CWE-597" ;
    cwe:name "Use of Wrong Operator in String Comparison" .

<http://w3id.org/sepses/resource/cwe/CWE-598> a cwe:CWE ;
    cwe:description "The web application uses an HTTP method to process a request, but the request includes sensitive information in the query string." ;
    cwe:id "CWE-598" ;
    cwe:name "Use of HTTP Request With Sensitive Query String" .

<http://w3id.org/sepses/resource/cwe/CWE-599> a cwe:CWE ;
    cwe:description "The product uses OpenSSL and trusts or uses a certificate without using the SSL_get_verify_result() function to ensure that the certificate satisfies all necessary security requirements." ;
    cwe:id "CWE-599" ;
    cwe:name "Missing Validation of OpenSSL Certificate" .

<http://w3id.org/sepses/resource/cwe/CWE-6> a cwe:CWE ;
    cwe:description "The J2EE application is configured to use an insufficient session ID length." ;
    cwe:id "CWE-6" ;
    cwe:name "J2EE Misconfiguration: Insufficient Session-ID Length" .

<http://w3id.org/sepses/resource/cwe/CWE-600> a cwe:CWE ;
    cwe:description "The Servlet does not catch all exceptions, which may reveal sensitive debugging information." ;
    cwe:id "CWE-600" ;
    cwe:name "Uncaught Exception in Servlet" .

<http://w3id.org/sepses/resource/cwe/CWE-601> a cwe:CWE ;
    cwe:description "The web application accepts a user-controlled input that specifies a link to an external site, and uses that link in a redirect." ;
    cwe:id "CWE-601" ;
    cwe:name "URL Redirection to Untrusted Site ('Open Redirect')" .

<http://w3id.org/sepses/resource/cwe/CWE-602> a cwe:CWE ;
    cwe:description "The product is composed of a server that relies on the client to implement a mechanism that is intended to protect the server." ;
    cwe:id "CWE-602" ;
    cwe:name "Client-Side Enforcement of Server-Side Security" .

<http://w3id.org/sepses/resource/cwe/CWE-603> a cwe:CWE ;
    cwe:description "A client/server product performs authentication within client code but not in server code, allowing server-side authentication to be bypassed via a modified client that omits the authentication check." ;
    cwe:id "CWE-603" ;
    cwe:name "Use of Client-Side Authentication" .

<http://w3id.org/sepses/resource/cwe/CWE-605> a cwe:CWE ;
    cwe:description "When multiple sockets are allowed to bind to the same port, other services on that port may be stolen or spoofed." ;
    cwe:id "CWE-605" ;
    cwe:name "Multiple Binds to the Same Port" .

<http://w3id.org/sepses/resource/cwe/CWE-606> a cwe:CWE ;
    cwe:description "The product does not properly check inputs that are used for loop conditions, potentially leading to a denial of service or other consequences because of excessive looping." ;
    cwe:id "CWE-606" ;
    cwe:name "Unchecked Input for Loop Condition" .

<http://w3id.org/sepses/resource/cwe/CWE-607> a cwe:CWE ;
    cwe:description "A public or protected static final field references a mutable object, which allows the object to be changed by malicious code, or accidentally from another package." ;
    cwe:id "CWE-607" ;
    cwe:name "Public Static Final Field References Mutable Object" .

<http://w3id.org/sepses/resource/cwe/CWE-608> a cwe:CWE ;
    cwe:description "An ActionForm class contains a field that has not been declared private, which can be accessed without using a setter or getter." ;
    cwe:id "CWE-608" ;
    cwe:name "Struts: Non-private Field in ActionForm Class" .

<http://w3id.org/sepses/resource/cwe/CWE-609> a cwe:CWE ;
    cwe:description "The product uses double-checked locking to access a resource without the overhead of explicit synchronization, but the locking is insufficient." ;
    cwe:id "CWE-609" ;
    cwe:name "Double-Checked Locking" .

<http://w3id.org/sepses/resource/cwe/CWE-61> a cwe:CWE ;
    cwe:description "The product, when opening a file or directory, does not sufficiently account for when the file is a symbolic link that resolves to a target outside of the intended control sphere. This could allow an attacker to cause the product to operate on unauthorized files." ;
    cwe:id "CWE-61" ;
    cwe:name "UNIX Symbolic Link (Symlink) Following" .

<http://w3id.org/sepses/resource/cwe/CWE-610> a cwe:CWE ;
    cwe:description "The product uses an externally controlled name or reference that resolves to a resource that is outside of the intended control sphere." ;
    cwe:id "CWE-610" ;
    cwe:name "Externally Controlled Reference to a Resource in Another Sphere" .

<http://w3id.org/sepses/resource/cwe/CWE-611> a cwe:CWE ;
    cwe:description "The product processes an XML document that can contain XML entities with URIs that resolve to documents outside of the intended sphere of control, causing the product to embed incorrect documents into its output." ;
    cwe:id "CWE-611" ;
    cwe:name "Improper Restriction of XML External Entity Reference" .

<http://w3id.org/sepses/resource/cwe/CWE-612> a cwe:CWE ;
    cwe:description "The product creates a search index of private or sensitive documents, but it does not properly limit index access to actors who are authorized to see the original information." ;
    cwe:id "CWE-612" ;
    cwe:name "Improper Authorization of Index Containing Sensitive Information" .

<http://w3id.org/sepses/resource/cwe/CWE-613> a cwe:CWE ;
    cwe:description "According to WASC, \"Insufficient Session Expiration is when a web site permits an attacker to reuse old session credentials or session IDs for authorization.\"" ;
    cwe:id "CWE-613" ;
    cwe:name "Insufficient Session Expiration" .

<http://w3id.org/sepses/resource/cwe/CWE-614> a cwe:CWE ;
    cwe:description "The Secure attribute for sensitive cookies in HTTPS sessions is not set." ;
    cwe:id "CWE-614" ;
    cwe:name "Sensitive Cookie in HTTPS Session Without 'Secure' Attribute" .

<http://w3id.org/sepses/resource/cwe/CWE-615> a cwe:CWE ;
    cwe:description "While adding general comments is very useful, some programmers tend to leave important data, such as: filenames related to the web application, old links or links which were not meant to be browsed by users, old code fragments, etc." ;
    cwe:id "CWE-615" ;
    cwe:name "Inclusion of Sensitive Information in Source Code Comments" .

<http://w3id.org/sepses/resource/cwe/CWE-616> a cwe:CWE ;
    cwe:description "The PHP application uses an old method for processing uploaded files by referencing the four global variables that are set for each file (e.g. $varname, $varname_size, $varname_name, $varname_type). These variables could be overwritten by attackers, causing the application to process unauthorized files." ;
    cwe:id "CWE-616" ;
    cwe:name "Incomplete Identification of Uploaded File Variables (PHP)" .

<http://w3id.org/sepses/resource/cwe/CWE-617> a cwe:CWE ;
    cwe:description "The product contains an assert() or similar statement that can be triggered by an attacker, which leads to an application exit or other behavior that is more severe than necessary." ;
    cwe:id "CWE-617" ;
    cwe:name "Reachable Assertion" .

<http://w3id.org/sepses/resource/cwe/CWE-618> a cwe:CWE ;
    cwe:description "An ActiveX control is intended for use in a web browser, but it exposes dangerous methods that perform actions that are outside of the browser's security model (e.g. the zone or domain)." ;
    cwe:id "CWE-618" ;
    cwe:name "Exposed Unsafe ActiveX Method" .

<http://w3id.org/sepses/resource/cwe/CWE-619> a cwe:CWE ;
    cwe:description "If a database cursor is not closed properly, then it could become accessible to other users while retaining the same privileges that were originally assigned, leaving the cursor \"dangling.\"" ;
    cwe:id "CWE-619" ;
    cwe:name "Dangling Database Cursor ('Cursor Injection')" .

<http://w3id.org/sepses/resource/cwe/CWE-62> a cwe:CWE ;
    cwe:description "The product, when opening a file or directory, does not sufficiently account for when the name is associated with a hard link to a target that is outside of the intended control sphere. This could allow an attacker to cause the product to operate on unauthorized files." ;
    cwe:id "CWE-62" ;
    cwe:name "UNIX Hard Link" .

<http://w3id.org/sepses/resource/cwe/CWE-620> a cwe:CWE ;
    cwe:description "When setting a new password for a user, the product does not require knowledge of the original password, or using another form of authentication." ;
    cwe:id "CWE-620" ;
    cwe:name "Unverified Password Change" .

<http://w3id.org/sepses/resource/cwe/CWE-621> a cwe:CWE ;
    cwe:description "The product uses external input to determine the names of variables into which information is extracted, without verifying that the names of the specified variables are valid. This could cause the program to overwrite unintended variables." ;
    cwe:id "CWE-621" ;
    cwe:name "Variable Extraction Error" .

<http://w3id.org/sepses/resource/cwe/CWE-622> a cwe:CWE ;
    cwe:description "The product adds hooks to user-accessible API functions, but it does not properly validate the arguments. This could lead to resultant vulnerabilities." ;
    cwe:id "CWE-622" ;
    cwe:name "Improper Validation of Function Hook Arguments" .

<http://w3id.org/sepses/resource/cwe/CWE-623> a cwe:CWE ;
    cwe:description "An ActiveX control is intended for restricted use, but it has been marked as safe-for-scripting." ;
    cwe:id "CWE-623" ;
    cwe:name "Unsafe ActiveX Control Marked Safe For Scripting" .

<http://w3id.org/sepses/resource/cwe/CWE-624> a cwe:CWE ;
    cwe:description "The product uses a regular expression that either (1) contains an executable component with user-controlled inputs, or (2) allows a user to enable execution by inserting pattern modifiers." ;
    cwe:id "CWE-624" ;
    cwe:name "Executable Regular Expression Error" .

<http://w3id.org/sepses/resource/cwe/CWE-625> a cwe:CWE ;
    cwe:description "The product uses a regular expression that does not sufficiently restrict the set of allowed values." ;
    cwe:id "CWE-625" ;
    cwe:name "Permissive Regular Expression" .

<http://w3id.org/sepses/resource/cwe/CWE-626> a cwe:CWE ;
    cwe:description "The product does not properly handle null bytes or NUL characters when passing data between different representations or components." ;
    cwe:id "CWE-626" ;
    cwe:name "Null Byte Interaction Error (Poison Null Byte)" .

<http://w3id.org/sepses/resource/cwe/CWE-627> a cwe:CWE ;
    cwe:description "In a language where the user can influence the name of a variable at runtime, if the variable names are not controlled, an attacker can read or write to arbitrary variables, or access arbitrary functions." ;
    cwe:id "CWE-627" ;
    cwe:name "Dynamic Variable Evaluation" .

<http://w3id.org/sepses/resource/cwe/CWE-628> a cwe:CWE ;
    cwe:description "The product calls a function, procedure, or routine with arguments that are not correctly specified, leading to always-incorrect behavior and resultant weaknesses." ;
    cwe:id "CWE-628" ;
    cwe:name "Function Call with Incorrectly Specified Arguments" .

<http://w3id.org/sepses/resource/cwe/CWE-636> a cwe:CWE ;
    cwe:description "When the product encounters an error condition or failure, its design requires it to fall back to a state that is less secure than other options that are available, such as selecting the weakest encryption algorithm or using the most permissive access control restrictions." ;
    cwe:id "CWE-636" ;
    cwe:name "Not Failing Securely ('Failing Open')" .

<http://w3id.org/sepses/resource/cwe/CWE-637> a cwe:CWE ;
    cwe:description "The product uses a more complex mechanism than necessary, which could lead to resultant weaknesses when the mechanism is not correctly understood, modeled, configured, implemented, or used." ;
    cwe:id "CWE-637" ;
    cwe:name "Unnecessary Complexity in Protection Mechanism (Not Using 'Economy of Mechanism')" .

<http://w3id.org/sepses/resource/cwe/CWE-638> a cwe:CWE ;
    cwe:description "The product does not perform access checks on a resource every time the resource is accessed by an entity, which can create resultant weaknesses if that entity's rights or privileges change over time." ;
    cwe:id "CWE-638" ;
    cwe:name "Not Using Complete Mediation" .

<http://w3id.org/sepses/resource/cwe/CWE-639> a cwe:CWE ;
    cwe:description "The system's authorization functionality does not prevent one user from gaining access to another user's data or record by modifying the key value identifying the data." ;
    cwe:id "CWE-639" ;
    cwe:name "Authorization Bypass Through User-Controlled Key" .

<http://w3id.org/sepses/resource/cwe/CWE-64> a cwe:CWE ;
    cwe:description "The product, when opening a file or directory, does not sufficiently handle when the file is a Windows shortcut (.LNK) whose target is outside of the intended control sphere. This could allow an attacker to cause the product to operate on unauthorized files." ;
    cwe:id "CWE-64" ;
    cwe:name "Windows Shortcut Following (.LNK)" .

<http://w3id.org/sepses/resource/cwe/CWE-640> a cwe:CWE ;
    cwe:description "The product contains a mechanism for users to recover or change their passwords without knowing the original password, but the mechanism is weak." ;
    cwe:id "CWE-640" ;
    cwe:name "Weak Password Recovery Mechanism for Forgotten Password" .

<http://w3id.org/sepses/resource/cwe/CWE-641> a cwe:CWE ;
    cwe:description "The product constructs the name of a file or other resource using input from an upstream component, but it does not restrict or incorrectly restricts the resulting name." ;
    cwe:id "CWE-641" ;
    cwe:name "Improper Restriction of Names for Files and Other Resources" .

<http://w3id.org/sepses/resource/cwe/CWE-642> a cwe:CWE ;
    cwe:description "The product stores security-critical state information about its users, or the product itself, in a location that is accessible to unauthorized actors." ;
    cwe:id "CWE-642" ;
    cwe:name "External Control of Critical State Data" .

<http://w3id.org/sepses/resource/cwe/CWE-643> a cwe:CWE ;
    cwe:description "The product uses external input to dynamically construct an XPath expression used to retrieve data from an XML database, but it does not neutralize or incorrectly neutralizes that input. This allows an attacker to control the structure of the query." ;
    cwe:id "CWE-643" ;
    cwe:name "Improper Neutralization of Data within XPath Expressions ('XPath Injection')" .

<http://w3id.org/sepses/resource/cwe/CWE-644> a cwe:CWE ;
    cwe:description "The product does not neutralize or incorrectly neutralizes web scripting syntax in HTTP headers that can be used by web browser components that can process raw headers, such as Flash." ;
    cwe:id "CWE-644" ;
    cwe:name "Improper Neutralization of HTTP Headers for Scripting Syntax" .

<http://w3id.org/sepses/resource/cwe/CWE-645> a cwe:CWE ;
    cwe:description "The product contains an account lockout protection mechanism, but the mechanism is too restrictive and can be triggered too easily, which allows attackers to deny service to legitimate users by causing their accounts to be locked out." ;
    cwe:id "CWE-645" ;
    cwe:name "Overly Restrictive Account Lockout Mechanism" .

<http://w3id.org/sepses/resource/cwe/CWE-646> a cwe:CWE ;
    cwe:description "The product allows a file to be uploaded, but it relies on the file name or extension of the file to determine the appropriate behaviors. This could be used by attackers to cause the file to be misclassified and processed in a dangerous fashion." ;
    cwe:id "CWE-646" ;
    cwe:name "Reliance on File Name or Extension of Externally-Supplied File" .

<http://w3id.org/sepses/resource/cwe/CWE-647> a cwe:CWE ;
    cwe:description "The product defines policy namespaces and makes authorization decisions based on the assumption that a URL is canonical. This can allow a non-canonical URL to bypass the authorization." ;
    cwe:id "CWE-647" ;
    cwe:name "Use of Non-Canonical URL Paths for Authorization Decisions" .

<http://w3id.org/sepses/resource/cwe/CWE-648> a cwe:CWE ;
    cwe:description "The product does not conform to the API requirements for a function call that requires extra privileges. This could allow attackers to gain privileges by causing the function to be called incorrectly." ;
    cwe:id "CWE-648" ;
    cwe:name "Incorrect Use of Privileged APIs" .

<http://w3id.org/sepses/resource/cwe/CWE-649> a cwe:CWE ;
    cwe:description "The product uses obfuscation or encryption of inputs that should not be mutable by an external actor, but the product does not use integrity checks to detect if those inputs have been modified." ;
    cwe:id "CWE-649" ;
    cwe:name "Reliance on Obfuscation or Encryption of Security-Relevant Inputs without Integrity Checking" .

<http://w3id.org/sepses/resource/cwe/CWE-65> a cwe:CWE ;
    cwe:description "The product, when opening a file or directory, does not sufficiently handle when the name is associated with a hard link to a target that is outside of the intended control sphere. This could allow an attacker to cause the product to operate on unauthorized files." ;
    cwe:id "CWE-65" ;
    cwe:name "Windows Hard Link" .

<http://w3id.org/sepses/resource/cwe/CWE-650> a cwe:CWE ;
    cwe:description "The server contains a protection mechanism that assumes that any URI that is accessed using HTTP GET will not cause a state change to the associated resource. This might allow attackers to bypass intended access restrictions and conduct resource modification and deletion attacks, since some applications allow GET to modify state." ;
    cwe:id "CWE-650" ;
    cwe:name "Trusting HTTP Permission Methods on the Server Side" .

<http://w3id.org/sepses/resource/cwe/CWE-651> a cwe:CWE ;
    cwe:description "The Web services architecture may require exposing a Web Service Definition Language (WSDL) file that contains information on the publicly accessible services and how callers of these services should interact with them (e.g. what parameters they expect and what types they return)." ;
    cwe:id "CWE-651" ;
    cwe:name "Exposure of WSDL File Containing Sensitive Information" .

<http://w3id.org/sepses/resource/cwe/CWE-652> a cwe:CWE ;
    cwe:description "The product uses external input to dynamically construct an XQuery expression used to retrieve data from an XML database, but it does not neutralize or incorrectly neutralizes that input. This allows an attacker to control the structure of the query." ;
    cwe:id "CWE-652" ;
    cwe:name "Improper Neutralization of Data within XQuery Expressions ('XQuery Injection')" .

<http://w3id.org/sepses/resource/cwe/CWE-653> a cwe:CWE ;
    cwe:description "The product does not properly compartmentalize or isolate functionality, processes, or resources that require different privilege levels, rights, or permissions." ;
    cwe:id "CWE-653" ;
    cwe:name "Improper Isolation or Compartmentalization" .

<http://w3id.org/sepses/resource/cwe/CWE-654> a cwe:CWE ;
    cwe:description "A protection mechanism relies exclusively, or to a large extent, on the evaluation of a single condition or the integrity of a single object or entity in order to make a decision about granting access to restricted resources or functionality." ;
    cwe:id "CWE-654" ;
    cwe:name "Reliance on a Single Factor in a Security Decision" .

<http://w3id.org/sepses/resource/cwe/CWE-655> a cwe:CWE ;
    cwe:description "The product has a protection mechanism that is too difficult or inconvenient to use, encouraging non-malicious users to disable or bypass the mechanism, whether by accident or on purpose." ;
    cwe:id "CWE-655" ;
    cwe:name "Insufficient Psychological Acceptability" .

<http://w3id.org/sepses/resource/cwe/CWE-656> a cwe:CWE ;
    cwe:description "The product uses a protection mechanism whose strength depends heavily on its obscurity, such that knowledge of its algorithms or key data is sufficient to defeat the mechanism." ;
    cwe:id "CWE-656" ;
    cwe:name "Reliance on Security Through Obscurity" .

<http://w3id.org/sepses/resource/cwe/CWE-657> a cwe:CWE ;
    cwe:description "The product violates well-established principles for secure design." ;
    cwe:id "CWE-657" ;
    cwe:name "Violation of Secure Design Principles" .

<http://w3id.org/sepses/resource/cwe/CWE-66> a cwe:CWE ;
    cwe:description "The product does not handle or incorrectly handles a file name that identifies a \"virtual\" resource that is not directly specified within the directory that is associated with the file name, causing the product to perform file-based operations on a resource that is not a file." ;
    cwe:id "CWE-66" ;
    cwe:name "Improper Handling of File Names that Identify Virtual Resources" .

<http://w3id.org/sepses/resource/cwe/CWE-662> a cwe:CWE ;
    cwe:description "The product utilizes multiple threads, processes, components, or systems to allow temporary access to a shared resource that can only be exclusive to one process at a time, but it does not properly synchronize these actions, which might cause simultaneous accesses of this resource by multiple threads or processes." ;
    cwe:id "CWE-662" ;
    cwe:name "Improper Synchronization" .

<http://w3id.org/sepses/resource/cwe/CWE-663> a cwe:CWE ;
    cwe:description "The product calls a non-reentrant function in a concurrent context in which a competing code sequence (e.g. thread or signal handler) may have an opportunity to call the same function or otherwise influence its state." ;
    cwe:id "CWE-663" ;
    cwe:name "Use of a Non-reentrant Function in a Concurrent Context" .

<http://w3id.org/sepses/resource/cwe/CWE-664> a cwe:CWE ;
    cwe:description "The product does not maintain or incorrectly maintains control over a resource throughout its lifetime of creation, use, and release." ;
    cwe:id "CWE-664" ;
    cwe:name "Improper Control of a Resource Through its Lifetime" .

<http://w3id.org/sepses/resource/cwe/CWE-665> a cwe:CWE ;
    cwe:description "The product does not initialize or incorrectly initializes a resource, which might leave the resource in an unexpected state when it is accessed or used." ;
    cwe:id "CWE-665" ;
    cwe:name "Improper Initialization" .

<http://w3id.org/sepses/resource/cwe/CWE-666> a cwe:CWE ;
    cwe:description "The product performs an operation on a resource at the wrong phase of the resource's lifecycle, which can lead to unexpected behaviors." ;
    cwe:id "CWE-666" ;
    cwe:name "Operation on Resource in Wrong Phase of Lifetime" .

<http://w3id.org/sepses/resource/cwe/CWE-667> a cwe:CWE ;
    cwe:description "The product does not properly acquire or release a lock on a resource, leading to unexpected resource state changes and behaviors." ;
    cwe:id "CWE-667" ;
    cwe:name "Improper Locking" .

<http://w3id.org/sepses/resource/cwe/CWE-668> a cwe:CWE ;
    cwe:description "The product exposes a resource to the wrong control sphere, providing unintended actors with inappropriate access to the resource." ;
    cwe:id "CWE-668" ;
    cwe:name "Exposure of Resource to Wrong Sphere" .

<http://w3id.org/sepses/resource/cwe/CWE-669> a cwe:CWE ;
    cwe:description "The product does not properly transfer a resource/behavior to another sphere, or improperly imports a resource/behavior from another sphere, in a manner that provides unintended control over that resource." ;
    cwe:id "CWE-669" ;
    cwe:name "Incorrect Resource Transfer Between Spheres" .

<http://w3id.org/sepses/resource/cwe/CWE-67> a cwe:CWE ;
    cwe:description "The product constructs pathnames from user input, but it does not handle or incorrectly handles a pathname containing a Windows device name such as AUX or CON. This typically leads to denial of service or an information exposure when the application attempts to process the pathname as a regular file." ;
    cwe:id "CWE-67" ;
    cwe:name "Improper Handling of Windows Device Names" .

<http://w3id.org/sepses/resource/cwe/CWE-670> a cwe:CWE ;
    cwe:description "The code contains a control flow path that does not reflect the algorithm that the path is intended to implement, leading to incorrect behavior any time this path is navigated." ;
    cwe:id "CWE-670" ;
    cwe:name "Always-Incorrect Control Flow Implementation" .

<http://w3id.org/sepses/resource/cwe/CWE-671> a cwe:CWE ;
    cwe:description "The product uses security features in a way that prevents the product's administrator from tailoring security settings to reflect the environment in which the product is being used. This introduces resultant weaknesses or prevents it from operating at a level of security that is desired by the administrator." ;
    cwe:id "CWE-671" ;
    cwe:name "Lack of Administrator Control over Security" .

<http://w3id.org/sepses/resource/cwe/CWE-672> a cwe:CWE ;
    cwe:description "The product uses, accesses, or otherwise operates on a resource after that resource has been expired, released, or revoked." ;
    cwe:id "CWE-672" ;
    cwe:name "Operation on a Resource after Expiration or Release" .

<http://w3id.org/sepses/resource/cwe/CWE-673> a cwe:CWE ;
    cwe:description "The product does not prevent the definition of control spheres from external actors." ;
    cwe:id "CWE-673" ;
    cwe:name "External Influence of Sphere Definition" .

<http://w3id.org/sepses/resource/cwe/CWE-674> a cwe:CWE ;
    cwe:description "The product does not properly control the amount of recursion that takes place,  consuming excessive resources, such as allocated memory or the program stack." ;
    cwe:id "CWE-674" ;
    cwe:name "Uncontrolled Recursion" .

<http://w3id.org/sepses/resource/cwe/CWE-675> a cwe:CWE ;
    cwe:description "The product performs the same operation on a resource two or more times, when the operation should only be applied once." ;
    cwe:id "CWE-675" ;
    cwe:name "Multiple Operations on Resource in Single-Operation Context" .

<http://w3id.org/sepses/resource/cwe/CWE-676> a cwe:CWE ;
    cwe:description "The product invokes a potentially dangerous function that could introduce a vulnerability if it is used incorrectly, but the function can also be used safely." ;
    cwe:id "CWE-676" ;
    cwe:name "Use of Potentially Dangerous Function" .

<http://w3id.org/sepses/resource/cwe/CWE-680> a cwe:CWE ;
    cwe:description "The product performs a calculation to determine how much memory to allocate, but an integer overflow can occur that causes less memory to be allocated than expected, leading to a buffer overflow." ;
    cwe:id "CWE-680" ;
    cwe:name "Integer Overflow to Buffer Overflow" .

<http://w3id.org/sepses/resource/cwe/CWE-681> a cwe:CWE ;
    cwe:description "When converting from one data type to another, such as long to integer, data can be omitted or translated in a way that produces unexpected values. If the resulting values are used in a sensitive context, then dangerous behaviors may occur." ;
    cwe:id "CWE-681" ;
    cwe:name "Incorrect Conversion between Numeric Types" .

<http://w3id.org/sepses/resource/cwe/CWE-682> a cwe:CWE ;
    cwe:description "The product performs a calculation that generates incorrect or unintended results that are later used in security-critical decisions or resource management." ;
    cwe:id "CWE-682" ;
    cwe:name "Incorrect Calculation" .

<http://w3id.org/sepses/resource/cwe/CWE-683> a cwe:CWE ;
    cwe:description "The product calls a function, procedure, or routine, but the caller specifies the arguments in an incorrect order, leading to resultant weaknesses." ;
    cwe:id "CWE-683" ;
    cwe:name "Function Call With Incorrect Order of Arguments" .

<http://w3id.org/sepses/resource/cwe/CWE-684> a cwe:CWE ;
    cwe:description "The code does not function according to its published specifications, potentially leading to incorrect usage." ;
    cwe:id "CWE-684" ;
    cwe:name "Incorrect Provision of Specified Functionality" .

<http://w3id.org/sepses/resource/cwe/CWE-685> a cwe:CWE ;
    cwe:description "The product calls a function, procedure, or routine, but the caller specifies too many arguments, or too few arguments, which may lead to undefined behavior and resultant weaknesses." ;
    cwe:id "CWE-685" ;
    cwe:name "Function Call With Incorrect Number of Arguments" .

<http://w3id.org/sepses/resource/cwe/CWE-686> a cwe:CWE ;
    cwe:description "The product calls a function, procedure, or routine, but the caller specifies an argument that is the wrong data type, which may lead to resultant weaknesses." ;
    cwe:id "CWE-686" ;
    cwe:name "Function Call With Incorrect Argument Type" .

<http://w3id.org/sepses/resource/cwe/CWE-687> a cwe:CWE ;
    cwe:description "The product calls a function, procedure, or routine, but the caller specifies an argument that contains the wrong value, which may lead to resultant weaknesses." ;
    cwe:id "CWE-687" ;
    cwe:name "Function Call With Incorrectly Specified Argument Value" .

<http://w3id.org/sepses/resource/cwe/CWE-688> a cwe:CWE ;
    cwe:description "The product calls a function, procedure, or routine, but the caller specifies the wrong variable or reference as one of the arguments, which may lead to undefined behavior and resultant weaknesses." ;
    cwe:id "CWE-688" ;
    cwe:name "Function Call With Incorrect Variable or Reference as Argument" .

<http://w3id.org/sepses/resource/cwe/CWE-689> a cwe:CWE ;
    cwe:description "The product, while copying or cloning a resource, does not set the resource's permissions or access control until the copy is complete, leaving the resource exposed to other spheres while the copy is taking place." ;
    cwe:id "CWE-689" ;
    cwe:name "Permission Race Condition During Resource Copy" .

<http://w3id.org/sepses/resource/cwe/CWE-69> a cwe:CWE ;
    cwe:description "The product does not properly prevent access to, or detect usage of, alternate data streams (ADS)." ;
    cwe:id "CWE-69" ;
    cwe:name "Improper Handling of Windows ::DATA Alternate Data Stream" .

<http://w3id.org/sepses/resource/cwe/CWE-690> a cwe:CWE ;
    cwe:description "The product does not check for an error after calling a function that can return with a NULL pointer if the function fails, which leads to a resultant NULL pointer dereference." ;
    cwe:id "CWE-690" ;
    cwe:name "Unchecked Return Value to NULL Pointer Dereference" .

<http://w3id.org/sepses/resource/cwe/CWE-691> a cwe:CWE ;
    cwe:description "The code does not sufficiently manage its control flow during execution, creating conditions in which the control flow can be modified in unexpected ways." ;
    cwe:id "CWE-691" ;
    cwe:name "Insufficient Control Flow Management" .

<http://w3id.org/sepses/resource/cwe/CWE-692> a cwe:CWE ;
    cwe:description "The product uses a denylist-based protection mechanism to defend against XSS attacks, but the denylist is incomplete, allowing XSS variants to succeed." ;
    cwe:id "CWE-692" ;
    cwe:name "Incomplete Denylist to Cross-Site Scripting" .

<http://w3id.org/sepses/resource/cwe/CWE-693> a cwe:CWE ;
    cwe:description "The product does not use or incorrectly uses a protection mechanism that provides sufficient defense against directed attacks against the product." ;
    cwe:id "CWE-693" ;
    cwe:name "Protection Mechanism Failure" .

<http://w3id.org/sepses/resource/cwe/CWE-694> a cwe:CWE ;
    cwe:description "The product uses multiple resources that can have the same identifier, in a context in which unique identifiers are required." ;
    cwe:id "CWE-694" ;
    cwe:name "Use of Multiple Resources with Duplicate Identifier" .

<http://w3id.org/sepses/resource/cwe/CWE-695> a cwe:CWE ;
    cwe:description "The product uses low-level functionality that is explicitly prohibited by the framework or specification under which the product is supposed to operate." ;
    cwe:id "CWE-695" ;
    cwe:name "Use of Low-Level Functionality" .

<http://w3id.org/sepses/resource/cwe/CWE-696> a cwe:CWE ;
    cwe:description "The product performs multiple related behaviors, but the behaviors are performed in the wrong order in ways that may produce resultant weaknesses." ;
    cwe:id "CWE-696" ;
    cwe:name "Incorrect Behavior Order" .

<http://w3id.org/sepses/resource/cwe/CWE-697> a cwe:CWE ;
    cwe:description "The product compares two entities in a security-relevant context, but the comparison is incorrect." ;
    cwe:id "CWE-697" ;
    cwe:name "Incorrect Comparison" .

<http://w3id.org/sepses/resource/cwe/CWE-698> a cwe:CWE ;
    cwe:description "The web application sends a redirect to another location, but instead of exiting, it executes additional code." ;
    cwe:id "CWE-698" ;
    cwe:name "Execution After Redirect (EAR)" .

<http://w3id.org/sepses/resource/cwe/CWE-7> a cwe:CWE ;
    cwe:description "The default error page of a web application should not display sensitive information about the product." ;
    cwe:id "CWE-7" ;
    cwe:name "J2EE Misconfiguration: Missing Custom Error Page" .

<http://w3id.org/sepses/resource/cwe/CWE-703> a cwe:CWE ;
    cwe:description "The product does not properly anticipate or handle exceptional conditions that rarely occur during normal operation of the product." ;
    cwe:id "CWE-703" ;
    cwe:name "Improper Check or Handling of Exceptional Conditions" .

<http://w3id.org/sepses/resource/cwe/CWE-704> a cwe:CWE ;
    cwe:description "The product does not correctly convert an object, resource, or structure from one type to a different type." ;
    cwe:id "CWE-704" ;
    cwe:name "Incorrect Type Conversion or Cast" .

<http://w3id.org/sepses/resource/cwe/CWE-705> a cwe:CWE ;
    cwe:description "The product does not properly return control flow to the proper location after it has completed a task or detected an unusual condition." ;
    cwe:id "CWE-705" ;
    cwe:name "Incorrect Control Flow Scoping" .

<http://w3id.org/sepses/resource/cwe/CWE-706> a cwe:CWE ;
    cwe:description "The product uses a name or reference to access a resource, but the name/reference resolves to a resource that is outside of the intended control sphere." ;
    cwe:id "CWE-706" ;
    cwe:name "Use of Incorrectly-Resolved Name or Reference" .

<http://w3id.org/sepses/resource/cwe/CWE-707> a cwe:CWE ;
    cwe:description "The product does not ensure or incorrectly ensures that structured messages or data are well-formed and that certain security properties are met before being read from an upstream component or sent to a downstream component." ;
    cwe:id "CWE-707" ;
    cwe:name "Improper Neutralization" .

<http://w3id.org/sepses/resource/cwe/CWE-708> a cwe:CWE ;
    cwe:description "The product assigns an owner to a resource, but the owner is outside of the intended control sphere." ;
    cwe:id "CWE-708" ;
    cwe:name "Incorrect Ownership Assignment" .

<http://w3id.org/sepses/resource/cwe/CWE-71> a cwe:CWE ;
    cwe:description "This entry has been deprecated as it represents a specific observed example of a UNIX Hard Link weakness type rather than its own individual weakness type. Please refer to CWE-62." ;
    cwe:id "CWE-71" ;
    cwe:name "DEPRECATED: Apple '.DS_Store'" .

<http://w3id.org/sepses/resource/cwe/CWE-710> a cwe:CWE ;
    cwe:description "The product does not follow certain coding rules for development, which can lead to resultant weaknesses or increase the severity of the associated vulnerabilities." ;
    cwe:id "CWE-710" ;
    cwe:name "Improper Adherence to Coding Standards" .

<http://w3id.org/sepses/resource/cwe/CWE-72> a cwe:CWE ;
    cwe:description "The product does not properly handle special paths that may identify the data or resource fork of a file on the HFS+ file system." ;
    cwe:id "CWE-72" ;
    cwe:name "Improper Handling of Apple HFS+ Alternate Data Stream Path" .

<http://w3id.org/sepses/resource/cwe/CWE-73> a cwe:CWE ;
    cwe:description "The product allows user input to control or influence paths or file names that are used in filesystem operations." ;
    cwe:id "CWE-73" ;
    cwe:name "External Control of File Name or Path" .

<http://w3id.org/sepses/resource/cwe/CWE-732> a cwe:CWE ;
    cwe:description "The product specifies permissions for a security-critical resource in a way that allows that resource to be read or modified by unintended actors." ;
    cwe:id "CWE-732" ;
    cwe:name "Incorrect Permission Assignment for Critical Resource" .

<http://w3id.org/sepses/resource/cwe/CWE-733> a cwe:CWE ;
    cwe:description "The developer builds a security-critical protection mechanism into the software, but the compiler optimizes the program such that the mechanism is removed or modified." ;
    cwe:id "CWE-733" ;
    cwe:name "Compiler Optimization Removal or Modification of Security-critical Code" .

<http://w3id.org/sepses/resource/cwe/CWE-74> a cwe:CWE ;
    cwe:description "The product constructs all or part of a command, data structure, or record using externally-influenced input from an upstream component, but it does not neutralize or incorrectly neutralizes special elements that could modify how it is parsed or interpreted when it is sent to a downstream component." ;
    cwe:id "CWE-74" ;
    cwe:name "Improper Neutralization of Special Elements in Output Used by a Downstream Component ('Injection')" .

<http://w3id.org/sepses/resource/cwe/CWE-749> a cwe:CWE ;
    cwe:description "The product provides an Applications Programming Interface (API) or similar interface for interaction with external actors, but the interface includes a dangerous method or function that is not properly restricted." ;
    cwe:id "CWE-749" ;
    cwe:name "Exposed Dangerous Method or Function" .

<http://w3id.org/sepses/resource/cwe/CWE-75> a cwe:CWE ;
    cwe:description "The product does not adequately filter user-controlled input for special elements with control implications." ;
    cwe:id "CWE-75" ;
    cwe:name "Failure to Sanitize Special Elements into a Different Plane (Special Element Injection)" .

<http://w3id.org/sepses/resource/cwe/CWE-754> a cwe:CWE ;
    cwe:description "The product does not check or incorrectly checks for unusual or exceptional conditions that are not expected to occur frequently during day to day operation of the product." ;
    cwe:id "CWE-754" ;
    cwe:name "Improper Check for Unusual or Exceptional Conditions" .

<http://w3id.org/sepses/resource/cwe/CWE-755> a cwe:CWE ;
    cwe:description "The product does not handle or incorrectly handles an exceptional condition." ;
    cwe:id "CWE-755" ;
    cwe:name "Improper Handling of Exceptional Conditions" .

<http://w3id.org/sepses/resource/cwe/CWE-756> a cwe:CWE ;
    cwe:description "The product does not return custom error pages to the user, possibly exposing sensitive information." ;
    cwe:id "CWE-756" ;
    cwe:name "Missing Custom Error Page" .

<http://w3id.org/sepses/resource/cwe/CWE-757> a cwe:CWE ;
    cwe:description "A protocol or its implementation supports interaction between multiple actors and allows those actors to negotiate which algorithm should be used as a protection mechanism such as encryption or authentication, but it does not select the strongest algorithm that is available to both parties." ;
    cwe:id "CWE-757" ;
    cwe:name "Selection of Less-Secure Algorithm During Negotiation ('Algorithm Downgrade')" .

<http://w3id.org/sepses/resource/cwe/CWE-758> a cwe:CWE ;
    cwe:description "The product uses an API function, data structure, or other entity in a way that relies on properties that are not always guaranteed to hold for that entity." ;
    cwe:id "CWE-758" ;
    cwe:name "Reliance on Undefined, Unspecified, or Implementation-Defined Behavior" .

<http://w3id.org/sepses/resource/cwe/CWE-759> a cwe:CWE ;
    cwe:description "The product uses a one-way cryptographic hash against an input that should not be reversible, such as a password, but the product does not also use a salt as part of the input." ;
    cwe:id "CWE-759" ;
    cwe:name "Use of a One-Way Hash without a Salt" .

<http://w3id.org/sepses/resource/cwe/CWE-76> a cwe:CWE ;
    cwe:description "The product correctly neutralizes certain special elements, but it improperly neutralizes equivalent special elements." ;
    cwe:id "CWE-76" ;
    cwe:name "Improper Neutralization of Equivalent Special Elements" .

<http://w3id.org/sepses/resource/cwe/CWE-760> a cwe:CWE ;
    cwe:description "The product uses a one-way cryptographic hash against an input that should not be reversible, such as a password, but the product uses a predictable salt as part of the input." ;
    cwe:id "CWE-760" ;
    cwe:name "Use of a One-Way Hash with a Predictable Salt" .

<http://w3id.org/sepses/resource/cwe/CWE-761> a cwe:CWE ;
    cwe:description "The product calls free() on a pointer to a memory resource that was allocated on the heap, but the pointer is not at the start of the buffer." ;
    cwe:id "CWE-761" ;
    cwe:name "Free of Pointer not at Start of Buffer" .

<http://w3id.org/sepses/resource/cwe/CWE-762> a cwe:CWE ;
    cwe:description "The product attempts to return a memory resource to the system, but it calls a release function that is not compatible with the function that was originally used to allocate that resource." ;
    cwe:id "CWE-762" ;
    cwe:name "Mismatched Memory Management Routines" .

<http://w3id.org/sepses/resource/cwe/CWE-763> a cwe:CWE ;
    cwe:description "The product attempts to return a memory resource to the system, but it calls the wrong release function or calls the appropriate release function incorrectly." ;
    cwe:id "CWE-763" ;
    cwe:name "Release of Invalid Pointer or Reference" .

<http://w3id.org/sepses/resource/cwe/CWE-764> a cwe:CWE ;
    cwe:description "The product locks a critical resource more times than intended, leading to an unexpected state in the system." ;
    cwe:id "CWE-764" ;
    cwe:name "Multiple Locks of a Critical Resource" .

<http://w3id.org/sepses/resource/cwe/CWE-765> a cwe:CWE ;
    cwe:description "The product unlocks a critical resource more times than intended, leading to an unexpected state in the system." ;
    cwe:id "CWE-765" ;
    cwe:name "Multiple Unlocks of a Critical Resource" .

<http://w3id.org/sepses/resource/cwe/CWE-766> a cwe:CWE ;
    cwe:description "The product declares a critical variable, field, or member to be public when intended security policy requires it to be private." ;
    cwe:id "CWE-766" ;
    cwe:name "Critical Data Element Declared Public" .

<http://w3id.org/sepses/resource/cwe/CWE-767> a cwe:CWE ;
    cwe:description "The product defines a public method that reads or modifies a private variable." ;
    cwe:id "CWE-767" ;
    cwe:name "Access to Critical Private Variable via Public Method" .

<http://w3id.org/sepses/resource/cwe/CWE-768> a cwe:CWE ;
    cwe:description "The product contains a conditional statement with multiple logical expressions in which one of the non-leading expressions may produce side effects. This may lead to an unexpected state in the program after the execution of the conditional, because short-circuiting logic may prevent the side effects from occurring." ;
    cwe:id "CWE-768" ;
    cwe:name "Incorrect Short Circuit Evaluation" .

<http://w3id.org/sepses/resource/cwe/CWE-769> a cwe:CWE ;
    cwe:description "This entry has been deprecated because it was a duplicate of CWE-774. All content has been transferred to CWE-774." ;
    cwe:id "CWE-769" ;
    cwe:name "DEPRECATED: Uncontrolled File Descriptor Consumption" .

<http://w3id.org/sepses/resource/cwe/CWE-77> a cwe:CWE ;
    cwe:description "The product constructs all or part of a command using externally-influenced input from an upstream component, but it does not neutralize or incorrectly neutralizes special elements that could modify the intended command when it is sent to a downstream component." ;
    cwe:id "CWE-77" ;
    cwe:name "Improper Neutralization of Special Elements used in a Command ('Command Injection')" .

<http://w3id.org/sepses/resource/cwe/CWE-770> a cwe:CWE ;
    cwe:description "The product allocates a reusable resource or group of resources on behalf of an actor without imposing any intended restrictions on the size or number of resources that can be allocated." ;
    cwe:id "CWE-770" ;
    cwe:name "Allocation of Resources Without Limits or Throttling" .

<http://w3id.org/sepses/resource/cwe/CWE-771> a cwe:CWE ;
    cwe:description "The product does not properly maintain a reference to a resource that has been allocated, which prevents the resource from being reclaimed." ;
    cwe:id "CWE-771" ;
    cwe:name "Missing Reference to Active Allocated Resource" .

<http://w3id.org/sepses/resource/cwe/CWE-772> a cwe:CWE ;
    cwe:description "The product does not release a resource after its effective lifetime has ended, i.e., after the resource is no longer needed." ;
    cwe:id "CWE-772" ;
    cwe:name "Missing Release of Resource after Effective Lifetime" .

<http://w3id.org/sepses/resource/cwe/CWE-773> a cwe:CWE ;
    cwe:description "The product does not properly maintain references to a file descriptor or handle, which prevents that file descriptor/handle from being reclaimed." ;
    cwe:id "CWE-773" ;
    cwe:name "Missing Reference to Active File Descriptor or Handle" .

<http://w3id.org/sepses/resource/cwe/CWE-774> a cwe:CWE ;
    cwe:description "The product allocates file descriptors or handles on behalf of an actor without imposing any restrictions on how many descriptors can be allocated, in violation of the intended security policy for that actor." ;
    cwe:id "CWE-774" ;
    cwe:name "Allocation of File Descriptors or Handles Without Limits or Throttling" .

<http://w3id.org/sepses/resource/cwe/CWE-775> a cwe:CWE ;
    cwe:description "The product does not release a file descriptor or handle after its effective lifetime has ended, i.e., after the file descriptor/handle is no longer needed." ;
    cwe:id "CWE-775" ;
    cwe:name "Missing Release of File Descriptor or Handle after Effective Lifetime" .

<http://w3id.org/sepses/resource/cwe/CWE-776> a cwe:CWE ;
    cwe:description "The product uses XML documents and allows their structure to be defined with a Document Type Definition (DTD), but it does not properly control the number of recursive definitions of entities." ;
    cwe:id "CWE-776" ;
    cwe:name "Improper Restriction of Recursive Entity References in DTDs ('XML Entity Expansion')" .

<http://w3id.org/sepses/resource/cwe/CWE-777> a cwe:CWE ;
    cwe:description "The product uses a regular expression to perform neutralization, but the regular expression is not anchored and may allow malicious or malformed data to slip through." ;
    cwe:id "CWE-777" ;
    cwe:name "Regular Expression without Anchors" .

<http://w3id.org/sepses/resource/cwe/CWE-778> a cwe:CWE ;
    cwe:description "When a security-critical event occurs, the product either does not record the event or omits important details about the event when logging it." ;
    cwe:id "CWE-778" ;
    cwe:name "Insufficient Logging" .

<http://w3id.org/sepses/resource/cwe/CWE-779> a cwe:CWE ;
    cwe:description "The product logs too much information, making log files hard to process and possibly hindering recovery efforts or forensic analysis after an attack." ;
    cwe:id "CWE-779" ;
    cwe:name "Logging of Excessive Data" .

<http://w3id.org/sepses/resource/cwe/CWE-78> a cwe:CWE ;
    cwe:description "The product constructs all or part of an OS command using externally-influenced input from an upstream component, but it does not neutralize or incorrectly neutralizes special elements that could modify the intended OS command when it is sent to a downstream component." ;
    cwe:id "CWE-78" ;
    cwe:name "Improper Neutralization of Special Elements used in an OS Command ('OS Command Injection')" .

<http://w3id.org/sepses/resource/cwe/CWE-780> a cwe:CWE ;
    cwe:description "The product uses the RSA algorithm but does not incorporate Optimal Asymmetric Encryption Padding (OAEP), which might weaken the encryption." ;
    cwe:id "CWE-780" ;
    cwe:name "Use of RSA Algorithm without OAEP" .

<http://w3id.org/sepses/resource/cwe/CWE-781> a cwe:CWE ;
    cwe:description "The product defines an IOCTL that uses METHOD_NEITHER for I/O, but it does not validate or incorrectly validates the addresses that are provided." ;
    cwe:id "CWE-781" ;
    cwe:name "Improper Address Validation in IOCTL with METHOD_NEITHER I/O Control Code" .

<http://w3id.org/sepses/resource/cwe/CWE-782> a cwe:CWE ;
    cwe:description "The product implements an IOCTL with functionality that should be restricted, but it does not properly enforce access control for the IOCTL." ;
    cwe:id "CWE-782" ;
    cwe:name "Exposed IOCTL with Insufficient Access Control" .

<http://w3id.org/sepses/resource/cwe/CWE-783> a cwe:CWE ;
    cwe:description "The product uses an expression in which operator precedence causes incorrect logic to be used." ;
    cwe:id "CWE-783" ;
    cwe:name "Operator Precedence Logic Error" .

<http://w3id.org/sepses/resource/cwe/CWE-784> a cwe:CWE ;
    cwe:description "The product uses a protection mechanism that relies on the existence or values of a cookie, but it does not properly ensure that the cookie is valid for the associated user." ;
    cwe:id "CWE-784" ;
    cwe:name "Reliance on Cookies without Validation and Integrity Checking in a Security Decision" .

<http://w3id.org/sepses/resource/cwe/CWE-785> a cwe:CWE ;
    cwe:description "The product invokes a function for normalizing paths or file names, but it provides an output buffer that is smaller than the maximum possible size, such as PATH_MAX." ;
    cwe:id "CWE-785" ;
    cwe:name "Use of Path Manipulation Function without Maximum-sized Buffer" .

<http://w3id.org/sepses/resource/cwe/CWE-786> a cwe:CWE ;
    cwe:description "The product reads or writes to a buffer using an index or pointer that references a memory location prior to the beginning of the buffer." ;
    cwe:id "CWE-786" ;
    cwe:name "Access of Memory Location Before Start of Buffer" .

<http://w3id.org/sepses/resource/cwe/CWE-787> a cwe:CWE ;
    cwe:description "The product writes data past the end, or before the beginning, of the intended buffer." ;
    cwe:id "CWE-787" ;
    cwe:name "Out-of-bounds Write" .

<http://w3id.org/sepses/resource/cwe/CWE-788> a cwe:CWE ;
    cwe:description "The product reads or writes to a buffer using an index or pointer that references a memory location after the end of the buffer." ;
    cwe:id "CWE-788" ;
    cwe:name "Access of Memory Location After End of Buffer" .

<http://w3id.org/sepses/resource/cwe/CWE-789> a cwe:CWE ;
    cwe:description "The product allocates memory based on an untrusted, large size value, but it does not ensure that the size is within expected limits, allowing arbitrary amounts of memory to be allocated." ;
    cwe:id "CWE-789" ;
    cwe:name "Memory Allocation with Excessive Size Value" .

<http://w3id.org/sepses/resource/cwe/CWE-79> a cwe:CWE ;
    cwe:description "The product does not neutralize or incorrectly neutralizes user-controllable input before it is placed in output that is used as a web page that is served to other users." ;
    cwe:id "CWE-79" ;
    cwe:name "Improper Neutralization of Input During Web Page Generation ('Cross-site Scripting')" .

<http://w3id.org/sepses/resource/cwe/CWE-790> a cwe:CWE ;
    cwe:description "The product receives data from an upstream component, but does not filter or incorrectly filters special elements before sending it to a downstream component." ;
    cwe:id "CWE-790" ;
    cwe:name "Improper Filtering of Special Elements" .

<http://w3id.org/sepses/resource/cwe/CWE-791> a cwe:CWE ;
    cwe:description "The product receives data from an upstream component, but does not completely filter special elements before sending it to a downstream component." ;
    cwe:id "CWE-791" ;
    cwe:name "Incomplete Filtering of Special Elements" .

<http://w3id.org/sepses/resource/cwe/CWE-792> a cwe:CWE ;
    cwe:description "The product receives data from an upstream component, but does not completely filter one or more instances of special elements before sending it to a downstream component." ;
    cwe:id "CWE-792" ;
    cwe:name "Incomplete Filtering of One or More Instances of Special Elements" .

<http://w3id.org/sepses/resource/cwe/CWE-793> a cwe:CWE ;
    cwe:description "The product receives data from an upstream component, but only filters a single instance of a special element before sending it to a downstream component." ;
    cwe:id "CWE-793" ;
    cwe:name "Only Filtering One Instance of a Special Element" .

<http://w3id.org/sepses/resource/cwe/CWE-794> a cwe:CWE ;
    cwe:description "The product receives data from an upstream component, but does not filter all instances of a special element before sending it to a downstream component." ;
    cwe:id "CWE-794" ;
    cwe:name "Incomplete Filtering of Multiple Instances of Special Elements" .

<http://w3id.org/sepses/resource/cwe/CWE-795> a cwe:CWE ;
    cwe:description "The product receives data from an upstream component, but only accounts for special elements at a specified location, thereby missing remaining special elements that may exist before sending it to a downstream component." ;
    cwe:id "CWE-795" ;
    cwe:name "Only Filtering Special Elements at a Specified Location" .

<http://w3id.org/sepses/resource/cwe/CWE-796> a cwe:CWE ;
    cwe:description "The product receives data from an upstream component, but only accounts for special elements positioned relative to a marker (e.g. \"at the beginning/end of a string; the second argument\"), thereby missing remaining special elements that may exist before sending it to a downstream component." ;
    cwe:id "CWE-796" ;
    cwe:name "Only Filtering Special Elements Relative to a Marker" .

<http://w3id.org/sepses/resource/cwe/CWE-797> a cwe:CWE ;
    cwe:description "The product receives data from an upstream component, but only accounts for special elements at an absolute position (e.g. \"byte number 10\"), thereby missing remaining special elements that may exist before sending it to a downstream component." ;
    cwe:id "CWE-797" ;
    cwe:name "Only Filtering Special Elements at an Absolute Position" .

<http://w3id.org/sepses/resource/cwe/CWE-798> a cwe:CWE ;
    cwe:description "The product contains hard-coded credentials, such as a password or cryptographic key." ;
    cwe:id "CWE-798" ;
    cwe:name "Use of Hard-coded Credentials" .

<http://w3id.org/sepses/resource/cwe/CWE-799> a cwe:CWE ;
    cwe:description "The product does not properly limit the number or frequency of interactions that it has with an actor, such as the number of incoming requests." ;
    cwe:id "CWE-799" ;
    cwe:name "Improper Control of Interaction Frequency" .

<http://w3id.org/sepses/resource/cwe/CWE-8> a cwe:CWE ;
    cwe:description "When an application exposes a remote interface for an entity bean, it might also expose methods that get or set the bean's data. These methods could be leveraged to read sensitive information, or to change data in ways that violate the application's expectations, potentially leading to other vulnerabilities." ;
    cwe:id "CWE-8" ;
    cwe:name "J2EE Misconfiguration: Entity Bean Declared Remote" .

<http://w3id.org/sepses/resource/cwe/CWE-80> a cwe:CWE ;
    cwe:description "The product receives input from an upstream component, but it does not neutralize or incorrectly neutralizes special characters such as \"<\", \">\", and \"&\" that could be interpreted as web-scripting elements when they are sent to a downstream component that processes web pages." ;
    cwe:id "CWE-80" ;
    cwe:name "Improper Neutralization of Script-Related HTML Tags in a Web Page (Basic XSS)" .

<http://w3id.org/sepses/resource/cwe/CWE-804> a cwe:CWE ;
    cwe:description "The product uses a CAPTCHA challenge, but the challenge can be guessed or automatically recognized by a non-human actor." ;
    cwe:id "CWE-804" ;
    cwe:name "Guessable CAPTCHA" .

<http://w3id.org/sepses/resource/cwe/CWE-805> a cwe:CWE ;
    cwe:description "The product uses a sequential operation to read or write a buffer, but it uses an incorrect length value that causes it to access memory that is outside of the bounds of the buffer." ;
    cwe:id "CWE-805" ;
    cwe:name "Buffer Access with Incorrect Length Value" .

<http://w3id.org/sepses/resource/cwe/CWE-806> a cwe:CWE ;
    cwe:description "The product uses the size of a source buffer when reading from or writing to a destination buffer, which may cause it to access memory that is outside of the bounds of the buffer." ;
    cwe:id "CWE-806" ;
    cwe:name "Buffer Access Using Size of Source Buffer" .

<http://w3id.org/sepses/resource/cwe/CWE-807> a cwe:CWE ;
    cwe:description "The product uses a protection mechanism that relies on the existence or values of an input, but the input can be modified by an untrusted actor in a way that bypasses the protection mechanism." ;
    cwe:id "CWE-807" ;
    cwe:name "Reliance on Untrusted Inputs in a Security Decision" .

<http://w3id.org/sepses/resource/cwe/CWE-81> a cwe:CWE ;
    cwe:description "The product receives input from an upstream component, but it does not neutralize or incorrectly neutralizes special characters that could be interpreted as web-scripting elements when they are sent to an error page." ;
    cwe:id "CWE-81" ;
    cwe:name "Improper Neutralization of Script in an Error Message Web Page" .

<http://w3id.org/sepses/resource/cwe/CWE-82> a cwe:CWE ;
    cwe:description "The web application does not neutralize or incorrectly neutralizes scripting elements within attributes of HTML IMG tags, such as the src attribute." ;
    cwe:id "CWE-82" ;
    cwe:name "Improper Neutralization of Script in Attributes of IMG Tags in a Web Page" .

<http://w3id.org/sepses/resource/cwe/CWE-820> a cwe:CWE ;
    cwe:description "The product utilizes a shared resource in a concurrent manner but does not attempt to synchronize access to the resource." ;
    cwe:id "CWE-820" ;
    cwe:name "Missing Synchronization" .

<http://w3id.org/sepses/resource/cwe/CWE-821> a cwe:CWE ;
    cwe:description "The product utilizes a shared resource in a concurrent manner, but it does not correctly synchronize access to the resource." ;
    cwe:id "CWE-821" ;
    cwe:name "Incorrect Synchronization" .

<http://w3id.org/sepses/resource/cwe/CWE-822> a cwe:CWE ;
    cwe:description "The product obtains a value from an untrusted source, converts this value to a pointer, and dereferences the resulting pointer." ;
    cwe:id "CWE-822" ;
    cwe:name "Untrusted Pointer Dereference" .

<http://w3id.org/sepses/resource/cwe/CWE-823> a cwe:CWE ;
    cwe:description "The product performs pointer arithmetic on a valid pointer, but it uses an offset that can point outside of the intended range of valid memory locations for the resulting pointer." ;
    cwe:id "CWE-823" ;
    cwe:name "Use of Out-of-range Pointer Offset" .

<http://w3id.org/sepses/resource/cwe/CWE-824> a cwe:CWE ;
    cwe:description "The product accesses or uses a pointer that has not been initialized." ;
    cwe:id "CWE-824" ;
    cwe:name "Access of Uninitialized Pointer" .

<http://w3id.org/sepses/resource/cwe/CWE-825> a cwe:CWE ;
    cwe:description "The product dereferences a pointer that contains a location for memory that was previously valid, but is no longer valid." ;
    cwe:id "CWE-825" ;
    cwe:name "Expired Pointer Dereference" .

<http://w3id.org/sepses/resource/cwe/CWE-826> a cwe:CWE ;
    cwe:description "The product releases a resource that is still intended to be used by itself or another actor." ;
    cwe:id "CWE-826" ;
    cwe:name "Premature Release of Resource During Expected Lifetime" .

<http://w3id.org/sepses/resource/cwe/CWE-827> a cwe:CWE ;
    cwe:description "The product does not restrict a reference to a Document Type Definition (DTD) to the intended control sphere. This might allow attackers to reference arbitrary DTDs, possibly causing the product to expose files, consume excessive system resources, or execute arbitrary http requests on behalf of the attacker." ;
    cwe:id "CWE-827" ;
    cwe:name "Improper Control of Document Type Definition" .

<http://w3id.org/sepses/resource/cwe/CWE-828> a cwe:CWE ;
    cwe:description "The product defines a signal handler that contains code sequences that are not asynchronous-safe, i.e., the functionality is not reentrant, or it can be interrupted." ;
    cwe:id "CWE-828" ;
    cwe:name "Signal Handler with Functionality that is not Asynchronous-Safe" .

<http://w3id.org/sepses/resource/cwe/CWE-829> a cwe:CWE ;
    cwe:description "The product imports, requires, or includes executable functionality (such as a library) from a source that is outside of the intended control sphere." ;
    cwe:id "CWE-829" ;
    cwe:name "Inclusion of Functionality from Untrusted Control Sphere" .

<http://w3id.org/sepses/resource/cwe/CWE-83> a cwe:CWE ;
    cwe:description "The product does not neutralize or incorrectly neutralizes \"javascript:\" or other URIs from dangerous attributes within tags, such as onmouseover, onload, onerror, or style." ;
    cwe:id "CWE-83" ;
    cwe:name "Improper Neutralization of Script in Attributes in a Web Page" .

<http://w3id.org/sepses/resource/cwe/CWE-830> a cwe:CWE ;
    cwe:description "The product includes web functionality (such as a web widget) from another domain, which causes it to operate within the domain of the product, potentially granting total access and control of the product to the untrusted source." ;
    cwe:id "CWE-830" ;
    cwe:name "Inclusion of Web Functionality from an Untrusted Source" .

<http://w3id.org/sepses/resource/cwe/CWE-831> a cwe:CWE ;
    cwe:description "The product defines a function that is used as a handler for more than one signal." ;
    cwe:id "CWE-831" ;
    cwe:name "Signal Handler Function Associated with Multiple Signals" .

<http://w3id.org/sepses/resource/cwe/CWE-832> a cwe:CWE ;
    cwe:description "The product attempts to unlock a resource that is not locked." ;
    cwe:id "CWE-832" ;
    cwe:name "Unlock of a Resource that is not Locked" .

<http://w3id.org/sepses/resource/cwe/CWE-833> a cwe:CWE ;
    cwe:description "The product contains multiple threads or executable segments that are waiting for each other to release a necessary lock, resulting in deadlock." ;
    cwe:id "CWE-833" ;
    cwe:name "Deadlock" .

<http://w3id.org/sepses/resource/cwe/CWE-834> a cwe:CWE ;
    cwe:description "The product performs an iteration or loop without sufficiently limiting the number of times that the loop is executed." ;
    cwe:id "CWE-834" ;
    cwe:name "Excessive Iteration" .

<http://w3id.org/sepses/resource/cwe/CWE-835> a cwe:CWE ;
    cwe:description "The product contains an iteration or loop with an exit condition that cannot be reached, i.e., an infinite loop." ;
    cwe:id "CWE-835" ;
    cwe:name "Loop with Unreachable Exit Condition ('Infinite Loop')" .

<http://w3id.org/sepses/resource/cwe/CWE-836> a cwe:CWE ;
    cwe:description "The product records password hashes in a data store, receives a hash of a password from a client, and compares the supplied hash to the hash obtained from the data store." ;
    cwe:id "CWE-836" ;
    cwe:name "Use of Password Hash Instead of Password for Authentication" .

<http://w3id.org/sepses/resource/cwe/CWE-837> a cwe:CWE ;
    cwe:description "The product requires that an actor should only be able to perform an action once, or to have only one unique action, but the product does not enforce or improperly enforces this restriction." ;
    cwe:id "CWE-837" ;
    cwe:name "Improper Enforcement of a Single, Unique Action" .

<http://w3id.org/sepses/resource/cwe/CWE-838> a cwe:CWE ;
    cwe:description "The product uses or specifies an encoding when generating output to a downstream component, but the specified encoding is not the same as the encoding that is expected by the downstream component." ;
    cwe:id "CWE-838" ;
    cwe:name "Inappropriate Encoding for Output Context" .

<http://w3id.org/sepses/resource/cwe/CWE-839> a cwe:CWE ;
    cwe:description "The product checks a value to ensure that it is less than or equal to a maximum, but it does not also verify that the value is greater than or equal to the minimum." ;
    cwe:id "CWE-839" ;
    cwe:name "Numeric Range Comparison Without Minimum Check" .

<http://w3id.org/sepses/resource/cwe/CWE-84> a cwe:CWE ;
    cwe:description "The web application improperly neutralizes user-controlled input for executable script disguised with URI encodings." ;
    cwe:id "CWE-84" ;
    cwe:name "Improper Neutralization of Encoded URI Schemes in a Web Page" .

<http://w3id.org/sepses/resource/cwe/CWE-841> a cwe:CWE ;
    cwe:description "The product supports a session in which more than one behavior must be performed by an actor, but it does not properly ensure that the actor performs the behaviors in the required sequence." ;
    cwe:id "CWE-841" ;
    cwe:name "Improper Enforcement of Behavioral Workflow" .

<http://w3id.org/sepses/resource/cwe/CWE-842> a cwe:CWE ;
    cwe:description "The product or the administrator places a user into an incorrect group." ;
    cwe:id "CWE-842" ;
    cwe:name "Placement of User into Incorrect Group" .

<http://w3id.org/sepses/resource/cwe/CWE-843> a cwe:CWE ;
    cwe:description "The product allocates or initializes a resource such as a pointer, object, or variable using one type, but it later accesses that resource using a type that is incompatible with the original type." ;
    cwe:id "CWE-843" ;
    cwe:name "Access of Resource Using Incompatible Type ('Type Confusion')" .

<http://w3id.org/sepses/resource/cwe/CWE-85> a cwe:CWE ;
    cwe:description "The web application does not filter user-controlled input for executable script disguised using doubling of the involved characters." ;
    cwe:id "CWE-85" ;
    cwe:name "Doubled Character XSS Manipulations" .

<http://w3id.org/sepses/resource/cwe/CWE-86> a cwe:CWE ;
    cwe:description "The product does not neutralize or incorrectly neutralizes invalid characters or byte sequences in the middle of tag names, URI schemes, and other identifiers." ;
    cwe:id "CWE-86" ;
    cwe:name "Improper Neutralization of Invalid Characters in Identifiers in Web Pages" .

<http://w3id.org/sepses/resource/cwe/CWE-862> a cwe:CWE ;
    cwe:description "The product does not perform an authorization check when an actor attempts to access a resource or perform an action." ;
    cwe:id "CWE-862" ;
    cwe:name "Missing Authorization" .

<http://w3id.org/sepses/resource/cwe/CWE-863> a cwe:CWE ;
    cwe:description "The product performs an authorization check when an actor attempts to access a resource or perform an action, but it does not correctly perform the check." ;
    cwe:id "CWE-863" ;
    cwe:name "Incorrect Authorization" .

<http://w3id.org/sepses/resource/cwe/CWE-87> a cwe:CWE ;
    cwe:description "The product does not neutralize or incorrectly neutralizes user-controlled input for alternate script syntax." ;
    cwe:id "CWE-87" ;
    cwe:name "Improper Neutralization of Alternate XSS Syntax" .

<http://w3id.org/sepses/resource/cwe/CWE-88> a cwe:CWE ;
    cwe:description """The product constructs a string for a command to be executed by a separate component
in another control sphere, but it does not properly delimit the
intended arguments, options, or switches within that command string.""" ;
    cwe:id "CWE-88" ;
    cwe:name "Improper Neutralization of Argument Delimiters in a Command ('Argument Injection')" .

<http://w3id.org/sepses/resource/cwe/CWE-89> a cwe:CWE ;
    cwe:description "The product constructs all or part of an SQL command using externally-influenced input from an upstream component, but it does not neutralize or incorrectly neutralizes special elements that could modify the intended SQL command when it is sent to a downstream component. Without sufficient removal or quoting of SQL syntax in user-controllable inputs, the generated SQL query can cause those inputs to be interpreted as SQL instead of ordinary user data." ;
    cwe:id "CWE-89" ;
    cwe:name "Improper Neutralization of Special Elements used in an SQL Command ('SQL Injection')" .

<http://w3id.org/sepses/resource/cwe/CWE-9> a cwe:CWE ;
    cwe:description "If elevated access rights are assigned to EJB methods, then an attacker can take advantage of the permissions to exploit the product." ;
    cwe:id "CWE-9" ;
    cwe:name "J2EE Misconfiguration: Weak Access Permissions for EJB Methods" .

<http://w3id.org/sepses/resource/cwe/CWE-90> a cwe:CWE ;
    cwe:description "The product constructs all or part of an LDAP query using externally-influenced input from an upstream component, but it does not neutralize or incorrectly neutralizes special elements that could modify the intended LDAP query when it is sent to a downstream component." ;
    cwe:id "CWE-90" ;
    cwe:name "Improper Neutralization of Special Elements used in an LDAP Query ('LDAP Injection')" .

<http://w3id.org/sepses/resource/cwe/CWE-908> a cwe:CWE ;
    cwe:description "The product uses or accesses a resource that has not been initialized." ;
    cwe:id "CWE-908" ;
    cwe:name "Use of Uninitialized Resource" .

<http://w3id.org/sepses/resource/cwe/CWE-909> a cwe:CWE ;
    cwe:description "The product does not initialize a critical resource." ;
    cwe:id "CWE-909" ;
    cwe:name "Missing Initialization of Resource" .

<http://w3id.org/sepses/resource/cwe/CWE-91> a cwe:CWE ;
    cwe:description "The product does not properly neutralize special elements that are used in XML, allowing attackers to modify the syntax, content, or commands of the XML before it is processed by an end system." ;
    cwe:id "CWE-91" ;
    cwe:name "XML Injection (aka Blind XPath Injection)" .

<http://w3id.org/sepses/resource/cwe/CWE-910> a cwe:CWE ;
    cwe:description "The product uses or accesses a file descriptor after it has been closed." ;
    cwe:id "CWE-910" ;
    cwe:name "Use of Expired File Descriptor" .

<http://w3id.org/sepses/resource/cwe/CWE-911> a cwe:CWE ;
    cwe:description "The product uses a reference count to manage a resource, but it does not update or incorrectly updates the reference count." ;
    cwe:id "CWE-911" ;
    cwe:name "Improper Update of Reference Count" .

<http://w3id.org/sepses/resource/cwe/CWE-912> a cwe:CWE ;
    cwe:description "The product contains functionality that is not documented, not part of the specification, and not accessible through an interface or command sequence that is obvious to the product's users or administrators." ;
    cwe:id "CWE-912" ;
    cwe:name "Hidden Functionality" .

<http://w3id.org/sepses/resource/cwe/CWE-913> a cwe:CWE ;
    cwe:description "The product does not properly restrict reading from or writing to dynamically-managed code resources such as variables, objects, classes, attributes, functions, or executable instructions or statements." ;
    cwe:id "CWE-913" ;
    cwe:name "Improper Control of Dynamically-Managed Code Resources" .

<http://w3id.org/sepses/resource/cwe/CWE-914> a cwe:CWE ;
    cwe:description "The product does not properly restrict reading from or writing to dynamically-identified variables." ;
    cwe:id "CWE-914" ;
    cwe:name "Improper Control of Dynamically-Identified Variables" .

<http://w3id.org/sepses/resource/cwe/CWE-915> a cwe:CWE ;
    cwe:description "The product receives input from an upstream component that specifies multiple attributes, properties, or fields that are to be initialized or updated in an object, but it does not properly control which attributes can be modified." ;
    cwe:id "CWE-915" ;
    cwe:name "Improperly Controlled Modification of Dynamically-Determined Object Attributes" .

<http://w3id.org/sepses/resource/cwe/CWE-916> a cwe:CWE ;
    cwe:description "The product generates a hash for a password, but it uses a scheme that does not provide a sufficient level of computational effort that would make password cracking attacks infeasible or expensive." ;
    cwe:id "CWE-916" ;
    cwe:name "Use of Password Hash With Insufficient Computational Effort" .

<http://w3id.org/sepses/resource/cwe/CWE-917> a cwe:CWE ;
    cwe:description "The product constructs all or part of an expression language (EL) statement in a framework such as a Java Server Page (JSP) using externally-influenced input from an upstream component, but it does not neutralize or incorrectly neutralizes special elements that could modify the intended EL statement before it is executed." ;
    cwe:id "CWE-917" ;
    cwe:name "Improper Neutralization of Special Elements used in an Expression Language Statement ('Expression Language Injection')" .

<http://w3id.org/sepses/resource/cwe/CWE-918> a cwe:CWE ;
    cwe:description "The web server receives a URL or similar request from an upstream component and retrieves the contents of this URL, but it does not sufficiently ensure that the request is being sent to the expected destination." ;
    cwe:id "CWE-918" ;
    cwe:name "Server-Side Request Forgery (SSRF)" .

<http://w3id.org/sepses/resource/cwe/CWE-92> a cwe:CWE ;
    cwe:description "This entry has been deprecated. It originally came from PLOVER, which sometimes defined \"other\" and \"miscellaneous\" categories in order to satisfy exhaustiveness requirements for taxonomies. Within the context of CWE, the use of a more abstract entry is preferred in mapping situations. CWE-75 is a more appropriate mapping." ;
    cwe:id "CWE-92" ;
    cwe:name "DEPRECATED: Improper Sanitization of Custom Special Characters" .

<http://w3id.org/sepses/resource/cwe/CWE-920> a cwe:CWE ;
    cwe:description "The product operates in an environment in which power is a limited resource that cannot be automatically replenished, but the product does not properly restrict the amount of power that its operation consumes." ;
    cwe:id "CWE-920" ;
    cwe:name "Improper Restriction of Power Consumption" .

<http://w3id.org/sepses/resource/cwe/CWE-921> a cwe:CWE ;
    cwe:description "The product stores sensitive information in a file system or device that does not have built-in access control." ;
    cwe:id "CWE-921" ;
    cwe:name "Storage of Sensitive Data in a Mechanism without Access Control" .

<http://w3id.org/sepses/resource/cwe/CWE-922> a cwe:CWE ;
    cwe:description "The product stores sensitive information without properly limiting read or write access by unauthorized actors." ;
    cwe:id "CWE-922" ;
    cwe:name "Insecure Storage of Sensitive Information" .

<http://w3id.org/sepses/resource/cwe/CWE-923> a cwe:CWE ;
    cwe:description "The product establishes a communication channel to (or from) an endpoint for privileged or protected operations, but it does not properly ensure that it is communicating with the correct endpoint." ;
    cwe:id "CWE-923" ;
    cwe:name "Improper Restriction of Communication Channel to Intended Endpoints" .

<http://w3id.org/sepses/resource/cwe/CWE-924> a cwe:CWE ;
    cwe:description "The product establishes a communication channel with an endpoint and receives a message from that endpoint, but it does not sufficiently ensure that the message was not modified during transmission." ;
    cwe:id "CWE-924" ;
    cwe:name "Improper Enforcement of Message Integrity During Transmission in a Communication Channel" .

<http://w3id.org/sepses/resource/cwe/CWE-925> a cwe:CWE ;
    cwe:description "The Android application uses a Broadcast Receiver that receives an Intent but does not properly verify that the Intent came from an authorized source." ;
    cwe:id "CWE-925" ;
    cwe:name "Improper Verification of Intent by Broadcast Receiver" .

<http://w3id.org/sepses/resource/cwe/CWE-926> a cwe:CWE ;
    cwe:description "The Android application exports a component for use by other applications, but does not properly restrict which applications can launch the component or access the data it contains." ;
    cwe:id "CWE-926" ;
    cwe:name "Improper Export of Android Application Components" .

<http://w3id.org/sepses/resource/cwe/CWE-927> a cwe:CWE ;
    cwe:description "The Android application uses an implicit intent for transmitting sensitive data to other applications." ;
    cwe:id "CWE-927" ;
    cwe:name "Use of Implicit Intent for Sensitive Communication" .

<http://w3id.org/sepses/resource/cwe/CWE-93> a cwe:CWE ;
    cwe:description "The product uses CRLF (carriage return line feeds) as a special element, e.g. to separate lines or records, but it does not neutralize or incorrectly neutralizes CRLF sequences from inputs." ;
    cwe:id "CWE-93" ;
    cwe:name "Improper Neutralization of CRLF Sequences ('CRLF Injection')" .

<http://w3id.org/sepses/resource/cwe/CWE-939> a cwe:CWE ;
    cwe:description "The product uses a handler for a custom URL scheme, but it does not properly restrict which actors can invoke the handler using the scheme." ;
    cwe:id "CWE-939" ;
    cwe:name "Improper Authorization in Handler for Custom URL Scheme" .

<http://w3id.org/sepses/resource/cwe/CWE-94> a cwe:CWE ;
    cwe:description "The product constructs all or part of a code segment using externally-influenced input from an upstream component, but it does not neutralize or incorrectly neutralizes special elements that could modify the syntax or behavior of the intended code segment." ;
    cwe:id "CWE-94" ;
    cwe:name "Improper Control of Generation of Code ('Code Injection')" .

<http://w3id.org/sepses/resource/cwe/CWE-940> a cwe:CWE ;
    cwe:description "The product establishes a communication channel to handle an incoming request that has been initiated by an actor, but it does not properly verify that the request is coming from the expected origin." ;
    cwe:id "CWE-940" ;
    cwe:name "Improper Verification of Source of a Communication Channel" .

<http://w3id.org/sepses/resource/cwe/CWE-941> a cwe:CWE ;
    cwe:description "The product creates a communication channel to initiate an outgoing request to an actor, but it does not correctly specify the intended destination for that actor." ;
    cwe:id "CWE-941" ;
    cwe:name "Incorrectly Specified Destination in a Communication Channel" .

<http://w3id.org/sepses/resource/cwe/CWE-942> a cwe:CWE ;
    cwe:description """The product uses a web-client protection
         mechanism such as a Content Security Policy (CSP) or
         cross-domain policy file, but the policy includes untrusted
         domains with which the web client is allowed to
         communicate.""" ;
    cwe:id "CWE-942" ;
    cwe:name "Permissive Cross-domain Security Policy with Untrusted Domains" .

<http://w3id.org/sepses/resource/cwe/CWE-943> a cwe:CWE ;
    cwe:description "The product generates a query intended to access or manipulate data in a data store such as a database, but it does not neutralize or incorrectly neutralizes special elements that can modify the intended logic of the query." ;
    cwe:id "CWE-943" ;
    cwe:name "Improper Neutralization of Special Elements in Data Query Logic" .

<http://w3id.org/sepses/resource/cwe/CWE-95> a cwe:CWE ;
    cwe:description "The product receives input from an upstream component, but it does not neutralize or incorrectly neutralizes code syntax before using the input in a dynamic evaluation call (e.g. \"eval\")." ;
    cwe:id "CWE-95" ;
    cwe:name "Improper Neutralization of Directives in Dynamically Evaluated Code ('Eval Injection')" .

<http://w3id.org/sepses/resource/cwe/CWE-96> a cwe:CWE ;
    cwe:description "The product receives input from an upstream component, but it does not neutralize or incorrectly neutralizes code syntax before inserting the input into an executable resource, such as a library, configuration file, or template." ;
    cwe:id "CWE-96" ;
    cwe:name "Improper Neutralization of Directives in Statically Saved Code ('Static Code Injection')" .

<http://w3id.org/sepses/resource/cwe/CWE-97> a cwe:CWE ;
    cwe:description "The product generates a web page, but does not neutralize or incorrectly neutralizes user-controllable input that could be interpreted as a server-side include (SSI) directive." ;
    cwe:id "CWE-97" ;
    cwe:name "Improper Neutralization of Server-Side Includes (SSI) Within a Web Page" .

<http://w3id.org/sepses/resource/cwe/CWE-98> a cwe:CWE ;
    cwe:description "The PHP application receives input from an upstream component, but it does not restrict or incorrectly restricts the input before its usage in \"require,\" \"include,\" or similar functions." ;
    cwe:id "CWE-98" ;
    cwe:name "Improper Control of Filename for Include/Require Statement in PHP Program ('PHP Remote File Inclusion')" .

<http://w3id.org/sepses/resource/cwe/CWE-99> a cwe:CWE ;
    cwe:description "The product receives input from an upstream component, but it does not restrict or incorrectly restricts the input before it is used as an identifier for a resource that may be outside the intended sphere of control." ;
    cwe:id "CWE-99" ;
    cwe:name "Improper Control of Resource Identifiers ('Resource Injection')" .

